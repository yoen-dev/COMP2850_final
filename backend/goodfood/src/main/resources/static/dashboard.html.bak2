<style>
.fmb{font-family:'JetBrains Mono',monospace;font-size:9px;padding:5px 12px;border-radius:20px;border:1px solid #d4dfd8;background:#fff;color:#3d5448;cursor:pointer}
.fmb.active{background:#0a1410;color:#fff;border-color:#0a1410}
.meal-picker-wrap{position:relative}
.meal-picker-btn{font-family:'JetBrains Mono',monospace;font-size:11px;padding:8px 14px;border-radius:8px;border:1px solid #d4dfd8;background:#fff;color:#0a1410;cursor:pointer;font-weight:600;transition:all .2s}
.meal-picker-btn:hover{border-color:#1e6b5e;color:#1e6b5e}
.meal-picker-menu{display:none;position:absolute;bottom:42px;right:0;background:#fff;border:1px solid #d4dfd8;border-radius:10px;min-width:240px;box-shadow:0 8px 30px rgba(10,20,16,0.12);overflow:hidden;z-index:10}
.meal-picker-menu.show{display:block}
.meal-picker-item{padding:11px 16px;font-size:12px;color:#3d5448;cursor:pointer;border-bottom:1px solid #f5f7f5;transition:background .15s}
.meal-picker-item:last-child{border-bottom:none}
.meal-picker-item:hover{background:#e8f4f2;color:#0a1410}
.meal-picker-item.active{color:#1e6b5e;font-weight:700;background:#e8f4f2}
.fcb{font-family:'JetBrains Mono',monospace;font-size:9px;padding:4px 10px;border-radius:14px;border:1px solid #d4dfd8;background:#fff;color:#4d6e5e;cursor:pointer}
.fcb.active{background:#e8f4f2;color:#1e6b5e;border-color:#b8ddd8}
.frow{display:flex;align-items:center;gap:12px;padding:10px 22px;cursor:pointer;transition:background .15s;border-bottom:1px solid #f5f7f5}
.frow:hover{background:#e8f4f2}
.fico{width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
.finf{flex:1;font-size:12px;color:#0a1410;line-height:1.5}
.fadd{width:28px;height:28px;border-radius:7px;border:1px solid #d4dfd8;background:#fff;display:flex;align-items:center;justify-content:center;font-size:16px;color:#1e6b5e;flex-shrink:0;transition:all .15s}
.frow:hover .fadd{background:#1e6b5e;color:#fff;border-color:#1e6b5e}
/* Tour — removed, will be rebuilt */

/* ── MEAL PLANNER ── */
.mp-meal-section { background:var(--white); border:1px solid var(--border); border-radius:14px; padding:18px 20px; margin-bottom:14px; box-shadow:0 2px 8px rgba(10,20,16,0.03); }
.mp-meal-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:14px; }
.mp-meal-title { display:flex; align-items:center; gap:8px; }
.mp-meal-title span:first-child { font-size:16px; }
.mp-meal-title .mp-name { font-size:13px; font-weight:700; color:var(--ink); }
.mp-meal-title .mp-kcal { font-family:'JetBrains Mono',monospace; font-size:9px; color:var(--ink-f); }
.mp-refresh { font-size:11px; color:var(--amber); cursor:pointer; background:var(--amber-ll); border:1px solid var(--amber-l); border-radius:8px; padding:6px 14px; font-family:'Bricolage Grotesque',sans-serif; font-weight:600; display:inline-flex; align-items:center; gap:5px; transition:all .2s; }
.mp-refresh:hover { background:var(--amber); color:#fff; border-color:var(--amber); }
.mp-cards { display:flex; gap:12px; flex-wrap:wrap; }
.mp-card { min-width:140px; max-width:200px; flex:1; border-radius:12px; overflow:hidden; transition:all .2s; }
.mp-card.locked { border:1.5px solid var(--teal); }
.mp-card.suggested { border:1.5px dashed var(--amber-l); }
.mp-card .mp-card-img { height:80px; display:flex; align-items:center; justify-content:center; font-size:28px; position:relative; }
.mp-card .mp-card-body { padding:10px; }
.mp-card .mp-card-name { font-size:11px; font-weight:700; color:var(--ink); }
.mp-card .mp-card-meta { font-family:'JetBrains Mono',monospace; font-size:9px; color:var(--ink-f); margin-top:2px; }
.mp-card .mp-card-actions { display:flex; justify-content:space-between; margin-top:8px; }
.mp-card .mp-card-actions span { font-size:9px; cursor:pointer; transition:color .2s; }
.mp-card .mp-badge { position:absolute; top:6px; right:6px; color:#fff; font-family:'JetBrains Mono',monospace; font-size:7px; padding:2px 6px; border-radius:8px; }
.mp-add-card { min-width:140px; max-width:200px; flex:1; border:1.5px dashed var(--border); border-radius:12px; display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:140px; cursor:pointer; transition:all .2s; color:var(--ink-f); }
.mp-add-card:hover { border-color:var(--teal); color:var(--teal); }
.mp-picker-item { display:flex; align-items:center; gap:14px; padding:12px 0; border-bottom:1px solid var(--fog); cursor:pointer; transition:background .15s; }
.mp-picker-item:hover { background:var(--teal-lll); margin:0 -24px; padding-left:24px; padding-right:24px; }
.mp-picker-item:last-child { border-bottom:none; }
body.dark-mode .mp-meal-section { background:#142420; border-color:#2a3e34; }
body.dark-mode .mp-picker-item:hover { background:#1e3028; }
body.dark-mode #mp-picker-overlay > div { background:#142420; }

</style>
<!-- ── MY NUTRITIONIST PAGE ── -->
<div class="page" id="page-mypro" role="tabpanel" aria-label="My Nutritionist">
  <div class="page-header">
    <div class="page-title">My <em>Nutritionist</em></div>
    <div class="page-date" id="mypro-subtitle">Connect with a professional to get personalised advice</div>
  </div>
  <div id="mypro-content"></div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
/* Exercise Chart */
const EX_TARGET = 350;
const EX_LABELS = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
const exChartData = [280, 420, 0, 310, 390, 500, 180];
let exChartInstance = null;

function initExerciseChart(){
  const ctx = document.getElementById('exerciseChart').getContext('2d');
  const daysHit = exChartData.filter((v,i)=>i<6&&v>=EX_TARGET).length;
  document.getElementById('weekSummary').textContent = daysHit+'/6 days on target this week';
  const barColors = exChartData.map(v=>v===0?'#dce6e0':v>=EX_TARGET?'#1e6b5e':'#2f8f7f');
  exChartInstance = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: EX_LABELS,
      datasets: [
        { label:'Actual (kcal)', data:[...exChartData], backgroundColor:barColors, borderRadius:5, borderSkipped:false, barPercentage:0.55, categoryPercentage:0.75, order:1 },
        { label:'Target', data:Array(7).fill(EX_TARGET), type:'line', borderColor:'#b8621f', borderWidth:1.5, borderDash:[4,3], pointRadius:0, pointHoverRadius:0, fill:false, tension:0, order:0 }
      ]
    },
    options: {
      responsive:true, maintainAspectRatio:false,
      plugins: {
        legend: { display:false },
        tooltip: {
          callbacks: { label: c => c.dataset.label==='Target'?'Target: '+EX_TARGET+' kcal':'Burned: '+c.parsed.y+' kcal' },
          backgroundColor:'#0a1410', titleColor:'rgba(255,255,255,0.5)', bodyColor:'#fff',
          titleFont:{family:"'JetBrains Mono',monospace",size:9}, bodyFont:{family:"'JetBrains Mono',monospace",size:11},
          padding:10, cornerRadius:6
        }
      },
      scales: {
        x: { grid:{display:false}, border:{display:false}, ticks:{font:{family:"'JetBrains Mono',monospace",size:9},color:'#6b8878'} },
        y: { min:0, max:600, grid:{color:'#dce6e0',lineWidth:0.5}, border:{display:false,dash:[4,4]},
             ticks:{font:{family:"'JetBrains Mono',monospace",size:9},color:'#6b8878',stepSize:200,callback:v=>v===0?'':v} }
      }
    }
  });
}

function updateExerciseChart(){
  if(!exChartInstance) return;
  const todayKcal = exLog.reduce((s,e)=>s+e.kcal,0);
  exChartData[6] = todayKcal;
  const barColors = exChartData.map(v=>v===0?'#dce6e0':v>=EX_TARGET?'#1e6b5e':'#2f8f7f');
  exChartInstance.data.datasets[0].data = [...exChartData];
  exChartInstance.data.datasets[0].backgroundColor = barColors;
  exChartInstance.update();
  const daysHit = exChartData.filter((v,i)=>i<6&&v>=EX_TARGET).length;
  document.getElementById('weekSummary').textContent = daysHit+'/6 days on target this week';
}
</script>

<script>
// ── Panels ────────────────────────────────────────────────────────────────────
function openPanel(t){
  if(t==='food'){
    foodAdded=[];
    document.querySelectorAll('#foodPanel .frow').forEach(r=>{
      r.style.background='';
      const fadd=r.querySelector('.fadd');
      if(fadd){fadd.textContent='+';fadd.style.cssText='';}
    });
    document.getElementById('foodCount').textContent='0 items added';
    document.getElementById('foodDim').style.display='block';
    document.getElementById('foodPanel').style.display='flex';
  } else {
    openExPanel();
  }
}
function closeFoodPanel(){
  if(foodAdded.length>0) commitFoodEntries();
  document.getElementById('foodDim').style.display='none';
  document.getElementById('foodPanel').style.display='none';
}
function closeExPanel(){document.getElementById('exDim').style.display='none';document.getElementById('exPanel').style.display='none';}

// ── Avatar menu (v3 feature) ──────────────────────────────────────────────────
function toggleAvatarMenu(e){e.stopPropagation();var m=document.getElementById('avatarMenu');m.classList.toggle('open');if(m.classList.contains('open')){var a=m.querySelector('a');if(a)setTimeout(function(){a.focus()},50)}}
function switchBackToPro(){
  window.location.replace('pro_dashboard.html');
}
function closeAvatarMenu(){document.getElementById('avatarMenu').classList.remove('open')}
document.addEventListener('click',function(){closeAvatarMenu()});

// ── Settings / nav ────────────────────────────────────────────────────────────
function showSettingsPage(p){
  document.querySelectorAll('.settings-overlay').forEach(o=>o.classList.remove('open'));
  document.getElementById('overlay-'+p).classList.add('open');
  document.querySelectorAll('.sn-item').forEach(i=>i.classList.remove('active'));
  closeAvatarMenu();
}
function closeSettings(){
  document.querySelectorAll('.settings-overlay').forEach(o=>o.classList.remove('open'));
  document.querySelectorAll('.page').forEach(pg=>{
    if(pg.classList.contains('active')){
      const id=pg.id.replace('page-','');
      document.querySelectorAll('.sn-item').forEach(i=>{
        if(i.getAttribute('onclick')&&i.getAttribute('onclick').includes("'"+id+"'")){i.classList.add('active');}
      });
    }
  });
}
function openCompareSelect(){document.getElementById('compare-select').classList.add('open')}
function closeCompareSelect(){
  document.getElementById('compare-select').classList.remove('open');
  compareSelected.clear();
  document.querySelectorAll('#compare-select .fav-item.selected').forEach(el=>{
    if(el.dataset.recipeId) compareSelected.add(el.dataset.recipeId);
  });
  renderComparePage();
}
function switchPage(p,el){
  closeSettings();
  var pg=document.getElementById('page-'+p);
  if(!pg){
    // page not injected yet (e.g. community-hub.js not ready) — retry once after short delay
    setTimeout(function(){ var pg2=document.getElementById('page-'+p); if(pg2){ document.querySelectorAll('.page').forEach(function(x){x.classList.remove('active');}); pg2.classList.add('active'); document.querySelectorAll('.sn-item').forEach(function(i){i.classList.remove('active');}); if(el) el.classList.add('active'); } }, 150);
    return;
  }
  document.querySelectorAll('.page').forEach(x=>x.classList.remove('active'));
  pg.classList.add('active');
  document.querySelectorAll('.sn-item').forEach(i=>i.classList.remove('active'));
  if(el) el.classList.add('active');
  if(p==='favourites') renderFavouritesPage();
  if(p==='plan') renderComparePage();
}
function switchChartTab(el){el.parentElement.querySelectorAll('.cc-tab').forEach(t=>t.classList.remove('active'));el.classList.add('active');}
function pickMeal(el){el.parentElement.querySelectorAll('.fmb').forEach(b=>b.classList.remove('active'));el.classList.add('active');}
function selectMealSlot(el,label){el.parentElement.querySelectorAll('.meal-picker-item').forEach(i=>i.classList.remove('active'));el.classList.add('active');document.getElementById('mealPickerBtn').textContent=label+' ▾';document.getElementById('mealPickerMenu').classList.remove('show');}
function pickCat(el){el.parentElement.querySelectorAll('.fcb').forEach(c=>c.classList.remove('active'));el.classList.add('active');}
function selCat(el){el.parentElement.querySelectorAll('.sp-cat').forEach(c=>c.classList.remove('active'));el.classList.add('active');}

// ── Date ──────────────────────────────────────────────────────────────────────
// ── Back to Pro mode ──────────────────────────────────────────────────────────
function backToPro() {
  try { sessionStorage.removeItem('nw-from-pro'); } catch(e) {}
  window.location.replace('pro_dashboard.html');
}
(function checkFromPro() {
  try {
    if (sessionStorage.getItem('nw-from-pro') === '1') {
      var wrap = document.getElementById('back-to-pro-wrap');
      if (wrap) wrap.style.display = 'block';
    }
  } catch(e) {}
})();

const d=new Date(),days=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'],months=['January','February','March','April','May','June','July','August','September','October','November','December'];
document.getElementById('today-date').textContent=days[d.getDay()]+', '+d.getDate()+' '+months[d.getMonth()]+' '+d.getFullYear();

// ── State ─────────────────────────────────────────────────────────────────────
var DAILY_TARGET=2400;
let foodAdded=[];
let favourites=new Set();
let compareSelected=new Set();

const RECIPES={
  'mediterranean-quinoa':{id:'mediterranean-quinoa',emoji:'🥗',name:'Mediterranean Quinoa Bowl',tag:'Healthy · 15 min',kcal:420,cost:'£3.20',rating:'★★★★☆',bg:'var(--teal-lll)',ingredients:['200g quinoa','1 cucumber','200g cherry tomatoes','100g feta','Olives','Olive oil & lemon'],steps:['Cook quinoa, allow to cool.','Dice cucumber, halve tomatoes.','Combine all in a bowl.','Drizzle with olive oil and lemon.','Season and serve.']},
  'shakshuka':{id:'shakshuka',emoji:'🍳',name:'Shakshuka',tag:'Quick · 20 min',kcal:380,cost:'£2.40',rating:'★★★★★',bg:'var(--amber-ll)',ingredients:['4 eggs','400g chopped tomatoes','1 red pepper','1 onion','2 garlic cloves','1 tsp cumin','1 tsp paprika'],steps:['Fry onion and pepper until soft.','Add garlic and spices, cook 1 min.','Add tomatoes, simmer 10 min.','Make wells, crack in eggs.','Cover and cook until whites set.']},
  'grilled-salmon':{id:'grilled-salmon',emoji:'🐟',name:'Grilled Salmon & Greens',tag:'Omega-3 · 25 min',kcal:510,cost:'£4.50',rating:'★★★★☆',bg:'rgba(122,170,212,0.15)',ingredients:['2 salmon fillets','200g asparagus','100g spinach','1 lemon','Olive oil','Salt & pepper'],steps:['Season salmon with salt and lemon zest.','Cook salmon 3-4 min each side.','Blanch asparagus 2 min.','Wilt spinach in pan.','Serve with lemon.']},
  'avocado-toast':{id:'avocado-toast',emoji:'🥑',name:'Avocado Toast',tag:'Vegan · 10 min',kcal:290,cost:'£1.80',rating:'★★★★★',bg:'var(--teal-lll)',ingredients:['2 slices sourdough','1 ripe avocado','Lemon juice','Chilli flakes','Salt & pepper'],steps:['Toast bread until golden.','Mash avocado with lemon, salt, pepper.','Spread onto toast.','Top with chilli flakes.']},
  'pasta-primavera':{id:'pasta-primavera',emoji:'🍝',name:'Pasta Primavera',tag:'Italian · 30 min',kcal:460,cost:'£2.90',rating:'★★★★☆',bg:'var(--amber-ll)',ingredients:['300g penne','2 courgettes','1 red pepper','200g cherry tomatoes','3 garlic cloves','Parmesan'],steps:['Cook pasta al dente.','Sauté garlic in olive oil.','Add veg, cook until tender.','Toss with pasta.','Finish with parmesan.']},
  'lentil-soup':{id:'lentil-soup',emoji:'🍲',name:'Lentil & Sweet Potato Soup',tag:'Comfort · 40 min',kcal:320,cost:'£1.60',rating:'★★★★★',bg:'rgba(224,123,120,0.1)',ingredients:['200g red lentils','1 sweet potato','1 onion','2 garlic cloves','1 tsp cumin','400ml veg stock'],steps:['Dice sweet potato and onion.','Fry onion and garlic.','Add cumin, lentils, sweet potato.','Pour in stock, simmer 25 min.','Blend half, stir in coconut milk.']}
};
window.RECIPES = RECIPES;  // expose for patch.js fridge mode & cooking mode

// ── Toast ─────────────────────────────────────────────────────────────────────
function showToast(msg,color){
  let t=document.getElementById('nw-toast');
  if(!t){t=document.createElement('div');t.id='nw-toast';t.style.cssText='position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(12px);background:#0a1410;color:#fff;padding:10px 22px;border-radius:10px;font-size:13px;font-weight:600;z-index:9999;opacity:0;transition:all .3s;pointer-events:none;white-space:nowrap;font-family:Bricolage Grotesque,sans-serif';document.body.appendChild(t);}
  t.textContent=msg; t.style.background=color||'#0a1410';
  t.style.opacity='1'; t.style.transform='translateX(-50%) translateY(0)';
  clearTimeout(t._t); t._t=setTimeout(()=>{t.style.opacity='0';t.style.transform='translateX(-50%) translateY(12px)';},2200);
}

// ── Food panel ────────────────────────────────────────────────────────────────
function addFoodItem(row){
  const b=row.querySelector('b'),meta=row.querySelector('.finf span'),fadd=row.querySelector('.fadd');
  if(!b||!meta) return;
  const name=b.textContent,m=meta.textContent.match(/\d+/),kcal=m?parseInt(m[0]):0;
  const idx=foodAdded.findIndex(i=>i.name===name);
  if(idx>-1){
    foodAdded.splice(idx,1);
    row.style.background=''; fadd.textContent='+'; fadd.style.cssText='';
  } else {
    const now=new Date(),ts=now.getHours().toString().padStart(2,'0')+':'+now.getMinutes().toString().padStart(2,'0');
    foodAdded.push({name,kcal,time:ts});
    row.style.background='#e8f4f2'; fadd.textContent='✓';
    fadd.style.background='#1e6b5e'; fadd.style.color='#fff'; fadd.style.borderColor='#1e6b5e';
  }
  const total=foodAdded.reduce((s,i)=>s+i.kcal,0);
  document.getElementById('foodCount').textContent=foodAdded.length===0?'0 items added':foodAdded.length+' item'+(foodAdded.length>1?'s':'')+' · '+total+' kcal';
}

function commitFoodEntries(){
  if(!foodAdded.length) return;
  const btn=document.getElementById('mealPickerBtn');
  const label=btn?btn.textContent:'🌅 Breakfast';
  const keyMap={
    'Breakfast':'breakfast','Morning Snack':'morningSnack',
    'Lunch':'lunch','Afternoon Snack':'afternoonSnack',
    'Dinner':'dinner','Evening Snack':'eveningSnack'
  };
  // match label text against keyMap keys
  const key=Object.keys(keyMap).find(k=>label.includes(k));
  const mealKey=key?keyMap[key]:'breakfast';
  foodAdded.forEach(item=>mealLog[mealKey].push(item));
  renderMealLog();
  updateDonut();
  updateCalorieTrend();
  showToast('✓ '+foodAdded.length+' item'+(foodAdded.length>1?'s':'')+' added','#1e6b5e');
  foodAdded=[];
}

// ── Meal log ──────────────────────────────────────────────────────────────────
const mealLog={
  breakfast:[{time:'07:30',name:'Oat porridge & banana',kcal:340}],
  morningSnack:[],
  lunch:[{time:'12:15',name:'Chicken Caesar salad',kcal:520}],
  afternoonSnack:[{time:'15:40',name:'Bubble tea',kcal:380}],
  dinner:[{time:'19:00',name:'Pad Thai',kcal:680}],
  eveningSnack:[]
};
const mealSections=[
  {col:'breakfast-col',header:'🌅 Breakfast & Morning Snack',secs:[{label:'Breakfast',key:'breakfast'},{label:'Morning Snack',key:'morningSnack'}]},
  {col:'lunch-col',header:'☀️ Lunch & Afternoon Snack',secs:[{label:'Lunch',key:'lunch'},{label:'Afternoon Snack',key:'afternoonSnack'}]},
  {col:'dinner-col',header:'🌙 Dinner & Evening Snack',secs:[{label:'Dinner',key:'dinner'},{label:'Evening Snack',key:'eveningSnack'}]}
];
function renderMealLog(){
  mealSections.forEach(col=>{
    const el=document.getElementById(col.col); if(!el) return;
    let h=`<div class="mc-header">${col.header}</div>`;
    col.secs.forEach(sec=>{
      h+=`<div class="mc-section"><div class="mc-section-label">${sec.label}</div>`;
      const entries=mealLog[sec.key];
      if(!entries.length) h+=`<div class="mc-empty">Nothing logged</div>`;
      else entries.forEach((e,i)=>{
        h+=`<div class="mc-row"><span class="mc-time">${escapeHtml(e.time)}</span><span class="mc-name">${escapeHtml(e.name)}</span><span class="mc-kcal">${e.kcal}</span><span tabindex="0" role="button" onclick="deleteMeal('${sec.key}',${i})" style="cursor:pointer;font-size:10px;color:#4d6e5e;margin-left:6px;opacity:.5" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=.5">✕</span></div>`;
      });
      h+=`</div>`;
    });
    h+=`<div class="mc-add" onclick="openPanel('food')">+ Add item</div>`;
    el.innerHTML=h;
  });
}
function deleteMeal(key,idx){mealLog[key].splice(idx,1);renderMealLog();updateDonut();updateCalorieTrend();}

// ── Donut ─────────────────────────────────────────────────────────────────────
function updateDonut(){
  var _target = window._nwDailyTarget || DAILY_TARGET;
  let kcal=0; Object.values(mealLog).forEach(arr=>arr.forEach(e=>kcal+=e.kcal));
  const carbs=Math.round(kcal*.42/4),protein=Math.round(kcal*.28/4),fat=Math.round(kcal*.18/9),sugar=Math.round(kcal*.12/4);
  const circ=2*Math.PI*48,pct=Math.min(kcal/_target,1);
  const segs=[{p:.42,c:'#2f8f7f'},{p:.28,c:'#d4956a'},{p:.18,c:'#7aaad4'},{p:.12,c:'#e07b78'}];
  const svg=document.querySelector('.dc-donut svg'); if(!svg) return;
  let a=-90,h=`<circle cx="75" cy="75" r="48" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="16"/>`;
  segs.forEach(s=>{const da=(circ*s.p*pct).toFixed(1);h+=`<circle cx="75" cy="75" r="48" fill="none" stroke="${s.c}" stroke-width="16" stroke-dasharray="${da} ${circ}" stroke-linecap="butt" transform="rotate(${a} 75 75)"/>`;a+=360*s.p*pct;});
  h+=`<text x="75" y="72" text-anchor="middle" font-size="20" font-weight="700" fill="#fff" font-family="Bricolage Grotesque,sans-serif">${kcal.toLocaleString()}</text><text x="75" y="88" text-anchor="middle" font-size="9" fill="rgba(255,255,255,0.35)" font-family="JetBrains Mono,monospace">kcal today</text>`;
  svg.innerHTML=h;
  const leg=document.querySelector('.dc-legend');
  if(leg) leg.innerHTML=`<div class="dc-leg-row"><div class="dc-leg-dot" style="background:#1a7a6a"></div><span class="dc-leg-name">Carbs</span><span class="dc-leg-val">42% · ${carbs}g</span></div><div class="dc-leg-row"><div class="dc-leg-dot" style="background:#d4956a"></div><span class="dc-leg-name">Protein</span><span class="dc-leg-val">28% · ${protein}g</span></div><div class="dc-leg-row"><div class="dc-leg-dot" style="background:#7aaad4"></div><span class="dc-leg-name">Fat</span><span class="dc-leg-val">18% · ${fat}g</span></div><div class="dc-leg-row"><div class="dc-leg-dot" style="background:#b5413e"></div><span class="dc-leg-name">Sugar</span><span class="dc-leg-val">12% · ${sugar}g</span></div>`;
  const tn=document.querySelector('.dc-total-num');if(tn)tn.innerHTML=`${kcal.toLocaleString()} <span class="dc-total-sub">/ ${_target.toLocaleString()}</span>`;
  const tp=document.querySelector('.dc-total-pct');if(tp)tp.textContent=Math.round(kcal/_target*100)+'%';
}

// ── Recipe detail ─────────────────────────────────────────────────────────────
function openRecipeDetail(id){
  const r=RECIPES[id]; if(!r) return;
  let panel=document.getElementById('recipe-detail-panel');
  if(!panel){
    const dim=document.createElement('div');
    dim.id='recipe-detail-dim';
    dim.style.cssText='position:fixed;inset:0;background:rgba(0,0,0,0.25);z-index:2999;display:none';
    dim.onclick=closeRecipeDetail;
    panel=document.createElement('div');
    panel.id='recipe-detail-panel';panel.setAttribute('role','dialog');panel.setAttribute('aria-modal','true');panel.setAttribute('aria-label','Recipe details');
    panel.style.cssText='position:fixed;top:0;right:-480px;bottom:0;width:480px;background:#fff;z-index:3000;box-shadow:-8px 0 40px rgba(0,0,0,0.15);display:flex;flex-direction:column;transition:right .35s cubic-bezier(.4,0,.2,1)';
    document.body.appendChild(dim);
    document.body.appendChild(panel);
  }
  panel.innerHTML=`
    <div style="padding:18px 22px;border-bottom:1px solid #d4dfd8;display:flex;justify-content:space-between;align-items:center;flex-shrink:0">
      <div style="font-family:'Instrument Serif',serif;font-size:20px;font-style:italic;color:#0a1410">${r.emoji} ${r.name}</div>
      <button onclick="closeRecipeDetail()" style="width:32px;height:32px;border-radius:6px;border:none;background:#f5f7f5;font-size:16px;cursor:pointer">✕</button>
    </div>
    <div style="flex:1;overflow-y:auto;padding:16px 22px">
      <div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#4d6e5e;text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px">Ingredients</div>
      ${r.ingredients.map(i=>`<div style="display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid #f5f7f5;font-size:13px;color:#0a1410"><div style="width:5px;height:5px;border-radius:50%;background:#1e6b5e;flex-shrink:0"></div>${i}</div>`).join('')}
      <div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#4d6e5e;text-transform:uppercase;letter-spacing:.08em;margin:16px 0 10px">Method</div>
      ${r.steps.map((s,i)=>`<div style="display:flex;gap:12px;padding:10px 0;border-bottom:1px solid #f5f7f5"><div style="width:22px;height:22px;border-radius:50%;background:#0a1410;color:#fff;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0">${i+1}</div><div style="font-size:13px;color:#0a1410;line-height:1.55">${s}</div></div>`).join('')}
    </div>
    <div style="padding:14px 22px;border-top:1px solid #d4dfd8;display:flex;justify-content:space-between;align-items:center;flex-shrink:0">
      <span style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#4d6e5e">${r.kcal} kcal · ${r.cost} · ${r.rating}</span>
      <button onclick="openCookingMode('${id}')" aria-label="Start step-by-step cooking mode for ${r.name}" style="padding:9px 18px;background:transparent;color:#1e6b5e;border:1.5px solid #1e6b5e;border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:12px;font-weight:600;cursor:pointer;display:inline-flex;align-items:center;gap:6px;margin-right:8px"><span aria-hidden="true">👨‍🍳</span> Cook</button><button id="detail-fav-btn" data-id="${id}" onclick="toggleFavFromDetail(this)" style="padding:9px 20px;background:${favourites.has(id)?'#1e6b5e':'#0a1410'};color:#fff;border:none;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer">${favourites.has(id)?'❤️ Saved':'🤍 Save'}</button>
    </div>`;
  document.getElementById('recipe-detail-dim').style.display='block';
  setTimeout(()=>panel.style.right='0',10);
}
document.addEventListener('keydown',function(e){if(e.key==='Escape'){var p=document.getElementById('recipe-detail-panel');if(p&&p.style.right==='0px')closeRecipeDetail();}});
function closeRecipeDetail(){
  const panel=document.getElementById('recipe-detail-panel');
  const dim=document.getElementById('recipe-detail-dim');
  if(panel) panel.style.right='-480px';
  if(dim) dim.style.display='none';
}
function toggleFavFromDetail(btn){
  const id=btn.dataset.id;
  if(favourites.has(id)){favourites.delete(id);btn.textContent='🤍 Save';btn.style.background='#0a1410';showToast('Removed from favourites');}
  else{favourites.add(id);btn.textContent='❤️ Saved';btn.style.background='#1e6b5e';showToast('❤️ Saved','#1e6b5e');}
  const heart=document.querySelector(`[data-recipe-id="${id}"] .rc-fav`);
  if(heart) heart.textContent=favourites.has(id)?'❤️':'🤍';
}

// ── Exercise panel ────────────────────────────────────────────────────────────
let exAdded=[];
function addExItem(row){
  const b=row.querySelector('b'),meta=row.querySelector('.finf span'),fadd=row.querySelector('.fadd');
  if(!b||!meta) return;
  const name=b.textContent,m=meta.textContent.match(/\d+/),kcalPerHour=m?parseInt(m[0]):300;
  const idx=exAdded.findIndex(i=>i.name===name);
  if(idx>-1){
    exAdded.splice(idx,1);
    row.style.background=''; fadd.textContent='+'; fadd.style.cssText='';
  } else {
    exAdded.push({name,kcalPerHour});
    row.style.background='#e8f4f2'; fadd.textContent='✓';
    fadd.style.background='#1e6b5e'; fadd.style.color='#fff'; fadd.style.borderColor='#1e6b5e';
  }
  const exCount=document.getElementById('exCount');
  if(exCount) exCount.textContent=exAdded.length===0?'0 exercises selected':exAdded.length+' exercise'+(exAdded.length>1?'s':'')+' selected';
}

function openExPanel(){
  exAdded=[];
  document.querySelectorAll('#exPanel .frow').forEach(r=>{
    r.style.background='';
    const fadd=r.querySelector('.fadd');
    if(fadd){fadd.textContent='+';fadd.style.cssText='';}
  });
  const exCount=document.getElementById('exCount');
  if(exCount) exCount.textContent='0 exercises selected';
  document.getElementById('exDim').style.display='block';
  document.getElementById('exPanel').style.display='flex';
}
function closeExPanel(){
  if(exAdded.length>0){
    const now=new Date(),ts=now.getHours().toString().padStart(2,'0')+':'+now.getMinutes().toString().padStart(2,'0');
    exAdded.forEach(ex=>{
      exLog.push({time:ts,name:ex.name,kcal:ex.kcalPerHour});
    });
    renderExerciseLog();
    updateExerciseChart();
    showToast('✓ '+exAdded.length+' exercise'+(exAdded.length>1?'s':'')+' logged','#1e6b5e');
    exAdded=[];
  }
  document.getElementById('exDim').style.display='none';
  document.getElementById('exPanel').style.display='none';
}

// Exercise log state
const exLog=[];
function renderExerciseLog(){
  const el=document.getElementById('exercise-log'); if(!el) return;
  if(!exLog.length){el.innerHTML='<div style="font-size:11px;color:#4d6e5e;font-style:italic;padding:8px 0">No exercise logged today</div>';return;}
  el.innerHTML=exLog.map((e,i)=>`
    <div style="display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid #f5f7f5">
      <span style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#4d6e5e;min-width:40px">${e.time}</span>
      <span style="flex:1;font-size:12px;font-weight:600;color:#0a1410">${escapeHtml(e.name)}</span>
      <span style="font-family:'JetBrains Mono',monospace;font-size:10px;color:#3d5448">${e.kcal} kcal/h</span>
      <span tabindex="0" role="button" onclick="deleteEx(${i})" style="cursor:pointer;font-size:10px;color:#4d6e5e;opacity:.5" onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=.5">✕</span>
    </div>`).join('');
}
function deleteEx(idx){exLog.splice(idx,1);renderExerciseLog();}
function toggleFav(id,heart){
  if(favourites.has(id)){favourites.delete(id);heart.textContent='🤍';showToast('Removed from favourites');}
  else{favourites.add(id);heart.textContent='❤️';showToast('❤️ Saved','#1e6b5e');}
}
function renderFavouritesPage(){
  if(favourites.size===0){
    document.getElementById('fav-cards-grid').innerHTML='<div class="empty-state" style="grid-column:1/-1"><div class="empty-state-icon" aria-hidden="true">🌱</div><div class="empty-state-title">No favourites yet</div><div class="empty-state-body">Tap the heart on any recipe to save it here.</div></div>';
    return;
  }
  const grid=document.getElementById('fav-cards-grid'); if(!grid) return;
  const list=Object.values(RECIPES).filter(r=>favourites.has(r.id));
  if(!list.length){grid.innerHTML=`<div style="grid-column:1/-1;text-align:center;padding:48px 0;color:#4d6e5e;font-size:13px">No favourites yet — tap ❤️ on any recipe</div>`;return;}
  grid.innerHTML=list.map(r=>`
    <div class="fav-card" tabindex="0" role="button" onclick="openRecipeDetail('${r.id}')" style="cursor:pointer">
      <div class="fav-card-img" style="background:${r.bg}">${r.emoji}</div>
      <div class="fav-card-body">
        <div class="fav-card-title">${r.name}</div>
        <div class="fav-card-meta">${r.kcal} kcal · ${r.tag.split('·')[1]?.trim()||''} · ${r.cost}</div>
        <div class="fav-card-footer">
          <span class="fav-card-rating">${r.rating}</span>
          <span class="fav-remove" onclick="event.stopPropagation();removeFav('${r.id}',this)">Remove</span>
        </div>
      </div>
    </div>`).join('');
}
function removeFav(id,el){
  favourites.delete(id);
  const heart=document.querySelector(`[data-recipe-id="${id}"] .rc-fav`);
  if(heart) heart.textContent='🤍';
  const card=el.closest('.fav-card');
  card.style.transition='opacity .3s';card.style.opacity='0';
  setTimeout(()=>renderFavouritesPage(),300);
  showToast('Removed from favourites');
}

// ── Recipe Compare ────────────────────────────────────────────────────────────
function removeCompareChip(id){compareSelected.delete(id);renderComparePage();}
function renderComparePage(){
  const chips=document.getElementById('compare-chips'); if(!chips) return;
  const colors=['#1e6b5e','#b8621f','#7aaad4','#e07b78'],ids=[...compareSelected];
  chips.innerHTML=ids.map((id,i)=>{const r=RECIPES[id];return r?`<div class="plan-chip selected"><div class="chip-dot" style="background:${colors[i]}"></div>${r.name}<span class="chip-remove" onclick="removeCompareChip('${id}')">×</span></div>`:''}).join('');
  if(ids.length<4) chips.innerHTML+=`<button class="plan-add" onclick="openCompareSelect()">+ Add from favourites (${4-ids.length} left)</button>`;
  const leg=document.getElementById('compare-legend');
  if(leg) leg.innerHTML=ids.map((id,i)=>`<div class="pc-leg-item"><div class="pc-leg-dot" style="background:${colors[i]}"></div>${RECIPES[id]?.name||id}</div>`).join('');
  renderCompareChart(ids,colors);
}
function renderCompareChart(ids,colors){
  const wrap=document.getElementById('compare-chart-svg-wrap'); if(!wrap) return;
  const nutrients=['Calories','Protein','Carbs','Fat'];
  const getVal=(id,n)=>{const r=RECIPES[id];if(!r)return 0;return{Calories:r.kcal,Protein:Math.round(r.kcal*.28/16),Carbs:Math.round(r.kcal*.42/20),Fat:Math.round(r.kcal*.18/27)}[n]||0;};
  const maxVal=Math.max(...nutrients.flatMap(n=>ids.map(id=>getVal(id,n))),1);
  const W=700,H=300,padL=60,innerH=H-70,innerW=W-padL-20,groupW=innerW/nutrients.length,barW=Math.min(28,groupW/(ids.length+1));
  let svg=`<svg width="100%" height="${H}" viewBox="0 0 ${W} ${H}">`;
  [0,.25,.5,.75,1].forEach(f=>{const y=20+innerH*(1-f);svg+=`<line x1="${padL}" y1="${y}" x2="${W-20}" y2="${y}" stroke="#dce6e0" stroke-width="0.5" stroke-dasharray="${f?'4':'0'}"/><text x="${padL-6}" y="${y+4}" text-anchor="end" font-size="9" fill="#6b8878" font-family="JetBrains Mono,monospace">${Math.round(maxVal*f)}</text>`;});
  svg+=`<line x1="${padL}" y1="20" x2="${padL}" y2="${20+innerH}" stroke="#d4dfd8" stroke-width="1"/><line x1="${padL}" y1="${20+innerH}" x2="${W-20}" y2="${20+innerH}" stroke="#d4dfd8" stroke-width="1"/>`;
  nutrients.forEach((n,gi)=>{
    const gx=padL+gi*groupW+groupW/2;
    ids.forEach((id,bi)=>{const val=getVal(id,n),bh=innerH*(val/maxVal),x=gx-(ids.length/2-bi-.5)*(barW+3)-barW/2,y=20+innerH-bh;svg+=`<rect x="${x.toFixed(1)}" y="${y.toFixed(1)}" width="${barW}" height="${bh.toFixed(1)}" rx="3" fill="${colors[bi]}" opacity="0.85"/>`;});
    svg+=`<text x="${gx.toFixed(1)}" y="${20+innerH+16}" text-anchor="middle" font-size="10" font-weight="600" fill="#0a1410" font-family="Bricolage Grotesque,sans-serif">${n}</text><text x="${gx.toFixed(1)}" y="${20+innerH+28}" text-anchor="middle" font-size="8" fill="#6b8878" font-family="JetBrains Mono,monospace">${n==='Calories'?'(kcal)':'(g)'}</text>`;
  });
  svg+='</svg>';
  wrap.innerHTML=svg;
}

// ── Macro sliders linked ──────────────────────────────────────────────────────
function initMacroSliders(){
  const sc=document.getElementById('slider-carbs'),lc=document.getElementById('label-carbs');
  const sp=document.getElementById('slider-protein'),lp=document.getElementById('label-protein');
  const sf=document.getElementById('slider-fat'),lf=document.getElementById('label-fat');
  if(!sc) return;
  let vals={carbs:45,protein:30,fat:25};
  const others={carbs:['protein','fat'],protein:['carbs','fat'],fat:['carbs','protein']};
  const inputs={carbs:sc,protein:sp,fat:sf},labels={carbs:lc,protein:lp,fat:lf};
  function update(changed){
    const nv=parseInt(inputs[changed].value),diff=nv-vals[changed];vals[changed]=nv;
    const ot=others[changed],tot=ot.reduce((s,k)=>s+vals[k],0);
    if(tot>0) ot.forEach(k=>vals[k]=Math.max(5,Math.round(vals[k]-diff*(vals[k]/tot))));
    const sum=Object.values(vals).reduce((a,b)=>a+b,0);
    if(sum!==100){const big=others[changed].reduce((a,b)=>vals[a]>vals[b]?a:b);vals[big]+=100-sum;}
    Object.keys(vals).forEach(k=>{inputs[k].value=vals[k];labels[k].textContent=vals[k]+'%';});
  }
  sc.addEventListener('input',()=>update('carbs'));
  sp.addEventListener('input',()=>update('protein'));
  sf.addEventListener('input',()=>update('fat'));
}

// ── Save buttons ──────────────────────────────────────────────────────────────
function initSaveBtns(){
  document.querySelectorAll('button').forEach(btn=>{
    if(['Save Changes','Update Profile','Update Password','Save All Preferences'].includes(btn.textContent.trim())){
      btn.addEventListener('click',function(){const o=this.textContent;this.textContent='✓ Saved!';this.style.background='#1e6b5e';setTimeout(()=>{this.textContent=o;this.style.background='#0a1410';},2000);});
    }
  });
}

// ── Recipe grid ───────────────────────────────────────────────────────────────
function initRecipeGrid(){
  document.querySelectorAll('.recipe-card').forEach(card=>{
    const id=card.dataset.recipeId; if(!id) return;
    const heart=card.querySelector('.rc-fav');
    if(heart){
      heart.textContent=favourites.has(id)?'❤️':'🤍';
      heart.addEventListener('click',e=>{e.stopPropagation();toggleFav(id,heart);});
    }
    card.addEventListener('click',e=>{if(e.target.classList.contains('rc-fav'))return;openRecipeDetail(id);});
  });
}

// ── Compare modal ─────────────────────────────────────────────────────────────
function initCompareModal(){
  const idMap={'Shakshuka':'shakshuka','Avocado Toast':'avocado-toast','Lentil & Sweet Potato Soup':'lentil-soup','Mediterranean Quinoa Bowl':'mediterranean-quinoa','Grilled Salmon & Greens':'grilled-salmon'};
  document.querySelectorAll('#compare-select .fav-item').forEach(el=>{
    const name=el.querySelector('.fav-item-name')?.textContent;
    if(name&&idMap[name]) el.dataset.recipeId=idMap[name];
  });
}

// ── Init ──────────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', function(){
  if(new URLSearchParams(window.location.search).get('from')==='pro'){
    var btn=document.getElementById('proSwitchNavBtn');
    if(btn) btn.style.display='flex';
  }
});
document.addEventListener('DOMContentLoaded',()=>{
  initExerciseChart();
  renderMealLog();
  updateDonut();
  renderExerciseLog();
  initRecipeGrid();
  initCompareModal();
  renderComparePage();
  initMacroSliders();
  initSaveBtns();
  // Show pro switch button if coming from pro dashboard
  if(new URLSearchParams(window.location.search).get('from')==='pro'){
    const btn = document.getElementById('proSwitchNavBtn');
    if(btn) btn.style.display='flex';
  }
});
</script>
