<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NourishWell — Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--teal:#1e6b5e;--teal-l:#1a7a6a;--teal-ll:#b8ddd8;--teal-lll:#e8f4f2;--amber:#955018;--amber-l:#d4956a;--amber-ll:#faeade;--ink:#0a1410;--ink-s:#1c2e26;--ink-m:#3d5448;--ink-f:#4d6e5e;--paper:#f5f7f5;--fog:#dce6e0;--white:#fff;--border:#d4dfd8;--blue:#7aaad4;--pink:#b5413e}
body{font-family:'Bricolage Grotesque',sans-serif;background:var(--paper);color:var(--ink);display:flex;min-height:100vh;-webkit-font-smoothing:antialiased}

.top-nav{position:fixed;top:0;left:0;right:0;z-index:999;height:60px;display:flex;align-items:center;justify-content:space-between;padding:0 24px 0 0;background:var(--ink)}
.top-nav-left{display:flex;align-items:center;gap:10px;padding:0 20px;height:100%}
.tn-logo{display:flex;align-items:center;gap:8px;text-decoration:none}
.tn-logo-mark{width:26px;height:26px;border-radius:6px;background:rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;font-size:12px}
.tn-logo-text{font-size:14px;font-weight:700;color:#fff;letter-spacing:-0.02em}
.top-nav-right{display:flex;align-items:center;gap:24px}
.tn-link{font-family:'JetBrains Mono',monospace;font-size:11px;color:rgba(255,255,255,0.95);text-decoration:none;padding:8px 16px;border:1px solid rgba(255,255,255,0.3);border-radius:6px;transition:all .2s;background:transparent;cursor:pointer}
button.tn-link{font-family:'JetBrains Mono',monospace}
.tn-link:hover{color:#fff;border-color:rgba(255,255,255,0.6);background:rgba(255,255,255,0.08)}
.tn-icon{width:38px;height:38px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px;cursor:pointer;transition:all .2s;color:rgba(255,255,255,0.95)}
.tn-icon:hover{background:rgba(255,255,255,0.1);color:#fff}
.tn-avatar-wrap{position:relative}
.tn-avatar{display:flex;align-items:center;gap:10px;cursor:pointer;padding:6px 12px 6px 6px;border-radius:10px;transition:background .2s}
.tn-avatar:hover{background:rgba(255,255,255,0.08)}
.tn-avatar-pic{width:34px;height:34px;border-radius:50%;background:var(--teal);color:#fff;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0}
.tn-avatar-name{font-size:13px;font-weight:600;color:rgba(255,255,255,0.85);letter-spacing:-0.01em}
.tn-dropdown{display:none;position:absolute;top:50px;right:0;background:var(--white);border:1px solid var(--border);border-radius:10px;min-width:200px;box-shadow:0 12px 40px rgba(10,20,16,0.12);overflow:hidden;z-index:100}
.tn-dropdown.open{display:block}
.tn-dropdown a{display:block;padding:13px 18px;font-size:13px;color:var(--ink);text-decoration:none;border-bottom:1px solid var(--fog);transition:background .15s}
.tn-dropdown a:last-child{border-bottom:none}
.tn-dropdown a:hover{background:var(--teal-lll)}
.tn-dropdown a.logout{color:#c0392b}

.side-nav{position:fixed;top:60px;left:0;bottom:0;width:200px;background:var(--white);border-right:1px solid var(--border);padding:20px 0;z-index:998;display:flex;flex-direction:column;gap:2px}
.sn-item{display:flex;align-items:center;gap:12px;padding:14px 24px;font-family:'JetBrains Mono',monospace;font-size:12px;font-weight:500;color:var(--ink-m);cursor:pointer;border-left:3px solid transparent;text-decoration:none;white-space:nowrap;transition:all .2s;letter-spacing:0.02em}
.sn-item:hover{color:var(--ink);background:var(--paper)}
.sn-item.active{color:#fff;background:var(--ink);border-left-color:var(--teal);font-weight:500;text-decoration:none}
.sn-icon{font-size:17px;flex-shrink:0;width:20px;text-align:center}

.main{margin-left:200px;margin-top:60px;padding:32px 36px;flex:1}
.page-title{font-family:'Instrument Serif',serif;font-size:28px;font-style:italic;color:var(--ink);letter-spacing:-0.02em}
.page-date{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--ink-f);letter-spacing:.06em;text-transform:uppercase;margin-top:4px}
.page-header{margin-bottom:24px}
.page{display:none}.page.active{display:block}

.settings-overlay{position:fixed;top:60px;left:200px;right:0;bottom:0;background:var(--paper);z-index:997;display:none;overflow-y:auto}
.settings-overlay.open{display:block}
.settings-inner{max-width:900px;margin:0 auto;padding:32px 40px}

.fav-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(10,20,16,0.4);z-index:1002;display:none;align-items:center;justify-content:center}
.fav-overlay.open{display:flex}
.fav-modal{background:var(--white);border-radius:20px;max-height:80vh;overflow:hidden;box-shadow:0 24px 80px rgba(10,20,16,0.2);display:flex;flex-direction:column}
.fav-modal-header{display:flex;justify-content:space-between;align-items:center;padding:20px 24px;border-bottom:1px solid var(--border)}
.fav-modal-title{font-family:'Instrument Serif',serif;font-size:22px;font-style:italic;color:var(--ink)}
.fav-modal-close{width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px;cursor:pointer;border:none;background:var(--paper);color:var(--ink-m);transition:all .2s}
.fav-modal-close:hover{background:var(--ink);color:#fff}
.fav-list{padding:12px 24px;overflow-y:auto;flex:1}
.fav-item{display:flex;align-items:center;gap:14px;padding:12px 0;border-bottom:1px solid var(--fog);cursor:pointer;transition:background .15s}
.fav-item:last-child{border-bottom:none}
.fav-item:hover{background:var(--teal-lll);margin:0 -24px;padding-left:24px;padding-right:24px}
.fav-item-icon{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0}
.fav-item-info{flex:1}
.fav-item-name{font-size:13px;font-weight:700;color:var(--ink)}
.fav-item-meta{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--ink-f);margin-top:2px}
.fav-item-check{width:24px;height:24px;border-radius:6px;border:1.5px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:12px;color:transparent;transition:all .2s}
.fav-item.selected .fav-item-check{border-color:var(--teal);background:var(--teal);color:#fff}

.dash-grid{display:grid;grid-template-columns:300px 1fr;gap:20px;margin-bottom:24px}
.donut-card{background:var(--ink);border-radius:20px;padding:24px;position:relative;overflow:hidden;box-shadow:0 16px 48px rgba(10,20,16,0.2)}
.donut-card::before{content:'';position:absolute;top:-40px;right:-40px;width:160px;height:160px;background:radial-gradient(circle,rgba(47,143,127,0.15) 0%,transparent 70%);pointer-events:none}
.dc-eyebrow{font-family:'JetBrains Mono',monospace;font-size:9px;color:rgba(255,255,255,0.3);letter-spacing:.1em;text-transform:uppercase;margin-bottom:16px}
.dc-donut{display:flex;justify-content:center;margin-bottom:16px}
.dc-legend{display:flex;flex-direction:column;gap:7px}
.dc-leg-row{display:flex;align-items:center;gap:7px}
.dc-leg-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.dc-leg-name{font-family:'JetBrains Mono',monospace;font-size:9px;color:rgba(255,255,255,0.4);flex:1}
.dc-leg-val{font-size:10px;font-weight:600;color:rgba(255,255,255,0.75)}
.dc-divider{height:1px;background:rgba(255,255,255,0.06);margin:12px 0}
.dc-total{display:flex;justify-content:space-between;align-items:baseline}
.dc-total-num{font-size:22px;font-weight:700;color:#fff}
.dc-total-sub{font-size:11px;color:rgba(255,255,255,0.3)}
.dc-total-pct{font-size:16px;font-weight:700;color:var(--teal-l)}
.dc-total-label{font-family:'JetBrains Mono',monospace;font-size:8px;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:.08em;margin-top:2px}

.right-panel{display:flex;flex-direction:column;gap:16px}
.chart-card{background:var(--white);border:1px solid var(--border);border-radius:16px;padding:20px;box-shadow:0 4px 16px rgba(10,20,16,0.04);flex:1}
.cc-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}
.cc-title{font-size:13px;font-weight:700;color:var(--ink)}
.cc-tabs{display:flex;gap:4px}
.cc-tab{font-family:'JetBrains Mono',monospace;font-size:9px;padding:4px 10px;border-radius:20px;cursor:pointer;color:var(--ink-f);background:var(--paper);border:none;transition:all .2s}
.cc-tab.active{background:var(--ink);color:#fff}
.action-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.action-btn{display:flex;align-items:center;gap:12px;padding:18px 20px;background:var(--white);border:1px solid var(--border);border-radius:14px;cursor:pointer;transition:all .2s;text-decoration:none}
.action-btn:hover{border-color:var(--teal);box-shadow:0 6px 20px rgba(30,107,94,0.1);transform:translateY(-1px)}
.ab-icon{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
.ab-icon.meal{background:var(--amber-ll)}.ab-icon.exercise{background:var(--teal-lll)}
.ab-text-main{font-size:13px;font-weight:700;color:var(--ink)}
.ab-text-sub{font-size:11px;color:var(--ink-f);margin-top:2px}

/* Three column meal log */
.meal-columns{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px}
.meal-col{background:var(--white);border:1px solid var(--border);border-radius:16px;padding:18px;box-shadow:0 4px 16px rgba(10,20,16,0.04)}
.mc-header{font-size:13px;font-weight:700;color:var(--ink);padding-bottom:4px;margin-bottom:4px;display:flex;align-items:center;gap:8px}
.mc-header .mc-icon{font-size:16px}
.mc-section{margin-bottom:14px}
.mc-section-label{font-family:'JetBrains Mono',monospace;font-size:8px;color:var(--ink-f);letter-spacing:.08em;text-transform:uppercase;padding:6px 0 4px;display:flex;align-items:center;gap:6px}
.mc-section-label::after{content:'';flex:1;height:1px;background:var(--fog)}
.mc-row{display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid var(--fog)}
.mc-row:last-child{border-bottom:none}
.mc-time{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f);min-width:40px}
.mc-name{flex:1;font-size:12px;font-weight:600;color:var(--ink)}
.mc-kcal{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--ink-m)}
.mc-empty{font-size:11px;color:var(--ink-f);font-style:italic;padding:8px 0}
.mc-add{display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:600;color:var(--teal);cursor:pointer;padding:6px 0;transition:color .2s}
.mc-add:hover{color:var(--ink)}

/* Slide panel */
.sp-cat{font-family:'JetBrains Mono',monospace;font-size:9px;padding:4px 10px;border-radius:16px;border:1px solid var(--border);background:var(--white);color:var(--ink-f);cursor:pointer;transition:all .2s}
.sp-cat.active{background:var(--teal-lll);color:var(--teal);border-color:var(--teal-ll)}
.sp-cat:hover:not(.active){border-color:var(--ink-f)}
.sp-footer-btn{padding:10px 24px;background:var(--ink);color:#fff;border:none;border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s}
.sp-footer-btn:hover{background:var(--teal)}

/* Recipe */
.recipe-top-bar{display:flex;gap:12px;margin-bottom:24px;align-items:center}
.recipe-search{display:flex;align-items:center;gap:10px;background:var(--white);border:1px solid var(--border);border-radius:12px;padding:10px 16px;flex:1;transition:all .25s}
.recipe-search:focus-within{border-color:var(--border);box-shadow:0 2px 12px rgba(10,20,16,0.06)}
.rs-input{flex:1;border:none;outline:none;font-family:'Bricolage Grotesque',sans-serif;font-size:14px;color:var(--ink);background:transparent}
.rs-input::placeholder{color:var(--ink-f)}
.fav-link{display:flex;align-items:center;gap:6px;padding:12px 20px;background:var(--white);border:1px solid var(--border);border-radius:12px;font-size:13px;font-weight:600;color:var(--ink);cursor:pointer;transition:all .2s;text-decoration:none;white-space:nowrap}
.fav-link:hover{border-color:var(--teal);color:var(--teal)}
.recipe-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
.recipe-card{background:var(--white);border:1px solid var(--border);border-radius:16px;overflow:hidden;box-shadow:0 4px 16px rgba(10,20,16,0.04);transition:all .25s;cursor:pointer}
.recipe-card:hover{transform:translateY(-3px);box-shadow:0 12px 36px rgba(10,20,16,0.1)}
.rc-img{width:100%;height:160px;display:flex;align-items:center;justify-content:center;font-size:48px}
.rc-body{padding:16px}
.rc-tag{font-family:'JetBrains Mono',monospace;font-size:8px;color:var(--teal);letter-spacing:.1em;text-transform:uppercase;margin-bottom:4px}
.rc-title{font-size:14px;font-weight:700;color:var(--ink);margin-bottom:6px}
.rc-meta{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--ink-f)}
.rc-footer{display:flex;justify-content:space-between;align-items:center;margin-top:10px;padding-top:10px;border-top:1px solid var(--fog)}
.rc-rating{font-size:11px;color:var(--amber)}
.rc-fav{font-size:16px;cursor:pointer;transition:transform .2s}
.rc-fav:hover{transform:scale(1.2)}

/* Favourites page */
.fav-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
.fav-card{background:var(--white);border:1px solid var(--border);border-radius:16px;overflow:hidden;box-shadow:0 4px 16px rgba(10,20,16,0.04);transition:all .25s;position:relative}
.fav-card:hover{transform:translateY(-3px);box-shadow:0 12px 36px rgba(10,20,16,0.1)}
.fav-card-img{width:100%;height:140px;display:flex;align-items:center;justify-content:center;font-size:42px}
.fav-card-body{padding:16px}
.fav-card-title{font-size:14px;font-weight:700;color:var(--ink);margin-bottom:4px}
.fav-card-meta{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--ink-f)}
.fav-card-footer{display:flex;justify-content:space-between;align-items:center;margin-top:10px;padding-top:10px;border-top:1px solid var(--fog)}
.fav-card-rating{font-size:11px;color:var(--amber)}
.fav-remove{font-size:11px;color:var(--pink);cursor:pointer;font-family:'JetBrains Mono',monospace;letter-spacing:.04em;transition:color .2s}
.fav-remove:hover{color:#c0392b}

/* Plan */
.plan-selector{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:20px}
.plan-chip{display:flex;align-items:center;gap:6px;padding:8px 14px;border:1.5px solid var(--border);border-radius:10px;cursor:pointer;font-size:12px;font-weight:600;color:var(--ink-m);background:var(--white);transition:all .2s}
.plan-chip.selected{border-color:var(--teal);background:var(--teal-lll);color:var(--teal)}
.plan-chip .chip-dot{width:8px;height:8px;border-radius:50%}
.plan-chip .chip-remove{font-size:14px;color:var(--ink-f);margin-left:4px;cursor:pointer}
.plan-add{padding:8px 14px;border:1.5px dashed var(--border);border-radius:10px;cursor:pointer;font-size:12px;color:var(--ink-f);background:transparent;transition:all .2s}
.plan-add:hover{border-color:var(--teal);color:var(--teal)}
.plan-charts{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.plan-chart-card{background:var(--white);border:1px solid var(--border);border-radius:16px;padding:20px;box-shadow:0 4px 16px rgba(10,20,16,0.04)}
.pc-title{font-size:12px;font-weight:700;color:var(--ink);margin-bottom:4px}
.pc-sub{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f);margin-bottom:14px}
.pc-legend{display:flex;gap:14px;margin-top:10px;flex-wrap:wrap}
.pc-leg-item{display:flex;align-items:center;gap:4px;font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f)}
.pc-leg-dot{width:6px;height:6px;border-radius:50%}

/* ── DARK MODE ── */
body.dark-mode { --paper:#0d1a14; --white:#142420; --ink:#e8f0ec; --ink-s:#d0ddd4; --ink-m:#a8bfb0; --ink-f:#7a9488; --border:#2a3e34; --fog:#1e3028; }
body.dark-mode .top-nav { background:#060e0a; }
body.dark-mode .side-nav { background:#0d1a14; border-color:#1e3028; }
body.dark-mode .donut-card { background:#060e0a; }
body.dark-mode .action-btn, body.dark-mode .meal-col, body.dark-mode .chart-card,
body.dark-mode .recipe-card, body.dark-mode .fav-card, body.dark-mode .stat-card,
body.dark-mode .plan-chart-card { background:#142420; border-color:#2a3e34; }
body.dark-mode .recipe-search { background:#142420; border-color:#2a3e34; }
body.dark-mode .fav-link { background:#142420; border-color:#2a3e34; color:var(--ink); }
body.dark-mode .rs-input { color:var(--ink); }
body.dark-mode .settings-overlay { background:#0d1a14; }
body.dark-mode input, body.dark-mode select, body.dark-mode textarea { background:#142420; color:#e8f0ec; border-color:#2a3e34; }
body.dark-mode .tn-dropdown { background:#142420; border-color:#2a3e34; }
body.dark-mode .tn-dropdown a { color:#e8f0ec; border-color:#1e3028; }
body.dark-mode .tn-dropdown a:hover { background:#1e3028; }
body.dark-mode .fav-overlay .fav-modal { background:#142420; border-color:#2a3e34; }
body.dark-mode .fav-item:hover { background:#1e3028; }
body.dark-mode #foodPanel, body.dark-mode #exPanel { background:#0d1a14; }
body.dark-mode .frow { border-color:#1e3028; }
body.dark-mode .frow:hover { background:#1e3028; }
body.dark-mode .fcb { background:#142420; border-color:#2a3e34; color:#7a9488; }
body.dark-mode .fcb.active { background:#1e3028; color:var(--teal-l); border-color:var(--teal); }
body.dark-mode .finf b { color:#e8f0ec; }
body.dark-mode .mc-row { border-color:#1e3028; }
body.dark-mode .mc-section-label::after { background:#1e3028; }
body.dark-mode .fadd { background:#142420; border-color:#2a3e34; }
body.dark-mode .bar-chart-card { background:#142420; border-color:#2a3e34; }

/* ── RESPONSIVE ── */

/* ── FILTER DROPDOWN ── */
.filter-check-label { display:flex; align-items:center; gap:8px; padding:6px 8px; border-radius:8px; font-size:12px; font-weight:500; color:var(--ink); cursor:pointer; transition:background .15s; }
.filter-check-label:hover { background:var(--paper); }
.filter-check-label input[type=checkbox] { accent-color:var(--teal); width:16px; height:16px; cursor:pointer; }
body.dark-mode .filter-dropdown { background:#142420 !important; border-color:#2a3e34 !important; }
body.dark-mode .filter-check-label:hover { background:#1e3028; }

@media (max-width:1024px) {
  .side-nav { width:60px; overflow:hidden; }
  .sn-item .sn-text { display:none; }
  .sn-item { padding:14px 0; justify-content:center; }
  .sn-icon { margin:0; }
  .main { margin-left:60px; padding:24px 20px; }
  .dash-grid { grid-template-columns:1fr; }
  .meal-columns { grid-template-columns:1fr; }
  .recipe-grid, .fav-grid { grid-template-columns:repeat(2,1fr); }
  .action-row { grid-template-columns:1fr; }
  .plan-charts { grid-template-columns:1fr; }
}
@media (max-width:768px) {
  .side-nav { position:fixed; bottom:0; top:auto; left:0; right:0; width:100%; height:56px; flex-direction:row; justify-content:space-around; padding:0; border-right:none; border-top:1px solid var(--border); z-index:999; }
  .sn-item { flex-direction:column; padding:6px 4px; gap:2px; border-left:none; border-bottom:2px solid transparent; font-size:9px; }
  .sn-item.active { border-bottom-color:var(--teal); border-left-color:transparent; }
  .sn-item .sn-text { display:block; font-size:9px; }
  .sn-icon { font-size:18px; }
  .main { margin-left:0; margin-bottom:60px; padding:16px 14px; }
  .top-nav { padding:0 12px; }
  .tn-avatar-name { display:none; }
  .recipe-grid, .fav-grid { grid-template-columns:1fr; }
  .hero-content { grid-template-columns:1fr; }
  .recipe-top-bar { flex-direction:column; }
  .page-title { font-size:22px; }
  #foodPanel, #exPanel { width:100% !important; }
  .dash-grid { grid-template-columns:1fr; }
  .settings-inner { padding:20px 16px; }
  .settings-inner > div { grid-template-columns:1fr !important; }
}
@media (max-width:480px) {
  .top-nav-right { gap:8px; }
  .tn-link, .tour-trigger-btn { display:none; }
}

/* ── PRINT ── */
@media print {
  .top-nav, .side-nav, .action-row, .tour-trigger-btn, .mc-add, #foodPanel, #exPanel, #foodDim, #exDim, .fav-overlay, .settings-overlay, .tn-dropdown, #msgPanel, #msgDim { display:none !important; }
  .main { margin:0; padding:20px; }
  body { background:#fff; color:#000; }
  .donut-card { box-shadow:none; border:1px solid #ccc; }
  .meal-col, .chart-card { box-shadow:none; border:1px solid #ccc; page-break-inside:avoid; }
  .page-title::after { content:' — NourishWell Nutrition Report'; font-size:14px; font-style:normal; color:#666; }
}

/* ── ACCESSIBILITY FOCUS ── */
*:focus-visible { outline:2px solid var(--fog); outline-offset:2px; border-radius:4px; } input:focus-visible, textarea:focus-visible, select:focus-visible { outline:none; box-shadow:0 1px 4px rgba(10,20,16,0.08); }
.skip-link { position:absolute; top:-40px; left:0; background:var(--teal); color:#fff; padding:8px 16px; z-index:99999; font-size:14px; font-weight:600; border-radius:0 0 8px 0; transition:top .2s; }
.skip-link:focus { top:0; }

/* ── RECIPE TAG FILTERS ── */
.recipe-filters { display:flex; gap:6px; flex-wrap:wrap; margin-bottom:18px; }
.rf-tag { font-family:'JetBrains Mono',monospace; font-size:9px; padding:5px 12px; border-radius:16px; border:1px solid var(--border); background:var(--white); color:var(--ink-f); cursor:pointer; transition:all .2s; }
.rf-tag.active { background:var(--teal-lll); color:var(--teal); border-color:var(--teal-ll); }
.rf-tag:hover:not(.active) { border-color:var(--ink-f); }

/* ── ADD RECIPE MODAL ── */
.add-recipe-overlay { position:fixed; inset:0; background:rgba(10,20,16,0.4); z-index:3000; display:none; align-items:center; justify-content:center; }
.add-recipe-overlay.open { display:flex; }
.add-recipe-modal { background:var(--white); border-radius:20px; width:520px; max-width:90vw; max-height:85vh; overflow-y:auto; box-shadow:0 24px 80px rgba(10,20,16,0.2); padding:28px; }
body.dark-mode .add-recipe-modal { background:#142420; }
.arm-field { margin-bottom:14px; }
.arm-field label { display:block; font-family:'JetBrains Mono',monospace; font-size:9px; color:var(--ink-m); text-transform:uppercase; letter-spacing:.08em; margin-bottom:6px; }
.arm-field input, .arm-field textarea, .arm-field select { width:100%; padding:10px 13px; font-family:'Bricolage Grotesque',sans-serif; font-size:13px; color:var(--ink); background:var(--paper); border:1px solid var(--border); border-radius:8px; outline:none; transition:border-color .2s; }
.arm-field input:focus, .arm-field textarea:focus { border-color:var(--border); box-shadow:0 1px 4px rgba(10,20,16,0.08); }
.arm-row { display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; }

/* ── STAR RATING INTERACTIVE ── */
.star-rate { display:inline-flex; gap:2px; cursor:pointer; font-size:14px; }
.star-rate .star { color:var(--fog); transition:color .15s; }
.star-rate .star.filled { color:var(--amber); }
.star-rate .star:hover, .star-rate .star:hover ~ .star { color:var(--amber-l); }

/* ── COMMENTS ── */
.comment-section { margin-top:14px; border-top:1px solid var(--fog); padding-top:12px; }
.comment-item { padding:8px 0; border-bottom:1px solid var(--fog); }
.comment-item:last-child { border-bottom:none; }
.comment-author { font-family:'JetBrains Mono',monospace; font-size:9px; color:var(--teal); font-weight:600; }
.comment-text { font-size:12px; color:var(--ink-m); margin-top:3px; line-height:1.5; }
.comment-input-wrap { display:flex; gap:8px; margin-top:8px; }
.comment-input-wrap input { flex:1; padding:8px 12px; border:1px solid var(--border); border-radius:8px; font-size:12px; outline:none; }
.comment-input-wrap input:focus { border-color:var(--border); box-shadow:0 1px 4px rgba(10,20,16,0.08); }
.comment-input-wrap button { padding:8px 16px; background:var(--ink); color:#fff; border:none; border-radius:8px; font-size:11px; font-weight:600; cursor:pointer; }

/* ── DATE PICKER ── */
.date-nav { display:flex; align-items:center; gap:12px; margin-top:6px; }
.date-nav-btn { width:30px; height:30px; border-radius:8px; border:1px solid var(--border); background:var(--white); display:flex; align-items:center; justify-content:center; cursor:pointer; font-size:14px; color:var(--ink-m); transition:all .2s; }
.date-nav-btn:hover { border-color:var(--teal); color:var(--teal); }
.date-nav input[type=date] { font-family:'JetBrains Mono',monospace; font-size:11px; padding:6px 10px; border:1px solid var(--border); border-radius:8px; color:var(--ink); background:var(--white); outline:none; }
.date-nav input[type=date]:focus { border-color:var(--border); box-shadow:0 1px 4px rgba(10,20,16,0.08); }


/* ═════════════════════════════════════════════════════════════════
 * NOURISHWELL PATCH — A11y & Polish (inline)
 * Added: WCAG AA fixes, focus, reduced-motion, sr-only, insights,
 *        fridge mode, cooked toggle, cooking mode, shortcuts modal.
 * ═════════════════════════════════════════════════════════════════ */

:root {
  --ink-f: #5a7267;                 /* was #6b8878 — now passes AA */
  --ink-f-decorative: #6b8878;
  --focus-ring: #1e6b5e;
  --error: #b3261e;
  --r-xs: 4px; --r-sm: 6px; --r-md: 10px; --r-lg: 14px; --r-xl: 20px;
  --shadow-sm: 0 2px 8px rgba(10,20,16,0.04);
  --shadow-md: 0 4px 16px rgba(10,20,16,0.06);
  --shadow-lg: 0 12px 36px rgba(10,20,16,0.10);
  --shadow-xl: 0 24px 80px rgba(10,20,16,0.18);
}
body.dark-mode { --ink-f: #9fb5aa; --ink-f-decorative: #7a9488; --focus-ring: #5fb8a5; }

*:focus { outline: none; }
*:focus-visible {
  outline: 2px solid var(--focus-ring) !important;
  outline-offset: 2px !important;
  border-radius: 4px;
  box-shadow: 0 0 0 4px rgba(30,107,94,0.15) !important;
}
input:focus-visible, textarea:focus-visible, select:focus-visible {
  outline: none !important;
  border-color: var(--focus-ring) !important;
  box-shadow: 0 0 0 2px rgba(30,107,94,0.18) !important;
}
.qa-search-input:focus-visible,
.rs-input:focus-visible,
.fridge-input input:focus-visible,
.comment-input-wrap input:focus-visible {
  box-shadow: none !important;
  border-color: transparent !important;
}

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
  .ticker { animation: none !important; }
  .reveal { opacity: 1 !important; transform: none !important; }
  .recipe-card:hover, .fav-card:hover, .action-btn:hover { transform: none !important; }
}

.sr-only {
  position: absolute !important; width: 1px !important; height: 1px !important;
  padding: 0 !important; margin: -1px !important; overflow: hidden !important;
  clip: rect(0,0,0,0) !important; white-space: nowrap !important; border: 0 !important;
}

.empty-state { text-align: center; padding: 48px 24px; background: var(--white); border: 1px dashed var(--border); border-radius: var(--r-lg); }
.empty-state-icon { font-size: 42px; margin-bottom: 12px; opacity: 0.7; }
.empty-state-title { font-size: 16px; font-weight: 700; color: var(--ink); margin-bottom: 6px; }
.empty-state-body { font-size: 13px; color: var(--ink-f); max-width: 320px; margin: 0 auto; line-height: 1.6; }

.insight-card { background: var(--white); border: 1px solid var(--border); border-radius: var(--r-lg); padding: 16px 18px; box-shadow: var(--shadow-sm); margin-bottom: 0; border-left: 4px solid var(--teal); }
.insight-card.warn { border-left-color: var(--amber); }
.insight-card.alert { border-left-color: var(--error); }
.insight-card.good { border-left-color: var(--teal); }
.insight-title { font-size: 12px; font-weight: 700; color: var(--ink); display: flex; align-items: center; gap: 8px; margin-bottom: 4px; }
.insight-title .insight-icon { font-size: 16px; }
.insight-body { font-size: 13px; color: var(--ink-f); line-height: 1.55; }
.insight-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 12px; margin-bottom: 20px; }
body.dark-mode .insight-card { background: #142420; border-color: #2a3e34; }

.fridge-panel { background: var(--teal-lll); border: 1px solid var(--teal-ll); border-radius: var(--r-lg); padding: 18px 20px; margin-bottom: 20px; }
body.dark-mode .fridge-panel { background: rgba(30,107,94,0.15); border-color: rgba(30,107,94,0.4); }
.fridge-title { font-size: 13px; font-weight: 700; color: var(--ink); margin-bottom: 4px; display: flex; align-items: center; gap: 8px; }
.fridge-sub { font-family: 'JetBrains Mono', monospace; font-size: 10px; color: var(--ink-f); margin-bottom: 14px; }
.fridge-chips { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 12px; }
.fridge-chip { display: inline-flex; align-items: center; gap: 4px; padding: 6px 12px; background: var(--white); border: 1px solid var(--border); border-radius: 20px; font-family: 'Bricolage Grotesque', sans-serif; font-size: 12px; font-weight: 500; color: var(--ink-m); cursor: pointer; transition: all 0.2s; }
.fridge-chip:hover { border-color: var(--teal); color: var(--teal); }
.fridge-chip.selected { background: var(--teal); color: white; border-color: var(--teal); }
.fridge-chip .chip-x { font-size: 14px; opacity: 0.7; margin-left: 2px; }
.fridge-input { display: flex; gap: 6px; align-items: center; }
.fridge-input input { flex: 1; padding: 8px 12px; border: 1px solid var(--border); border-radius: var(--r-md); font-family: 'Bricolage Grotesque', sans-serif; font-size: 12px; background: var(--white); color: var(--ink); outline: none; }
.fridge-input button { padding: 8px 16px; background: var(--teal); color: white; border: none; border-radius: var(--r-md); font-family: 'Bricolage Grotesque', sans-serif; font-size: 12px; font-weight: 600; cursor: pointer; transition: background 0.2s; }
.fridge-input button:hover { background: var(--ink); }

.recipe-card { position: relative; }
.recipe-card .rc-match-badge { position: absolute; top: 8px; left: 8px; background: var(--teal); color: white; font-family: 'JetBrains Mono', monospace; font-size: 9px; padding: 3px 8px; border-radius: 12px; font-weight: 600; z-index: 2; }

.cooked-toggle { display: inline-flex; align-items: center; gap: 5px; padding: 4px 10px; font-family: 'JetBrains Mono', monospace; font-size: 9px; font-weight: 600; letter-spacing: 0.04em; border-radius: 12px; border: 1px solid var(--border); background: var(--white); color: var(--ink-f); cursor: pointer; transition: all 0.15s; }
.cooked-toggle:hover { border-color: var(--teal); color: var(--teal); }
.cooked-toggle.cooked { background: var(--teal-lll); color: var(--teal); border-color: var(--teal-ll); }

.cooking-mode { position: fixed; inset: 0; background: var(--paper); z-index: 10000; display: none; flex-direction: column; padding: 24px; }
.cooking-mode.active { display: flex; }
.cook-header { display: flex; align-items: center; justify-content: space-between; padding-bottom: 20px; border-bottom: 1px solid var(--border); margin-bottom: 32px; }
.cook-title { font-family: 'Instrument Serif', serif; font-size: 28px; font-style: italic; color: var(--ink); }
.cook-close { width: 40px; height: 40px; border-radius: var(--r-md); border: 1px solid var(--border); background: var(--white); font-size: 18px; cursor: pointer; color: var(--ink-m); }
.cook-body { flex: 1; display: flex; align-items: center; justify-content: center; max-width: 800px; margin: 0 auto; width: 100%; }
.cook-step { text-align: center; }
.cook-step-counter { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: var(--teal); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 20px; }
.cook-step-text { font-family: 'Instrument Serif', serif; font-size: 42px; font-style: italic; color: var(--ink); line-height: 1.3; letter-spacing: -0.02em; margin-bottom: 24px; }
.cook-ingredient-list { font-size: 15px; color: var(--ink-f); line-height: 1.9; background: var(--white); border: 1px solid var(--border); border-radius: var(--r-lg); padding: 24px 32px; max-width: 480px; margin: 0 auto; text-align: left; }
.cook-footer { display: flex; align-items: center; justify-content: space-between; padding-top: 24px; border-top: 1px solid var(--border); }
.cook-nav-btn { padding: 14px 28px; background: var(--ink); color: white; border: none; border-radius: var(--r-md); font-family: 'Bricolage Grotesque', sans-serif; font-size: 14px; font-weight: 600; cursor: pointer; transition: background 0.2s; }
.cook-nav-btn:hover { background: var(--teal); }
.cook-nav-btn:disabled { opacity: 0.4; cursor: not-allowed; }
.cook-nav-btn.ghost { background: transparent; color: var(--ink-m); border: 1px solid var(--border); }
.cook-progress { flex: 1; margin: 0 24px; height: 6px; background: var(--fog); border-radius: 3px; overflow: hidden; }
.cook-progress-fill { height: 100%; background: var(--teal); transition: width 0.3s ease; }
body.dark-mode .cooking-mode { background: #0d1a14; }
body.dark-mode .cook-ingredient-list { background: #142420; border-color: #2a3e34; }

.shortcuts-overlay { position: fixed; inset: 0; background: rgba(10,20,16,0.5); z-index: 10001; display: none; align-items: center; justify-content: center; }
.shortcuts-overlay.open { display: flex; }
.shortcuts-modal { background: var(--white); border-radius: var(--r-xl); padding: 32px; max-width: 480px; width: 90vw; box-shadow: var(--shadow-xl); }
body.dark-mode .shortcuts-modal { background: #142420; }
.shortcut-row { display: flex; align-items: center; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--fog); font-size: 13px; color: var(--ink); }
.shortcut-row:last-child { border-bottom: none; }
.shortcut-keys { display: flex; gap: 4px; }
.shortcut-key { font-family: 'JetBrains Mono', monospace; font-size: 11px; padding: 4px 8px; background: var(--paper); border: 1px solid var(--border); border-radius: 4px; color: var(--ink-m); min-width: 22px; text-align: center; }

@media print {
  .insight-card { page-break-inside: avoid; border: 1px solid #999; box-shadow: none; }
  .skip-link, .shortcuts-overlay, .cooking-mode { display: none !important; }
}

@media (max-width: 768px) {
  .auth-shell { grid-template-columns: 1fr !important; }
  .panel-left { min-height: 220px; padding: 28px 24px !important; }
  .panel-left .feature-pills { display: none; }
  .panel-right { padding: 32px 20px !important; }
  .qa-title { font-size: 28px !important; }
  .qa-search { padding: 10px 14px !important; }
}

</style>
</head>
<body>
<a href="#main-content" class="skip-link">Skip to main content</a>
<nav class="top-nav" role="navigation" aria-label="Main navigation"><div class="top-nav-left"><a href="#" class="tn-logo"><div class="tn-logo-mark" aria-hidden="true">🌿</div><span class="tn-logo-text">NourishWell</span></a></div><div class="top-nav-right">
<div id="back-to-pro-wrap" style="display:none">
  <button class="tn-link" onclick="backToPro()" style="background:rgba(124,58,237,0.15);border-color:rgba(124,58,237,0.4);color:rgba(200,180,255,0.95)">← Back to Pro Dashboard</button>
</div><a href="#" id="proSwitchNavBtn" onclick="switchBackToPro();return false" class="tn-link" style="display:none;align-items:center;gap:6px;border-color:rgba(255,255,255,0.25);color:rgba(255,255,255,0.9)"><svg width="13" height="13" viewBox="0 0 15 15" fill="none"><path d="M1 4.5h10M8 1.5l3 3-3 3M14 10.5H4M7 7.5l-3 3 3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg> Switch to Pro</a><a href="qa_subscriber.html" class="tn-link" id="helpLink" style="display:flex;align-items:center;gap:5px"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.3"/><text x="7" y="10.5" text-anchor="middle" font-size="8.5" fill="currentColor" font-weight="600" font-family="JetBrains Mono,monospace">?</text></svg> Help</a><button onclick="toggleShortcutHelp(true)" class="tn-link" aria-label="Show keyboard shortcuts" title="Keyboard shortcuts (press ?)" style="display:flex;align-items:center;gap:5px"><svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><rect x="1" y="3" width="12" height="8" rx="1.5" stroke="currentColor" stroke-width="1.3"/><path d="M3.5 6.5h.01M5.5 6.5h.01M7.5 6.5h.01M9.5 6.5h.01M3.5 8.5h7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg> Shortcuts</button><button onclick="exportWeeklyReportCSV()" class="tn-link" aria-label="Download last 7 days of diary data as CSV" title="Export weekly report" style="display:flex;align-items:center;gap:5px"><svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M7 1v8M4 6l3 3 3-3M2 12h10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg> Export</button><button onclick="startTour()" class="tn-link" title="Guided tour" style="display:flex;align-items:center;gap:5px"><svg width="14" height="14" viewBox="0 0 15 15" fill="none" aria-hidden="true"><path d="M3 7.5h9M9 4.5l3 3-3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/><circle cx="3" cy="7.5" r="1.5" fill="currentColor"/></svg> Tour</button><div class="tn-icon" id="userMailIcon" onclick="openUserMessages()" style="position:relative;cursor:pointer" aria-label="Messages" role="button" tabindex="0"><svg width="20" height="16" viewBox="0 0 20 16" fill="none"><rect x="1" y="1" width="18" height="14" rx="2" stroke="rgba(255,255,255,0.85)" stroke-width="1.5"/><path d="M1 4l9 6 9-6" stroke="rgba(255,255,255,0.85)" stroke-width="1.5"/></svg><div id="userMailDot" style="display:block;width:7px;height:7px;border-radius:50%;background:#dc2626;position:absolute;top:4px;right:4px;border:1.5px solid #0a1410"></div></div><div class="tn-icon" onclick="toggleDarkMode()" style="cursor:pointer" aria-label="Toggle dark mode" role="button" tabindex="0" title="Toggle dark mode"><span id="subDarkModeIcon" style="font-size:16px">🌙</span></div><div class="tn-avatar-wrap"><div class="tn-avatar" onclick="toggleAvatarMenu(event)" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();toggleAvatarMenu(event)}" tabindex="0" role="button" aria-label="User menu" aria-expanded="false" aria-haspopup="true"><div class="tn-avatar-pic">RC</div><span class="tn-avatar-name">Rose C.</span></div><div class="tn-dropdown" id="avatarMenu"><a href="#" onclick="showSettingsPage('personal');return false">Personal Details</a><a href="#" onclick="showSettingsPage('preferences');return false">Preferences</a>
<a href="#" class="logout" onclick="event.preventDefault();window.location.href='/COMP2850_final/index.html'">Log Out</a></div></div></div></nav>

<aside class="side-nav" role="navigation" aria-label="Page navigation">
<a class="sn-item active" onclick="switchPage('record',this)" href="#" aria-label="Record Today" role="tab" aria-selected="true"><span class="sn-icon" aria-hidden="true">📋</span> <span class="sn-text">Record Today</span></a>
<a class="sn-item" onclick="switchPage('recipe',this)" href="#"><span class="sn-icon">🍳</span> <span class="sn-text">Recipe</span></a>
<a class="sn-item" onclick="switchPage('favourites',this)" href="#"><span class="sn-icon">❤️</span> <span class="sn-text">Favourites</span></a>
<a class="sn-item" onclick="switchPage('plan',this)" href="#"><span class="sn-icon">📊</span> <span class="sn-text">Recipe Compare</span></a>
<a class="sn-item" onclick="switchPage('planner',this)" href="#"><span class="sn-icon">🧠</span> <span class="sn-text">Meal Planner</span></a>
<div style="height:1px;background:var(--fog);margin:8px 24px"></div>
<a class="sn-item" onclick="switchPage('mypro',this)" href="#" id="sn-mypro"><span class="sn-icon">🩺</span> <span class="sn-text">My Nutritionist</span></a>
<a class="sn-item" id="sn-community" onclick="switchPage('community',this)" href="#"><span class="sn-icon">💬</span> <span class="sn-text">Community</span></a>
</aside>

<div class="main" id="main-content" role="main">

<!-- Record Today -->
<div class="page active" id="page-record" role="tabpanel" aria-label="Record Today">
<div class="page-header"><div class="page-title">Record <em>Today</em></div><div class="page-date" id="today-date"></div>
<div class="date-nav"><button class="date-nav-btn" onclick="changeDate(-1)" aria-label="Previous day">←</button><input type="date" id="diary-date-picker" onchange="loadDateDiary(this.value)" aria-label="Select date"><button class="date-nav-btn" onclick="changeDate(1)" aria-label="Next day">→</button><button class="date-nav-btn" onclick="goToday()" style="font-size:10px;width:auto;padding:0 10px;font-family:'JetBrains Mono',monospace">Today</button></div></div>
<div class="dash-grid">
<div class="donut-card"><div class="dc-eyebrow">Today's Nutrition</div><div class="dc-donut"><svg width="150" height="150" viewBox="0 0 150 150"><circle cx="75" cy="75" r="48" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="16"/><circle cx="75" cy="75" r="48" fill="none" stroke="#2f8f7f" stroke-width="16" stroke-dasharray="126.7 175" stroke-linecap="butt" transform="rotate(-90 75 75)"/><circle cx="75" cy="75" r="48" fill="none" stroke="#d4956a" stroke-width="16" stroke-dasharray="84.5 217.2" stroke-linecap="butt" transform="rotate(61 75 75)"/><circle cx="75" cy="75" r="48" fill="none" stroke="#7aaad4" stroke-width="16" stroke-dasharray="54.3 247.4" stroke-linecap="butt" transform="rotate(162 75 75)"/><circle cx="75" cy="75" r="48" fill="none" stroke="#e07b78" stroke-width="16" stroke-dasharray="36.2 265.5" stroke-linecap="butt" transform="rotate(227 75 75)"/><text x="75" y="72" text-anchor="middle" font-size="20" font-weight="700" fill="#fff" font-family="Bricolage Grotesque,sans-serif">1,920</text><text x="75" y="88" text-anchor="middle" font-size="9" fill="rgba(255,255,255,0.35)" font-family="JetBrains Mono,monospace">kcal today</text></svg></div><div class="dc-legend"><div class="dc-leg-row"><div class="dc-leg-dot" style="background:#1a7a6a"></div><span class="dc-leg-name">Carbs</span><span class="dc-leg-val">42% · 201g</span></div><div class="dc-leg-row"><div class="dc-leg-dot" style="background:#d4956a"></div><span class="dc-leg-name">Protein</span><span class="dc-leg-val">28% · 68g</span></div><div class="dc-leg-row"><div class="dc-leg-dot" style="background:#7aaad4"></div><span class="dc-leg-name">Fat</span><span class="dc-leg-val">18% · 38g</span></div><div class="dc-leg-row"><div class="dc-leg-dot" style="background:#b5413e"></div><span class="dc-leg-name">Sugar</span><span class="dc-leg-val">12% · 84g</span></div></div><div class="dc-divider"></div><div class="dc-total"><div><div class="dc-total-num">1,920 <span class="dc-total-sub">/ 2,400</span></div><div class="dc-total-label">Daily target</div></div><div style="text-align:right"><div class="dc-total-pct">80%</div><div class="dc-total-label">Complete</div></div></div></div>
<div class="right-panel"><div class="chart-card"><div class="cc-header"><span class="cc-title">Exercise Activity</span><div style="display:flex;align-items:center;gap:14px"><div style="display:flex;align-items:center;gap:5px"><span style="display:inline-block;width:9px;height:9px;border-radius:2px;background:#1e6b5e"></span><span style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#4d6e5e">Actual</span></div><div style="display:flex;align-items:center;gap:5px"><span style="display:inline-block;width:9px;height:9px;border-radius:2px;background:#dce6e0"></span><span style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#4d6e5e">Target</span></div><div class="cc-tabs"><button class="cc-tab active" onclick="switchChartTab(this)">Week</button><button class="cc-tab" onclick="switchChartTab(this)">Month</button><button class="cc-tab" onclick="switchChartTab(this)">Year</button></div></div></div>
<div style="position:relative;width:100%;height:148px"><canvas id="exerciseChart"></canvas></div>
<div style="display:flex;justify-content:space-between;align-items:center;margin-top:10px;padding-top:10px;border-top:1px solid var(--fog)">
  <div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f)">Daily target based on your profile · <span style="color:var(--teal);font-weight:600">62 kg · Moderately Active</span></div>
  <div id="weekSummary" style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f)"></div>
</div>
</div>
<div class="action-row"><div class="action-btn" tabindex="0" role="button" onclick="openPanel('food')" style="cursor:pointer"><div class="ab-icon meal">🍽️</div><div><div class="ab-text-main">Record Meal</div><div class="ab-text-sub">Log what you ate</div></div></div><div class="action-btn" tabindex="0" role="button" onclick="openPanel('ex')" style="cursor:pointer"><div class="ab-icon exercise">🏃</div><div><div class="ab-text-main">Exercise</div><div class="ab-text-sub">Log your activity</div></div></div></div></div></div>

<!-- Proactive Nutrition Insights (populated by patch.js) -->
<div id="insights-container" class="insight-row" aria-label="Daily nutrition insights and suggestions"></div>

<!-- Three column meal log -->
<div class="meal-columns">
<div class="meal-col" id="breakfast-col">
<div class="mc-header"><span class="mc-icon" aria-hidden="true">🌅</span> Breakfast & Morning Snack</div>
<div class="mc-section"><div class="mc-section-label">Breakfast</div>
<div class="mc-row"><span class="mc-time">07:30</span><span class="mc-name">Oat porridge & banana</span><span class="mc-kcal">340</span></div></div>
<div class="mc-section"><div class="mc-section-label">Morning Snack</div>
<div class="mc-empty">Nothing logged</div></div>
<div class="mc-add" onclick="openPanel('food')">+ Add item</div>
</div>
<div class="meal-col" id="lunch-col">
<div class="mc-header"><span class="mc-icon" aria-hidden="true">☀️</span> Lunch & Afternoon Snack</div>
<div class="mc-section"><div class="mc-section-label">Lunch</div>
<div class="mc-row"><span class="mc-time">12:15</span><span class="mc-name">Chicken Caesar salad</span><span class="mc-kcal">520</span></div></div>
<div class="mc-section"><div class="mc-section-label">Afternoon Snack</div>
<div class="mc-row"><span class="mc-time">15:40</span><span class="mc-name">Bubble tea</span><span class="mc-kcal">380</span></div></div>
<div class="mc-add" onclick="openPanel('food')">+ Add item</div>
</div>
<div class="meal-col" id="dinner-col">
<div class="mc-header"><span class="mc-icon" aria-hidden="true">🌙</span> Dinner & Evening Snack</div>
<div class="mc-section"><div class="mc-section-label">Dinner</div>
<div class="mc-row"><span class="mc-time">19:00</span><span class="mc-name">Pad Thai</span><span class="mc-kcal">680</span></div></div>
<div class="mc-section"><div class="mc-section-label">Evening Snack</div>
<div class="mc-empty">Nothing logged</div></div>
<div class="mc-add" onclick="openPanel('food')">+ Add item</div>
</div>
</div>

<!-- Exercise log — inside page-record -->
<div style="background:var(--white);border:1px solid var(--border);border-radius:16px;padding:18px;box-shadow:0 4px 16px rgba(10,20,16,0.04);margin-top:16px">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
    <div style="font-size:13px;font-weight:700;color:#0a1410;display:flex;align-items:center;gap:8px"><span style="font-size:16px">🏃</span> Today's Exercise</div>
    <div class="mc-add" onclick="openPanel('ex')" style="margin:0;padding:0">+ Log exercise</div>
  </div>
  <div id="exercise-log"></div>
</div>


<div class="chart-card" style="margin-top:16px">
  <div class="cc-header">
    <span class="cc-title">Calorie Intake Trend</span>
    <div style="display:flex;align-items:center;gap:14px">
      <div style="display:flex;align-items:center;gap:5px"><span style="display:inline-block;width:9px;height:9px;border-radius:2px;background:#1e6b5e"></span><span style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#4d6e5e">Intake</span></div>
      <div style="display:flex;align-items:center;gap:5px"><span style="display:inline-block;width:9px;height:2px;background:#b8621f"></span><span style="font-family:'JetBrains Mono',monospace;font-size:9px;color:#4d6e5e">Target</span></div>
    </div>
  </div>
  <div style="position:relative;width:100%;height:148px"><canvas id="calorieTrendChart" aria-label="Calorie intake trend chart" role="img" aria-label="Weekly calorie intake trend chart" role="img"></canvas></div>
</div>

</div><!-- end page-record -->

<div class="page" id="page-recipe" role="tabpanel" aria-label="Recipes"><div class="page-header"><div class="page-title">Discover <em>Recipes</em></div></div>
<!-- Fridge Mode (ingredient-based search) -->
<div id="fridge-panel-host"></div>
<div class="recipe-top-bar" style="display:flex;gap:10px;margin-bottom:24px;align-items:center">
<!-- Filter dropdown -->
<div class="filter-dropdown-wrap" style="position:relative">
  <button onclick="toggleFilterDropdown()" class="fav-link" id="filterToggleBtn" style="display:flex;align-items:center;gap:6px" aria-label="Filter recipes" aria-expanded="false" aria-haspopup="true">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M1.5 2h13L9.5 8.5V13l-3 1.5V8.5L1.5 2z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>
    Filter <span id="filterCount" style="font-family:'JetBrains Mono',monospace;font-size:9px;padding:1px 6px;border-radius:10px;background:var(--teal-lll);color:var(--teal);display:none">0</span>
  </button>
  <div class="filter-dropdown" id="filterDropdown" style="display:none;position:absolute;top:48px;left:0;background:var(--white);border:1px solid var(--border);border-radius:14px;padding:16px 18px;min-width:300px;box-shadow:0 12px 40px rgba(10,20,16,0.12);z-index:100" role="menu">
    <div style="font-size:13px;font-weight:700;color:var(--ink);margin-bottom:4px">Exclude ingredients</div>
    <div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f);margin-bottom:12px">Recipes containing these in their ingredients will be hidden</div>
    <div style="display:flex;flex-direction:column;gap:6px" id="filterCheckboxes">
      <label class="filter-check-label"><input type="checkbox" value="nuts" onchange="applyAllFilters()"> 🥜 Nuts</label>
      <label class="filter-check-label"><input type="checkbox" value="dairy" onchange="applyAllFilters()"> 🧀 Dairy (milk, cheese, feta, parmesan)</label>
      <label class="filter-check-label"><input type="checkbox" value="gluten" onchange="applyAllFilters()"> 🌾 Gluten (bread, pasta, penne, sourdough)</label>
      <label class="filter-check-label"><input type="checkbox" value="eggs" onchange="applyAllFilters()"> 🥚 Eggs</label>
      <label class="filter-check-label"><input type="checkbox" value="fish" onchange="applyAllFilters()"> 🐟 Fish / Seafood (salmon)</label>
      <label class="filter-check-label"><input type="checkbox" value="meat" onchange="applyAllFilters()"> 🥩 Meat (chicken, beef, pork)</label>
      <label class="filter-check-label"><input type="checkbox" value="soy" onchange="applyAllFilters()"> 🫘 Soy</label>
    </div>
    <div style="border-top:1px solid var(--fog);margin-top:12px;padding-top:10px">
      <div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f);letter-spacing:.06em;text-transform:uppercase;margin-bottom:6px">Custom exclusions</div>
      <div style="display:flex;gap:6px;margin-bottom:6px">
        <input type="text" id="customExcludeInput" placeholder="e.g. tomato, onion..." style="flex:1;padding:7px 10px;border:1px solid var(--border);border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:12px;color:var(--ink);outline:none;background:var(--paper)" onfocus="this.style.boxShadow='0 1px 4px rgba(10,20,16,0.08)'" onblur="this.style.boxShadow='none'" onkeydown="if(event.key==='Enter'){addCustomExclusion();event.preventDefault();}">
        <button onclick="addCustomExclusion()" style="padding:7px 12px;background:var(--ink);color:#fff;border:none;border-radius:8px;font-size:11px;font-weight:600;cursor:pointer;flex-shrink:0;transition:background .2s" onmouseover="this.style.background='var(--teal)'" onmouseout="this.style.background='var(--ink)'">Add</button>
      </div>
      <div id="customExcludeTags" style="display:flex;flex-wrap:wrap;gap:5px"></div>
    </div>
    <div style="border-top:1px solid var(--fog);margin-top:10px;padding-top:10px;display:flex;justify-content:space-between;align-items:center">
      <button onclick="clearAllFilters()" style="font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--ink-f);background:none;border:none;cursor:pointer;padding:4px 0;transition:color .2s" onmouseover="this.style.color='var(--teal)'" onmouseout="this.style.color='var(--ink-f)'">Clear all</button>
      <button onclick="toggleFilterDropdown()" style="padding:7px 16px;background:var(--ink);color:#fff;border:none;border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:11px;font-weight:600;cursor:pointer;transition:background .2s" onmouseover="this.style.background='var(--teal)'" onmouseout="this.style.background='var(--ink)'">Done</button>
    </div>
  </div>
</div>
<div class="recipe-search"><span style="font-size:16px;color:var(--ink-f)" aria-hidden="true">🔍</span><label for="recipe-search-input" class="sr-only">Search recipes by name or ingredient</label><input aria-label="Text input" style="display:none" type="text" name="fake-autofill-trap" tabindex="-1" autocomplete="username"><input id="recipe-search-input" class="rs-input" type="search" placeholder="Search by name or ingredient (e.g. salmon, lentils)" aria-label="Search recipes by name or ingredient" oninput="filterRecipes(this.value)" autocomplete="new-password" name="nw-recipe-q" role="searchbox"></div>
<a href="#" class="fav-link" onclick="switchPage('favourites',document.querySelectorAll('.sn-item')[2]);return false">❤️ My Favourites</a>
<button onclick="openAddRecipeModal()" class="fav-link" style="background:var(--teal);color:#fff;border-color:var(--teal)" aria-label="Add new recipe">+ Add Recipe</button>
</div>
<div class="recipe-filters" role="toolbar" aria-label="Filter recipes"><button class="rf-tag active" onclick="filterRecipeTag(this,'all')" aria-pressed="true">All</button><button class="rf-tag" onclick="filterRecipeTag(this,'healthy')" aria-pressed="false">Healthy</button><button class="rf-tag" onclick="filterRecipeTag(this,'quick')" aria-pressed="false">Quick</button><button class="rf-tag" onclick="filterRecipeTag(this,'vegan')" aria-pressed="false">Vegan</button><button class="rf-tag" onclick="filterRecipeTag(this,'high-protein')" aria-pressed="false">High Protein</button><button class="rf-tag" onclick="filterRecipeTag(this,'comfort')" aria-pressed="false">Comfort</button><button class="rf-tag" onclick="filterRecipeTag(this,'my-recipes')" aria-pressed="false">My Recipes</button></div>
<div class="recipe-grid">
<div class="recipe-card" data-recipe-id="mediterranean-quinoa"><div class="rc-img" style="background:var(--teal-lll)">🥗</div><div class="rc-body"><div class="rc-tag">Healthy · 15 min</div><div class="rc-title">Mediterranean Quinoa Bowl</div><div class="rc-meta">420 kcal · £3.20</div><div class="rc-footer"><span class="rc-rating">★★★★☆</span><span class="rc-fav">🤍</span></div></div></div>
<div class="recipe-card" data-recipe-id="shakshuka"><div class="rc-img" style="background:var(--amber-ll)">🍳</div><div class="rc-body"><div class="rc-tag">Quick · 20 min</div><div class="rc-title">Shakshuka</div><div class="rc-meta">380 kcal · £2.40</div><div class="rc-footer"><span class="rc-rating">★★★★★</span><span class="rc-fav">❤️</span></div></div></div>
<div class="recipe-card" data-recipe-id="grilled-salmon"><div class="rc-img" style="background:rgba(122,170,212,0.15)">🐟</div><div class="rc-body"><div class="rc-tag">Omega-3 · 25 min</div><div class="rc-title">Grilled Salmon & Greens</div><div class="rc-meta">510 kcal · £4.50</div><div class="rc-footer"><span class="rc-rating">★★★★☆</span><span class="rc-fav">🤍</span></div></div></div>
<div class="recipe-card" data-recipe-id="avocado-toast"><div class="rc-img" style="background:var(--teal-lll)">🥑</div><div class="rc-body"><div class="rc-tag">Vegan · 10 min</div><div class="rc-title">Avocado Toast</div><div class="rc-meta">290 kcal · £1.80</div><div class="rc-footer"><span class="rc-rating">★★★★★</span><span class="rc-fav">❤️</span></div></div></div>
<div class="recipe-card" data-recipe-id="pasta-primavera"><div class="rc-img" style="background:var(--amber-ll)">🍝</div><div class="rc-body"><div class="rc-tag">Italian · 30 min</div><div class="rc-title">Pasta Primavera</div><div class="rc-meta">460 kcal · £2.90</div><div class="rc-footer"><span class="rc-rating">★★★★☆</span><span class="rc-fav">🤍</span></div></div></div>
<div class="recipe-card" data-recipe-id="lentil-soup"><div class="rc-img" style="background:rgba(224,123,120,0.1)">🍲</div><div class="rc-body"><div class="rc-tag">Comfort · 40 min</div><div class="rc-title">Lentil & Sweet Potato Soup</div><div class="rc-meta">320 kcal · £1.60</div><div class="rc-footer"><span class="rc-rating">★★★★★</span><span class="rc-fav">❤️</span></div></div></div>
</div></div>

<!-- Favourites -->
<div class="page" id="page-favourites" role="tabpanel" aria-label="Favourites"><div class="page-header"><div class="page-title">My <em>Favourites</em></div><div class="page-date">Your saved recipes — click remove to unfavourite</div></div>
<div class="fav-grid" id="fav-cards-grid">
<div class="fav-card"><div class="fav-card-img" style="background:var(--amber-ll)">🍳</div><div class="fav-card-body"><div class="fav-card-title">Shakshuka</div><div class="fav-card-meta">380 kcal · 20 min · £2.40</div><div class="fav-card-footer"><span class="fav-card-rating">★★★★★</span><span class="fav-remove">Remove</span></div></div></div>
<div class="fav-card"><div class="fav-card-img" style="background:var(--teal-lll)">🥑</div><div class="fav-card-body"><div class="fav-card-title">Avocado Toast</div><div class="fav-card-meta">290 kcal · 10 min · £1.80</div><div class="fav-card-footer"><span class="fav-card-rating">★★★★★</span><span class="fav-remove">Remove</span></div></div></div>
<div class="fav-card"><div class="fav-card-img" style="background:rgba(224,123,120,0.1)">🍲</div><div class="fav-card-body"><div class="fav-card-title">Lentil & Sweet Potato Soup</div><div class="fav-card-meta">320 kcal · 40 min · £1.60</div><div class="fav-card-footer"><span class="fav-card-rating">★★★★★</span><span class="fav-remove">Remove</span></div></div></div>
</div></div>

<!-- Plan -->
<div class="page" id="page-plan" role="tabpanel" aria-label="Recipe Compare"><div class="page-header"><div class="page-title">Recipe <em>Compare</em></div><div class="page-date">Select up to 4 favourite recipes to compare nutritional data</div></div>
<div class="plan-selector" id="compare-chips">
<div class="plan-chip selected"><div class="chip-dot" style="background:var(--teal)"></div>Shakshuka<span class="chip-remove">×</span></div>
<div class="plan-chip selected"><div class="chip-dot" style="background:var(--amber)"></div>Avocado Toast<span class="chip-remove">×</span></div>
<div class="plan-chip selected"><div class="chip-dot" style="background:var(--blue)"></div>Lentil Soup<span class="chip-remove">×</span></div>
<button class="plan-add" onclick="openCompareSelect()">+ Add from favourites (1 left)</button>
</div>

<!-- Big bar chart -->
<div class="bar-chart-card" style="background:var(--white);border:1px solid var(--border);border-radius:16px;padding:28px;box-shadow:0 4px 16px rgba(10,20,16,0.04)">
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
<div><div style="font-size:15px;font-weight:700;color:var(--ink)">Nutritional Comparison</div><div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f);margin-top:3px">Per serving values</div></div>
<div class="pc-legend" style="margin:0" id="compare-legend"></div>
</div>
<div id="compare-chart-svg-wrap" style="overflow-x:auto;margin-top:4px"></div>
</div>
</div>

<!-- PAGE 5: Meal Planner (dynamic) -->
<div class="page" id="page-planner" role="tabpanel" aria-label="Meal Planner">
<div class="page-header"><div class="page-title">Meal <em>Planner</em></div><div class="page-date">Plan your meals for the day — lock your picks, let us fill the rest</div></div>

<!-- Calorie budget bar -->
<div style="background:var(--white);border:1px solid var(--border);border-radius:14px;padding:18px 24px;margin-bottom:20px;box-shadow:0 2px 8px rgba(10,20,16,0.03)">
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
  <div style="font-size:13px;font-weight:700;color:var(--ink)">Today's Calorie Budget</div>
  <div id="mp-budget-text" style="font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--ink-f)"></div>
</div>
<div style="width:100%;height:8px;background:var(--fog);border-radius:8px;overflow:hidden">
  <div id="mp-budget-bar" style="height:100%;background:linear-gradient(90deg,var(--teal),var(--teal-l));border-radius:8px;transition:width .3s"></div>
</div>
<div style="display:flex;justify-content:space-between;margin-top:5px;font-family:'JetBrains Mono',monospace;font-size:8px;color:var(--ink-f)"><span>0</span><span id="mp-target-label">2,400 kcal</span></div>
</div>

<!-- Auto-fill controls -->
<div style="background:var(--teal-lll);border:1px solid var(--teal-ll);border-radius:14px;padding:18px 20px;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px">
  <div>
    <div style="font-size:13px;font-weight:700;color:var(--ink);display:flex;align-items:center;gap:8px"><span aria-hidden="true">✨</span> Smart fill</div>
    <div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--ink-f);margin-top:3px">Pick your favourites first, then auto-fill the rest based on your calorie budget</div>
  </div>
  <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
    <div style="display:flex;gap:4px" id="mp-fill-mode">
      <button class="sp-cat" onclick="mpSetFillMode(this,'light')" style="font-size:9px">🥗 Light (~50%)</button>
      <button class="sp-cat active" onclick="mpSetFillMode(this,'balanced')" style="font-size:9px">⚖️ Balanced (~75%)</button>
      <button class="sp-cat" onclick="mpSetFillMode(this,'full')" style="font-size:9px">💪 Full (100%)</button>
    </div>
    <button onclick="mpAutoFill()" style="padding:9px 20px;background:var(--ink);color:#fff;border:none;border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:12px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:6px;transition:background .2s" onmouseover="this.style.background='var(--teal)'" onmouseout="this.style.background='var(--ink)'"><span aria-hidden="true">⚡</span> Fill remaining</button>
    <button onclick="mpClearAll()" style="padding:9px 14px;background:transparent;color:var(--ink-f);border:1px solid var(--border);border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:11px;font-weight:600;cursor:pointer;transition:all .2s" onmouseover="this.style.borderColor='var(--teal)';this.style.color='var(--teal)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--ink-f)'">Clear all</button>
  </div>
</div>

<!-- Meal slots (rendered by JS) -->
<div id="mp-breakfast" class="mp-meal-section"></div>
<div id="mp-lunch" class="mp-meal-section"></div>
<div id="mp-dinner" class="mp-meal-section"></div>

<!-- Summary bar -->
<div id="mp-summary" style="background:var(--ink);border-radius:14px;padding:20px 24px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 8px 32px rgba(10,20,16,0.2);flex-wrap:wrap;gap:12px"></div>
</div>

<!-- Recipe picker modal for meal planner -->
<div id="mp-picker-overlay" style="position:fixed;inset:0;background:rgba(10,20,16,0.4);z-index:3000;display:none;align-items:center;justify-content:center">
<div style="background:var(--white);border-radius:20px;width:520px;max-width:90vw;max-height:80vh;overflow:hidden;box-shadow:0 24px 80px rgba(10,20,16,0.2);display:flex;flex-direction:column">
  <div style="padding:20px 24px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center">
    <div style="font-family:'Instrument Serif',serif;font-size:22px;font-style:italic;color:var(--ink)">Add to <em id="mp-picker-meal">Breakfast</em></div>
    <button onclick="mpClosePicker()" aria-label="Close recipe picker" style="width:36px;height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px;cursor:pointer;border:none;background:var(--paper);color:var(--ink-m)">✕</button>
  </div>
  <div style="padding:12px 24px;border-bottom:1px solid var(--border)">
    <input type="text" id="mp-picker-search" placeholder="Search recipes..." oninput="mpFilterPicker(this.value)" style="width:100%;padding:9px 12px;border:1px solid var(--border);border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:13px;outline:none">
  </div>
  <div id="mp-picker-list" style="flex:1;overflow-y:auto;padding:8px 24px"></div>
</div>
</div>



<!-- Personal Details Overlay -->
<div class="settings-overlay" id="overlay-personal">
<div class="settings-inner">
<div style="margin-bottom:28px"><div class="page-title">Personal <em>Details</em></div><div class="page-date">Manage your account information</div></div>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px">
<div style="background:var(--white);border:1px solid var(--border);border-radius:16px;padding:28px;box-shadow:0 4px 16px rgba(10,20,16,0.04)">
<div style="display:flex;align-items:center;gap:18px;margin-bottom:24px;padding-bottom:20px;border-bottom:1px solid var(--fog)"><div style="width:64px;height:64px;border-radius:50%;background:var(--teal);color:#fff;display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:700">RC</div><div><div style="font-size:18px;font-weight:700;color:var(--ink)">Rose Campbell</div><div style="font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--ink-f);margin-top:3px">Subscriber · Member since March 2026</div></div></div>
<div style="display:flex;flex-direction:column;gap:16px">
<div><div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f);letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px">First Name</div><input aria-label="Text input" type="text" value="Rose" style="width:100%;padding:10px 14px;border:1px solid var(--border);border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:13px;color:var(--ink);outline:none" onfocus="this.style.boxShadow='0 1px 4px rgba(10,20,16,0.08)'" onblur="this.style.boxShadow='none'"></div>
<div><div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f);letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px">Last Name</div><input aria-label="Text input" type="text" value="Campbell" style="width:100%;padding:10px 14px;border:1px solid var(--border);border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:13px;color:var(--ink);outline:none" onfocus="this.style.boxShadow='0 1px 4px rgba(10,20,16,0.08)'" onblur="this.style.boxShadow='none'"></div>
<div><div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f);letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px">Email Address</div><input type="email" value="rose.campbell@example.com" style="width:100%;padding:10px 14px;border:1px solid var(--border);border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:13px;color:var(--ink);outline:none" onfocus="this.style.boxShadow='0 1px 4px rgba(10,20,16,0.08)'" onblur="this.style.boxShadow='none'"></div>
<div><div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f);letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px">Date of Birth</div><input aria-label="Select date" type="date" value="1995-06-14" style="width:100%;padding:10px 14px;border:1px solid var(--border);border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:13px;color:var(--ink);outline:none" onfocus="this.style.boxShadow='0 1px 4px rgba(10,20,16,0.08)'" onblur="this.style.boxShadow='none'"></div>
</div>
<button style="margin-top:20px;padding:11px 28px;background:var(--ink);color:#fff;border:none;border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s" onmouseover="this.style.background='var(--teal)'" onmouseout="this.style.background='var(--ink)'">Save Changes</button>
</div>
<div style="display:flex;flex-direction:column;gap:20px">
<div style="background:var(--white);border:1px solid var(--border);border-radius:16px;padding:28px;box-shadow:0 4px 16px rgba(10,20,16,0.04)"><div style="font-size:14px;font-weight:700;color:var(--ink);margin-bottom:18px">Health Profile</div><div style="display:grid;grid-template-columns:1fr 1fr;gap:14px"><div><div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f);letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px">Height (cm)</div><input id="profileHeight" aria-label="Enter number" type="number" placeholder="e.g. 170" style="width:100%;padding:10px 14px;border:1px solid var(--border);border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:13px;color:var(--ink);outline:none"></div><div><div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f);letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px">Weight (kg)</div><input id="profileWeight" aria-label="Enter number" type="number" placeholder="e.g. 70" style="width:100%;padding:10px 14px;border:1px solid var(--border);border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:13px;color:var(--ink);outline:none"></div><div><div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f);letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px">Age</div><input id="profileAge" aria-label="Enter number" type="number" placeholder="e.g. 28" style="width:100%;padding:10px 14px;border:1px solid var(--border);border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:13px;color:var(--ink);outline:none"></div><div><div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f);letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px">Daily Calorie Target</div><input id="profileTargetKcal" aria-label="Enter number" type="number" placeholder="e.g. 2000" style="width:100%;padding:10px 14px;border:1px solid var(--border);border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:13px;color:var(--ink);outline:none"></div><div style="grid-column:1/-1"><div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f);letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px">Goal</div><select id="profileGoal" style="width:100%;padding:10px 14px;border:1px solid var(--border);border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:13px;color:var(--ink);outline:none;background:var(--white)"><option value="">Select a goal</option><option value="Weight Loss">Weight Loss</option><option value="Muscle Gain">Muscle Gain</option><option value="Maintenance">Maintenance</option><option value="General Health">General Health</option></select></div></div><button id="profileSaveBtn" onclick="saveHealthProfile()" style="margin-top:16px;padding:11px 28px;background:var(--ink);color:#fff;border:none;border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s" onmouseover="this.style.background='var(--teal)'" onmouseout="this.style.background='var(--ink)'">Save Profile</button></div>
<div style="background:var(--white);border:1px solid var(--border);border-radius:16px;padding:28px;box-shadow:0 4px 16px rgba(10,20,16,0.04)"><div style="font-size:14px;font-weight:700;color:var(--ink);margin-bottom:18px">Change Password</div><div style="display:flex;flex-direction:column;gap:14px"><div><div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f);letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px">Current Password</div><input type="password" placeholder="Enter current password" style="width:100%;padding:10px 14px;border:1px solid var(--border);border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:13px;color:var(--ink);outline:none"></div><div><div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f);letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px">New Password</div><input type="password" placeholder="Min. 8 characters" style="width:100%;padding:10px 14px;border:1px solid var(--border);border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:13px;color:var(--ink);outline:none"></div><div><div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f);letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px">Confirm New Password</div><input type="password" placeholder="Re-enter new password" style="width:100%;padding:10px 14px;border:1px solid var(--border);border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:13px;color:var(--ink);outline:none"></div></div><button style="margin-top:16px;padding:11px 28px;background:var(--ink);color:#fff;border:none;border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s" onmouseover="this.style.background='var(--teal)'" onmouseout="this.style.background='var(--ink)'">Update Password</button></div>
</div>
</div>
</div>
</div>

<!-- Preferences Overlay -->
<div class="settings-overlay" id="overlay-preferences">
<div class="settings-inner">
<div style="margin-bottom:28px"><div class="page-title">My <em>Preferences</em></div><div class="page-date">Customise your NourishWell experience</div></div>
<div style="display:grid;grid-template-columns:1fr 1fr;gap:20px">
<div style="display:flex;flex-direction:column;gap:20px">
<div style="background:var(--white);border:1px solid var(--border);border-radius:16px;padding:28px;box-shadow:0 4px 16px rgba(10,20,16,0.04)"><div style="font-size:14px;font-weight:700;color:var(--ink);margin-bottom:6px">Dietary Restrictions</div><div style="font-size:11px;color:var(--ink-f);margin-bottom:16px">Select any that apply</div><div style="display:flex;flex-wrap:wrap;gap:8px"><label style="display:flex;align-items:center;gap:6px;padding:8px 14px;border:1px solid var(--border);border-radius:8px;cursor:pointer;font-size:12px;color:var(--ink-m)"><input type="checkbox" style="accent-color:var(--teal)"> Vegetarian</label><label style="display:flex;align-items:center;gap:6px;padding:8px 14px;border:1px solid var(--border);border-radius:8px;cursor:pointer;font-size:12px;color:var(--ink-m)"><input type="checkbox" style="accent-color:var(--teal)"> Vegan</label><label style="display:flex;align-items:center;gap:6px;padding:8px 14px;border:1px solid var(--border);border-radius:8px;cursor:pointer;font-size:12px;color:var(--ink-m)"><input type="checkbox" style="accent-color:var(--teal)"> Gluten-free</label><label style="display:flex;align-items:center;gap:6px;padding:8px 14px;border:1px solid var(--border);border-radius:8px;cursor:pointer;font-size:12px;color:var(--ink-m)"><input type="checkbox" style="accent-color:var(--teal)"> Dairy-free</label><label style="display:flex;align-items:center;gap:6px;padding:8px 14px;border:1px solid var(--border);border-radius:8px;cursor:pointer;font-size:12px;color:var(--ink-m)"><input type="checkbox" style="accent-color:var(--teal)"> Nut allergy</label><label style="display:flex;align-items:center;gap:6px;padding:8px 14px;border:1px solid var(--border);border-radius:8px;cursor:pointer;font-size:12px;color:var(--ink-m)"><input type="checkbox" style="accent-color:var(--teal)"> Halal</label><label style="display:flex;align-items:center;gap:6px;padding:8px 14px;border:1px solid var(--border);border-radius:8px;cursor:pointer;font-size:12px;color:var(--ink-m)"><input type="checkbox" checked style="accent-color:var(--teal)"> Low-sugar</label></div></div>
<div style="background:var(--white);border:1px solid var(--border);border-radius:16px;padding:28px;box-shadow:0 4px 16px rgba(10,20,16,0.04)"><div style="font-size:14px;font-weight:700;color:var(--ink);margin-bottom:6px">Nutrition Goals</div><div style="font-size:11px;color:var(--ink-f);margin-bottom:16px">Set your daily macro targets</div><div style="display:flex;flex-direction:column;gap:14px"><div><div style="display:flex;justify-content:space-between;margin-bottom:6px"><span style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f);letter-spacing:.08em;text-transform:uppercase">Carbohydrates</span><span style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--teal);font-weight:600" id="label-carbs">45%</span></div><input aria-label="Adjust value" id="slider-carbs" type="range" min="5" max="70" value="45" style="width:100%;accent-color:var(--teal)"></div><div><div style="display:flex;justify-content:space-between;margin-bottom:6px"><span style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f);letter-spacing:.08em;text-transform:uppercase">Protein</span><span style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--teal);font-weight:600" id="label-protein">30%</span></div><input aria-label="Adjust value" id="slider-protein" type="range" min="5" max="60" value="30" style="width:100%;accent-color:var(--teal)"></div><div><div style="display:flex;justify-content:space-between;margin-bottom:6px"><span style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f);letter-spacing:.08em;text-transform:uppercase">Fat</span><span style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--teal);font-weight:600" id="label-fat">25%</span></div><input aria-label="Adjust value" id="slider-fat" type="range" min="5" max="50" value="25" style="width:100%;accent-color:var(--teal)"></div></div></div>
</div>
<div style="display:flex;flex-direction:column;gap:20px">
<div style="background:var(--white);border:1px solid var(--border);border-radius:16px;padding:28px;box-shadow:0 4px 16px rgba(10,20,16,0.04)"><div style="font-size:14px;font-weight:700;color:var(--ink);margin-bottom:6px">Notifications</div><div style="font-size:11px;color:var(--ink-f);margin-bottom:16px">Choose what alerts you receive</div><div style="display:flex;flex-direction:column;gap:12px"><label style="display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--fog)"><div><div style="font-size:12px;font-weight:600;color:var(--ink)">Meal reminders</div><div style="font-size:10px;color:var(--ink-f);margin-top:2px">Get reminded to log meals</div></div><input type="checkbox" checked style="accent-color:var(--teal);width:18px;height:18px"></label><label style="display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--fog)"><div><div style="font-size:12px;font-weight:600;color:var(--ink)">Weekly summary</div><div style="font-size:10px;color:var(--ink-f);margin-top:2px">Weekly nutrition report via email</div></div><input type="checkbox" checked style="accent-color:var(--teal);width:18px;height:18px"></label><label style="display:flex;align-items:center;justify-content:space-between;padding:10px 0;border-bottom:1px solid var(--fog)"><div><div style="font-size:12px;font-weight:600;color:var(--ink)">Recipe recommendations</div><div style="font-size:10px;color:var(--ink-f);margin-top:2px">New recipes based on preferences</div></div><input type="checkbox" style="accent-color:var(--teal);width:18px;height:18px"></label><label style="display:flex;align-items:center;justify-content:space-between;padding:10px 0"><div><div style="font-size:12px;font-weight:600;color:var(--ink)">Professional messages</div><div style="font-size:10px;color:var(--ink-f);margin-top:2px">Advice from your health professional</div></div><input type="checkbox" checked style="accent-color:var(--teal);width:18px;height:18px"></label></div></div>
<div style="background:var(--white);border:1px solid var(--border);border-radius:16px;padding:28px;box-shadow:0 4px 16px rgba(10,20,16,0.04)"><div style="font-size:14px;font-weight:700;color:var(--ink);margin-bottom:6px">Display Settings</div><div style="font-size:11px;color:var(--ink-f);margin-bottom:16px">Customise how data is shown</div><div style="display:flex;flex-direction:column;gap:14px"><div><div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f);letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px">Units</div><select style="width:100%;padding:10px 14px;border:1px solid var(--border);border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:13px;color:var(--ink);outline:none;background:var(--white)"><option selected>Metric (kg, cm)</option><option>Imperial (lbs, ft)</option></select></div><div><div style="font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--ink-f);letter-spacing:.08em;text-transform:uppercase;margin-bottom:6px">Currency</div><select style="width:100%;padding:10px 14px;border:1px solid var(--border);border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:13px;color:var(--ink);outline:none;background:var(--white)"><option selected>GBP (£)</option><option>EUR (€)</option><option>USD ($)</option></select></div></div></div>
<button style="padding:11px 28px;background:var(--ink);color:#fff;border:none;border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s;width:100%" onmouseover="this.style.background='var(--teal)'" onmouseout="this.style.background='var(--ink)'">Save All Preferences</button>
</div>
</div>
</div>
</div>

<!-- Compare Select Popup (from favourites) -->
<div class="fav-overlay" id="compare-select" onclick="closeCompareSelect()"><div class="fav-modal" onclick="event.stopPropagation()" style="width:500px">
<div class="fav-modal-header"><div class="fav-modal-title">Select from <em>Favourites</em></div><button class="fav-modal-close" onclick="closeCompareSelect()">✕</button></div>
<div style="padding:12px 24px;font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--ink-f);border-bottom:1px solid var(--border)">Choose up to 4 recipes to compare</div>
<div class="fav-list">
<div class="fav-item selected" onclick="this.classList.toggle('selected')"><div class="fav-item-icon" style="background:var(--amber-ll)">🍳</div><div class="fav-item-info"><div class="fav-item-name">Shakshuka</div><div class="fav-item-meta">380 kcal · 20 min</div></div><div class="fav-item-check">✓</div></div>
<div class="fav-item selected" onclick="this.classList.toggle('selected')"><div class="fav-item-icon" style="background:var(--teal-lll)">🥑</div><div class="fav-item-info"><div class="fav-item-name">Avocado Toast</div><div class="fav-item-meta">290 kcal · 10 min</div></div><div class="fav-item-check">✓</div></div>
<div class="fav-item selected" onclick="this.classList.toggle('selected')"><div class="fav-item-icon" style="background:rgba(224,123,120,0.1)">🍲</div><div class="fav-item-info"><div class="fav-item-name">Lentil & Sweet Potato Soup</div><div class="fav-item-meta">320 kcal · 40 min</div></div><div class="fav-item-check">✓</div></div>
<div class="fav-item" onclick="this.classList.toggle('selected')"><div class="fav-item-icon" style="background:var(--teal-lll)">🥗</div><div class="fav-item-info"><div class="fav-item-name">Mediterranean Quinoa Bowl</div><div class="fav-item-meta">420 kcal · 15 min</div></div><div class="fav-item-check">✓</div></div>
<div class="fav-item" onclick="this.classList.toggle('selected')"><div class="fav-item-icon" style="background:rgba(122,170,212,0.15)">🐟</div><div class="fav-item-info"><div class="fav-item-name">Grilled Salmon & Greens</div><div class="fav-item-meta">510 kcal · 25 min</div></div><div class="fav-item-check">✓</div></div>
</div>
<div style="padding:14px 24px;border-top:1px solid var(--border);display:flex;justify-content:flex-end"><button class="sp-footer-btn" onclick="closeCompareSelect()">Apply</button></div>
</div></div>


<!-- FOOD PANEL -->
<div id="foodDim" style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.25);z-index:2000;display:none" onclick="closeFoodPanel()"></div>
<div id="foodPanel" style="position:fixed;top:0;right:0;bottom:0;width:460px;background:#fff;z-index:2001;box-shadow:-8px 0 40px rgba(0,0,0,0.15);display:none;flex-direction:column">
<div style="padding:18px 22px;border-bottom:1px solid #d4dfd8;display:flex;justify-content:space-between;align-items:center">
<div style="font-family:'Instrument Serif',serif;font-size:20px;font-style:italic;color:#0a1410">Add Food</div>
<button onclick="closeFoodPanel()" style="width:32px;height:32px;border-radius:6px;border:none;background:#f5f7f5;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center">✕</button>
</div>
