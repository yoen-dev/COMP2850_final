<script>
function startTour(){} // stub
</script>


<div id="msgDim" onclick="closeUserMessages()" style="display:none;position:fixed;inset:0;z-index:997"></div>
<div id="msgPanel" style="display:none;position:fixed;top:60px;right:0;bottom:0;width:380px;background:#fff;border-left:1px solid var(--border);z-index:998;flex-direction:column;box-shadow:-8px 0 32px rgba(10,20,16,0.1)">
  <div style="padding:18px 20px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center">
    <div style="font-family:'Instrument Serif',serif;font-size:18px;font-style:italic;color:var(--ink)">Messages from Dr. Rivera</div>
    <button onclick="closeUserMessages()" style="width:30px;height:30px;border:none;background:var(--paper);border-radius:6px;cursor:pointer;font-size:16px;color:var(--ink-m)">✕</button>
  </div>
  <div style="flex:1;overflow-y:auto" id="msgList"></div>
  <div style="padding:14px 20px;border-top:1px solid var(--border)">
    <div style="display:flex;gap:8px">
      <input id="msgInput" type="text" placeholder="Reply to Dr. Rivera..." style="flex:1;padding:9px 12px;border:1px solid var(--border);border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:13px;color:var(--ink);outline:none" onkeydown="if(event.key==='Enter')sendMsg()">
      <button onclick="sendMsg()" style="padding:9px 18px;background:var(--ink);color:#fff;border:none;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer">Send</button>
    </div>
  </div>
</div>
<script>
var userMsgs=[
  {from:'pro',text:"Hi Rose! How did the new salmon recipe go?",time:"09:32"},
  {from:'user',text:"Loved it! Adding it to my weekly rotation.",time:"09:45"},
  {from:'pro',text:"Great — solid source of omega-3 and protein. Aim for at least 100g protein today.",time:"10:02"},
  {from:'pro',text:"Quick check-in: you're a bit low on protein this week. You're doing great overall 💪",time:"2h ago"},
];
function renderMsgs(){
  var list=document.getElementById('msgList');
  list.innerHTML=userMsgs.map(function(m){
    var isPro=m.from==='pro';
    return '<div style="display:flex;justify-content:'+(isPro?'flex-start':'flex-end')+';padding:10px 16px">'
      +'<div style="max-width:78%;background:'+(isPro?'var(--paper)':'var(--ink)')+';color:'+(isPro?'var(--ink)':'#fff')+';border-radius:'+(isPro?'4px 14px 14px 14px':'14px 4px 14px 14px')+';padding:10px 14px">'
      +(isPro?'<div style="font-size:9px;color:var(--teal);margin-bottom:4px;font-weight:600">Dr. Rivera</div>':'')
      +'<div style="font-size:13px;line-height:1.5">'+m.text+'</div>'
      +'<div style="font-size:9px;margin-top:4px;opacity:.45">'+m.time+'</div>'
      +'</div></div>';
  }).join('');
  list.scrollTop=list.scrollHeight;
}
function openUserMessages(){
  document.getElementById('userMailDot').style.display='none';
  document.getElementById('msgPanel').style.display='flex';
  document.getElementById('msgDim').style.display='block';
  renderMsgs();
}
function closeUserMessages(){
  document.getElementById('msgPanel').style.display='none';
  document.getElementById('msgDim').style.display='none';
}
function sendMsg(){
  var inp=document.getElementById('msgInput');
  var t=inp.value.trim(); if(!t) return;
  var now=new Date();
  userMsgs.push({from:'user',text:t,time:now.getHours()+':'+String(now.getMinutes()).padStart(2,'0')});
  inp.value=''; renderMsgs();
}
</script>


<!-- Add Recipe Modal -->
<div class="add-recipe-overlay" id="addRecipeOverlay" onclick="closeAddRecipeModal()" role="dialog" aria-modal="true" aria-label="Add new recipe">
<div class="add-recipe-modal" onclick="event.stopPropagation()">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
    <div style="font-family:'Instrument Serif',serif;font-size:22px;font-style:italic;color:var(--ink)">Add Your Recipe</div>
    <button onclick="closeAddRecipeModal()" style="width:32px;height:32px;border-radius:8px;border:none;background:var(--paper);cursor:pointer;font-size:16px" aria-label="Close">✕</button>
  </div>
  <div class="arm-row">
    <div class="arm-field"><label for="arm-emoji">Emoji</label><input id="arm-emoji" type="text" placeholder="🍕" maxlength="2"></div>
    <div class="arm-field" style="grid-column:span 2"><label for="arm-name">Recipe Name</label><input id="arm-name" type="text" placeholder="My Amazing Dish"></div>
  </div>
  <div class="arm-row">
    <div class="arm-field"><label for="arm-kcal">Calories (kcal)</label><input id="arm-kcal" type="number" placeholder="400" min="0"></div>
    <div class="arm-field"><label for="arm-time">Prep Time</label><input id="arm-time" type="text" placeholder="20 min"></div>
    <div class="arm-field"><label for="arm-cost">Cost</label><input id="arm-cost" type="text" placeholder="£2.50"></div>
  </div>
  <div class="arm-field"><label for="arm-tag">Category</label>
    <select id="arm-tag"><option value="Healthy">Healthy</option><option value="Quick">Quick</option><option value="Vegan">Vegan</option><option value="Comfort">Comfort</option><option value="High Protein">High Protein</option><option value="Italian">Italian</option></select>
  </div>
  <div class="arm-field"><label for="arm-ingredients">Ingredients (one per line)</label><textarea id="arm-ingredients" rows="4" placeholder="200g pasta&#10;1 onion&#10;2 tomatoes"></textarea></div>
  <div class="arm-field"><label for="arm-steps">Steps (one per line)</label><textarea id="arm-steps" rows="4" placeholder="Boil pasta.&#10;Sauté onion.&#10;Combine and serve."></textarea></div>
  <div style="display:flex;gap:10px;margin-top:8px">
    <button onclick="submitCustomRecipe()" style="flex:1;padding:12px;background:var(--ink);color:#fff;border:none;border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s" onmouseover="this.style.background='var(--teal)'" onmouseout="this.style.background='var(--ink)'">Save Recipe →</button>
    <button onclick="closeAddRecipeModal()" style="padding:12px 20px;background:var(--paper);color:var(--ink-m);border:1px solid var(--border);border-radius:8px;font-size:13px;cursor:pointer">Cancel</button>
  </div>
</div>
</div>


<script>
// ══════════════════════════════════════════════════════════════
// FEATURE: Dark Mode
// ══════════════════════════════════════════════════════════════
function toggleDarkMode(){
  document.body.classList.toggle('dark-mode');
  const isDark = document.body.classList.contains('dark-mode');
  try { localStorage.setItem('nw-dark-mode', isDark ? '1' : '0'); } catch(e){}
  var icon = document.getElementById('subDarkModeIcon');
  if(icon) icon.textContent = isDark ? '☀️' : '🌙';
  showToast(isDark ? '🌙 Dark mode on' : '☀️ Light mode on');
}
(function(){try{if(localStorage.getItem('nw-dark-mode')==='1'){document.body.classList.add('dark-mode');var i=document.getElementById('subDarkModeIcon');if(i)i.textContent='☀️';}}catch(e){}})();

// ══════════════════════════════════════════════════════════════
// FEATURE: Recipe Search (actually working)
// ══════════════════════════════════════════════════════════════
function filterRecipes(q){
  applyAllFilters();
}

// ══════════════════════════════════════════════════════════════
// FEATURE: Recipe Tag Filter
// ══════════════════════════════════════════════════════════════
function filterRecipeTag(btn, tag){
  document.querySelectorAll('.rf-tag').forEach(b=>{ b.classList.remove('active'); b.setAttribute('aria-pressed','false'); });
  btn.classList.add('active'); btn.setAttribute('aria-pressed','true');
  applyAllFilters();
}

// ══════════════════════════════════════════════════════════════
// FEATURE: Food Panel Search (actually working)
// ══════════════════════════════════════════════════════════════
function filterFoodItems(q){
  const term = q.toLowerCase().trim();
  document.querySelectorAll('#foodPanel .frow').forEach(row=>{
    const name = (row.querySelector('b')?.textContent || '').toLowerCase();
    row.style.display = (!term || name.includes(term)) ? '' : 'none';
  });
}

// ══════════════════════════════════════════════════════════════
// FEATURE: Food/Exercise Category Filter (actually working)
// ══════════════════════════════════════════════════════════════
(function(){
  // Assign data-cat to food rows
  const foodCats = {
    'White Rice':'staples','Steamed Broccoli':'vegetables','Grilled Chicken':'meat & eggs',
    'Boiled Egg':'meat & eggs','Mixed Salad':'vegetables','Wholemeal Toast':'staples',
    'Apple':'fruits','Semi-Skimmed Milk':'dairy','Mixed Nuts':'snacks','Grilled Salmon':'meat & eggs'
  };
  const exCats = {
    'Running':'cardio','Swimming':'cardio','Weight Training':'strength','Cycling':'cardio',
    'Yoga':'flexibility','Walking':'cardio','Football':'sports','Tennis':'sports','HIIT Workout':'cardio'
  };
  document.addEventListener('DOMContentLoaded', function(){
    document.querySelectorAll('#foodPanel .frow').forEach(row=>{
      const name = row.querySelector('b')?.textContent||'';
      row.dataset.cat = foodCats[name] || 'all';
    });
    document.querySelectorAll('#exPanel .frow').forEach(row=>{
      const name = row.querySelector('b')?.textContent||'';
      row.dataset.cat = exCats[name] || 'all';
    });
  });
})();

// Override pickCat to actually filter
var _origPickCat = typeof pickCat === 'function' ? pickCat : null;
pickCat = function(el){
  el.parentElement.querySelectorAll('.fcb').forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
  const cat = el.textContent.toLowerCase().trim();
  const panel = el.closest('#foodPanel') || el.closest('#exPanel');
  if(!panel) return;
  panel.querySelectorAll('.frow').forEach(row=>{
    if(cat==='all'){ row.style.display=''; return; }
    row.style.display = (row.dataset.cat||'').includes(cat) ? '' : 'none';
  });
};

// ══════════════════════════════════════════════════════════════
// FEATURE: Add Custom Recipe
// ══════════════════════════════════════════════════════════════
function openAddRecipeModal(){ document.getElementById('addRecipeOverlay').classList.add('open'); }
function closeAddRecipeModal(){ document.getElementById('addRecipeOverlay').classList.remove('open'); }
function submitCustomRecipe(){
  const emoji = document.getElementById('arm-emoji').value.trim() || '🍽️';
  const name = document.getElementById('arm-name').value.trim();
  const kcal = parseInt(document.getElementById('arm-kcal').value) || 0;
  const time = document.getElementById('arm-time').value.trim() || '? min';
  const cost = document.getElementById('arm-cost').value.trim() || '£0';
  const tag = document.getElementById('arm-tag').value;
  const ingredients = document.getElementById('arm-ingredients').value.split('\n').filter(Boolean);
  const steps = document.getElementById('arm-steps').value.split('\n').filter(Boolean);
  if(!name){ showToast('Please enter a recipe name','#c0392b'); return; }
  if(!kcal){ showToast('Please enter calories','#c0392b'); return; }
  const id = 'custom-' + Date.now();
  const bgColors = ['var(--teal-lll)','var(--amber-ll)','rgba(122,170,212,0.15)','rgba(224,123,120,0.1)'];
  RECIPES[id] = { id, emoji, name, tag: tag+' · '+time, kcal, cost, rating:'★★★★★', bg: bgColors[Math.floor(Math.random()*bgColors.length)], ingredients, steps, custom:true };
  // Add card to grid
  const grid = document.querySelector('.recipe-grid');
  const card = document.createElement('div');
  card.className = 'recipe-card';
  card.dataset.recipeId = id;
  card.innerHTML = '<div class="rc-img" style="background:'+RECIPES[id].bg+'">'+emoji+'</div><div class="rc-body"><div class="rc-tag">'+RECIPES[id].tag+'</div><div class="rc-title">'+name+'</div><div class="rc-meta">'+kcal+' kcal · '+cost+'</div><div class="rc-footer"><span class="rc-rating">★★★★★</span><span class="rc-fav" onclick="event.stopPropagation();toggleFav(\''+id+'\',this)">🤍</span></div></div>';
  card.addEventListener('click', function(e){ if(!e.target.classList.contains('rc-fav')) openRecipeDetail(id); });
  grid.appendChild(card);
  closeAddRecipeModal();
  showToast('✓ Recipe "'+name+'" added!','#1e6b5e');
  // Save to localStorage
  saveCustomRecipes();
  // Clear form
  ['arm-emoji','arm-name','arm-kcal','arm-time','arm-cost','arm-ingredients','arm-steps'].forEach(id=>document.getElementById(id).value='');
}
function saveCustomRecipes(){
  try{
    const custom = {};
    Object.entries(RECIPES).forEach(([k,v])=>{ if(v.custom) custom[k]=v; });
    localStorage.setItem(_nwKey('custom-recipes'), JSON.stringify(custom));
  }catch(e){}
}
function loadCustomRecipes(){
  try{
    const data = localStorage.getItem(_nwKey('custom-recipes'));
    if(!data) return;
    const custom = JSON.parse(data);
    Object.entries(custom).forEach(([k,v])=>{
      v.custom = true;
      RECIPES[k] = v;
      // Render card
      const grid = document.querySelector('.recipe-grid');
      if(!grid) return;
      const card = document.createElement('div');
      card.className = 'recipe-card';
      card.dataset.recipeId = k;
      card.innerHTML = '<div class="rc-img" style="background:'+v.bg+'">'+v.emoji+'</div><div class="rc-body"><div class="rc-tag">'+v.tag+'</div><div class="rc-title">'+v.name+'</div><div class="rc-meta">'+v.kcal+' kcal · '+v.cost+'</div><div class="rc-footer"><span class="rc-rating">'+(v.rating||'★★★★★')+'</span><span class="rc-fav">🤍</span></div></div>';
      card.addEventListener('click', function(e){ if(!e.target.classList.contains('rc-fav')) openRecipeDetail(k); });
      const fav = card.querySelector('.rc-fav');
      if(fav) fav.addEventListener('click', function(e){ e.stopPropagation(); toggleFav(k, fav); });
      grid.appendChild(card);
    });
  }catch(e){}
}

// ══════════════════════════════════════════════════════════════
// FEATURE: Interactive Star Rating
// ══════════════════════════════════════════════════════════════
var recipeRatings = {};
(function(){ try{ recipeRatings = JSON.parse(localStorage.getItem('nw-ratings')||'{}'); }catch(e){} })();
function renderStarRating(recipeId, container){
  const current = recipeRatings[recipeId] || 0;
  let html = '<div class="star-rate" data-recipe="'+recipeId+'" role="radiogroup" aria-label="Rate this recipe">';
  for(let i=1;i<=5;i++){
    html += '<span class="star '+(i<=current?'filled':'')+'" data-val="'+i+'" onclick="setRating(\''+recipeId+'\','+i+',this)" role="radio" aria-checked="'+(i<=current)+'" aria-label="'+i+' star'+(i>1?'s':'')+'" tabindex="0">★</span>';
  }
  html += '</div>';
  container.innerHTML = html;
}
function setRating(recipeId, val, starEl){
  recipeRatings[recipeId] = val;
  try{ localStorage.setItem('nw-ratings', JSON.stringify(recipeRatings)); }catch(e){}
  const wrap = starEl.closest('.star-rate');
  wrap.querySelectorAll('.star').forEach((s,i)=>{
    s.classList.toggle('filled', i < val);
    s.setAttribute('aria-checked', i < val);
  });
  // Update recipe card rating text
  const stars = '★'.repeat(val) + '☆'.repeat(5-val);
  if(RECIPES[recipeId]) RECIPES[recipeId].rating = stars;
  const card = document.querySelector('[data-recipe-id="'+recipeId+'"] .rc-rating');
  if(card) card.textContent = stars;
  showToast('Rated '+val+' star'+(val>1?'s':''),'#b8621f');
}

// ══════════════════════════════════════════════════════════════
// FEATURE: Recipe Comments
// ══════════════════════════════════════════════════════════════
var recipeComments = {};
(function(){ try{ recipeComments = JSON.parse(localStorage.getItem('nw-comments')||'{}'); }catch(e){} })();
function renderComments(recipeId){
  const comments = recipeComments[recipeId] || [];
  let html = '<div class="comment-section"><div style="font-family:\'JetBrains Mono\',monospace;font-size:9px;color:var(--ink-f);letter-spacing:.08em;text-transform:uppercase;margin-bottom:8px">Comments ('+comments.length+')</div>';
  comments.forEach(c=>{
    html += '<div class="comment-item"><div class="comment-author">'+c.author+' · '+c.time+'</div><div class="comment-text">'+c.text+'</div></div>';
  });
  html += '<div class="comment-input-wrap"><input type="text" id="comment-input-'+recipeId+'" placeholder="Add a comment..." aria-label="Add comment" onkeydown="if(event.key===\'Enter\')addComment(\''+recipeId+'\')"><button onclick="addComment(\''+recipeId+'\')">Post</button></div></div>';
  return html;
}
function addComment(recipeId){
  const input = document.getElementById('comment-input-'+recipeId);
  if(!input) return;
  const text = input.value.trim();
  if(!text) return;
  if(!recipeComments[recipeId]) recipeComments[recipeId] = [];
  const now = new Date();
  recipeComments[recipeId].push({ author:'Rose C.', text, time: now.getHours()+':'+String(now.getMinutes()).padStart(2,'0') });
  try{ localStorage.setItem('nw-comments', JSON.stringify(recipeComments)); }catch(e){}
  input.value = '';
  // Re-render comments section
  const panel = document.getElementById('recipe-detail-panel');
  if(panel){
    const cs = panel.querySelector('.comment-section');
    if(cs) cs.outerHTML = renderComments(recipeId);
  }
  showToast('Comment added','#1e6b5e');
}

// ── Patch openRecipeDetail to include rating + comments ──
var _origOpenRecipeDetail = openRecipeDetail;
openRecipeDetail = function(id){
  _origOpenRecipeDetail(id);
  // Wait for panel to render
  setTimeout(function(){
    const panel = document.getElementById('recipe-detail-panel');
    if(!panel) return;
    // Add star rating
    const footer = panel.querySelector('[style*="border-top"]');
    if(footer){
      const ratingWrap = document.createElement('div');
      ratingWrap.style.cssText = 'padding:0 22px 6px';
      footer.parentNode.insertBefore(ratingWrap, footer);
      renderStarRating(id, ratingWrap);
    }
    // Add comments
    const scrollArea = panel.querySelector('[style*="overflow-y:auto"]');
    if(scrollArea){
      const commentsHtml = renderComments(id);
      scrollArea.insertAdjacentHTML('beforeend', commentsHtml);
    }
  }, 50);
};

// ══════════════════════════════════════════════════════════════
// FEATURE: Food Diary History with Date Navigation
// ══════════════════════════════════════════════════════════════
var currentDiaryDate = new Date().toISOString().split('T')[0];
var diaryHistory = {};

function saveDiaryForDate(){
  diaryHistory[currentDiaryDate] = JSON.parse(JSON.stringify(mealLog));
  try{ localStorage.setItem(_nwKey('diary-history'), JSON.stringify(diaryHistory)); }catch(e){}
}
function loadDiaryHistory(){
  try{
    const data = localStorage.getItem(_nwKey('diary-history'));
    if(data) diaryHistory = JSON.parse(data);
  }catch(e){}
}
function loadDateDiary(dateStr){
  // Save current day first
  saveDiaryForDate();
  currentDiaryDate = dateStr;
  if(diaryHistory[dateStr]){
    Object.keys(mealLog).forEach(k=>{ mealLog[k] = diaryHistory[dateStr][k] || []; });
  } else {
    Object.keys(mealLog).forEach(k=>{ mealLog[k] = []; });
  }
  renderMealLog(); updateDonut();
  // Update display date
  const d = new Date(dateStr+'T12:00:00');
  const days=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  const months=['January','February','March','April','May','June','July','August','September','October','November','December'];
  document.getElementById('today-date').textContent = days[d.getDay()]+', '+d.getDate()+' '+months[d.getMonth()]+' '+d.getFullYear();
  document.getElementById('diary-date-picker').value = dateStr;
}
function changeDate(delta){
  const d = new Date(currentDiaryDate+'T12:00:00');
  d.setDate(d.getDate()+delta);
  loadDateDiary(d.toISOString().split('T')[0]);
}
function goToday(){
  loadDateDiary(new Date().toISOString().split('T')[0]);
}

// ══════════════════════════════════════════════════════════════
// FEATURE: Calorie Trend Line Chart
// ══════════════════════════════════════════════════════════════
var calorieTrendData = [0, 0, 0, 0, 0, 0, 0];
var _calorieTrendChart = null;

function updateCalorieTrend(){
  if(!_calorieTrendChart) return;
  // today is index 6 (Sun col) — compute total kcal from mealLog
  var todayKcal = 0;
  Object.values(mealLog).forEach(function(arr){ arr.forEach(function(e){ todayKcal += e.kcal; }); });
  calorieTrendData[6] = todayKcal;
  _calorieTrendChart.data.datasets[0].data = calorieTrendData.slice();
  _calorieTrendChart.update();
}

function initCalorieTrendChart(){
  const ctx = document.getElementById('calorieTrendChart');
  if(!ctx) return;
  var _t = window._nwDailyTarget || DAILY_TARGET;
  _calorieTrendChart = new Chart(ctx.getContext('2d'), {
    type:'line',
    data:{
      labels:['Mon','Tue','Wed','Thu','Fri','Sat','Sun'],
      datasets:[
        { label:'Intake', data:calorieTrendData, borderColor:'#1e6b5e', backgroundColor:'rgba(30,107,94,0.1)', fill:true, tension:0.35, pointRadius:4, pointBackgroundColor:'#1e6b5e', borderWidth:2 },
        { label:'Target', data:Array(7).fill(_t), borderColor:'#b8621f', borderWidth:1.5, borderDash:[4,3], pointRadius:0, fill:false, tension:0 }
      ]
    },
    options:{
      responsive:true, maintainAspectRatio:false,
      plugins:{ legend:{display:false}, tooltip:{ backgroundColor:'#0a1410', titleColor:'rgba(255,255,255,0.5)', bodyColor:'#fff', titleFont:{family:"'JetBrains Mono',monospace",size:9}, bodyFont:{family:"'JetBrains Mono',monospace",size:11}, padding:10, cornerRadius:6 } },
      scales:{
        x:{ grid:{display:false}, border:{display:false}, ticks:{font:{family:"'JetBrains Mono',monospace",size:9},color:'#6b8878'} },
        y:{ min:0, max:3000, grid:{color:'#dce6e0',lineWidth:0.5}, border:{display:false}, ticks:{font:{family:"'JetBrains Mono',monospace",size:9},color:'#6b8878',stepSize:500} }
      }
    }
  });
}
// Update calorie trend target line when profile changes
window._nwUpdateCalorieTrend = function(){
  if(!_calorieTrendChart) return;
  var _t = window._nwDailyTarget || DAILY_TARGET;
  _calorieTrendChart.data.datasets[1].data = Array(7).fill(_t);
  _calorieTrendChart.update();
};

// ══════════════════════════════════════════════════════════════
// FEATURE: Exercise Chart Month/Year Data Switching
// ══════════════════════════════════════════════════════════════
var exMonthData = [280,420,0,310,390,500,180,450,320,0,280,410,350,290,0,310,480,0,390,270,510,0,320,440,380,290,0,410,370,0];
var exYearData = [8500,9200,7800,10100,9600,11200,8900,10500,9800,7200,8800,9500];
var _origSwitchChartTab = switchChartTab;
switchChartTab = function(el){
  el.parentElement.querySelectorAll('.cc-tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  const mode = el.textContent.trim();
  if(!exChartInstance) return;
  if(mode==='Week'){
    exChartInstance.data.labels = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
    exChartInstance.data.datasets[0].data = [...exChartData];
    exChartInstance.data.datasets[0].backgroundColor = exChartData.map(v=>v===0?'#dce6e0':v>=EX_TARGET?'#1e6b5e':'#2f8f7f');
    exChartInstance.data.datasets[1].data = Array(7).fill(EX_TARGET);
    exChartInstance.options.scales.y.max = 600;
  } else if(mode==='Month'){
    exChartInstance.data.labels = Array.from({length:30},(_,i)=>i+1);
    exChartInstance.data.datasets[0].data = exMonthData;
    exChartInstance.data.datasets[0].backgroundColor = exMonthData.map(v=>v===0?'#dce6e0':v>=EX_TARGET?'#1e6b5e':'#2f8f7f');
    exChartInstance.data.datasets[1].data = Array(30).fill(EX_TARGET);
    exChartInstance.options.scales.y.max = 600;
  } else {
    exChartInstance.data.labels = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    exChartInstance.data.datasets[0].data = exYearData;
    exChartInstance.data.datasets[0].backgroundColor = exYearData.map(v=>'#1e6b5e');
    exChartInstance.data.datasets[1].data = Array(12).fill(EX_TARGET*30);
    exChartInstance.options.scales.y.max = 12000;
  }
  exChartInstance.update();
};

// ══════════════════════════════════════════════════════════════
// FEATURE: localStorage Persistence
// ══════════════════════════════════════════════════════════════
function _nwKey(k){ var uid = (typeof NW !== 'undefined' && NW.auth) ? NW.auth.userId : ''; return uid ? 'nw-' + uid + '-' + k : 'nw-' + k; }
function saveState(){
  saveDiaryForDate();
  try{
    localStorage.setItem(_nwKey('favourites'), JSON.stringify([...favourites]));
    localStorage.setItem(_nwKey('compare'), JSON.stringify([...compareSelected]));
    localStorage.setItem(_nwKey('exlog'), JSON.stringify(exLog));
    localStorage.setItem(_nwKey('exdata'), JSON.stringify(exChartData));
  }catch(e){}
}
function loadState(){
  try{
    const f = localStorage.getItem(_nwKey('favourites'));
    if(f){ favourites = new Set(JSON.parse(f)); }
    const c = localStorage.getItem(_nwKey('compare'));
    if(c){ compareSelected = new Set(JSON.parse(c)); }
    const el = localStorage.getItem(_nwKey('exlog'));
    if(el){ const parsed = JSON.parse(el); exLog.length=0; parsed.forEach(e=>exLog.push(e)); }
    const ed = localStorage.getItem(_nwKey('exdata'));
    if(ed){ const parsed = JSON.parse(ed); parsed.forEach((v,i)=>exChartData[i]=v); }
  }catch(e){}
  loadDiaryHistory();
}
// Auto-save on changes
var _origToggleFav = toggleFav;
toggleFav = function(id, heart){
  _origToggleFav(id, heart);
  saveState();
};
var _origCommitFoodEntries = commitFoodEntries;
commitFoodEntries = function(){
  _origCommitFoodEntries();
  saveState();
};
var _origDeleteMeal = deleteMeal;
deleteMeal = function(key,idx){
  _origDeleteMeal(key,idx);
  saveState();
};

// ══════════════════════════════════════════════════════════════
// FEATURE: Form Validation Enhancement
// ══════════════════════════════════════════════════════════════
function validateSettingsField(input, type){
  let valid = true;
  const val = input.value.trim();
  if(type==='email') valid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val);
  else if(type==='required') valid = val.length > 0;
  else if(type==='number') valid = !isNaN(val) && parseInt(val) > 0;
  else if(type==='password') valid = val.length >= 8;
  input.style.borderColor = valid ? 'var(--border)' : '#c0392b';
  return valid;
}

// ══════════════════════════════════════════════════════════════
// FEATURE: Keyboard Navigation
// ══════════════════════════════════════════════════════════════
document.addEventListener('keydown', function(e){
  if(e.key==='Escape'){
    // Close any open overlay/panel
    closeFoodPanel();
    closeExPanel();
    closeRecipeDetail();
    closeAddRecipeModal();
    closeCompareSelect();
    closeUserMessages();
    closeSettings();
    closeAvatarMenu();
  }
});
// Let Enter work on mail icon
document.addEventListener('DOMContentLoaded', function(){
  var mailIcon = document.getElementById('userMailIcon');
  if(mailIcon) mailIcon.addEventListener('keydown', function(e){ if(e.key==='Enter'||e.key===' '){ e.preventDefault(); openUserMessages(); } });
});

// ══════════════════════════════════════════════════════════════
// FEATURE: Print / Export
// ══════════════════════════════════════════════════════════════
// Print is handled by CSS @media print - no JS needed

// ══════════════════════════════════════════════════════════════
// INIT: Wire everything up on DOMContentLoaded
// ══════════════════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', function(){
  loadState();
  loadCustomRecipes();
  initCalorieTrendChart();
  updateCalorieTrend(); // sync existing mealLog into chart on load
  // Set date picker to today
  var picker = document.getElementById('diary-date-picker');
  if(picker) picker.value = new Date().toISOString().split('T')[0];
  // Update recipe hearts from loaded favourites
  document.querySelectorAll('.recipe-card').forEach(card=>{
    const id = card.dataset.recipeId;
    const heart = card.querySelector('.rc-fav');
    if(heart && id) heart.textContent = favourites.has(id) ? '❤️' : '🤍';
  });
  // Re-render compare if loaded from storage
  if(typeof renderComparePage === 'function') renderComparePage();
  if(typeof renderExerciseLog === 'function') renderExerciseLog();
  if(typeof updateExerciseChart === 'function') updateExerciseChart();
});

// Save state before leaving
window.addEventListener('beforeunload', saveState);
</script>


<script>
// ══════════════════════════════════════════════════════════════
// FEATURE: Ingredient Exclusion Filter (Funnel) + Search
// All filters work together: search + tag + checkbox + custom
// ══════════════════════════════════════════════════════════════

// Keyword→ingredient mappings: when user checks "dairy", match these words in ingredients
var ingredientKeywords = {
  'nuts': ['nuts','almond','almonds','walnut','walnuts','peanut','peanuts','cashew','cashews','pecan','pecans','pistachio','hazelnut'],
  'dairy': ['milk','cheese','feta','parmesan','cream','yogurt','yoghurt','butter','mozzarella','cheddar','ricotta'],
  'gluten': ['bread','pasta','penne','sourdough','flour','wheat','noodle','noodles','toast','spaghetti','couscous','tortilla','wrap'],
  'eggs': ['egg','eggs'],
  'fish': ['salmon','tuna','cod','fish','prawn','prawns','shrimp','anchovy','anchovies','mackerel','sardine','seafood'],
  'meat': ['chicken','beef','pork','lamb','turkey','bacon','sausage','ham','steak','mince'],
  'soy': ['soy','soya','tofu','edamame','tempeh','soy sauce']
};

// Custom exclusion words added by user
var customExclusions = [];

function toggleFilterDropdown(){
  var dd = document.getElementById('filterDropdown');
  var btn = document.getElementById('filterToggleBtn');
  var isOpen = dd.style.display !== 'none';
  dd.style.display = isOpen ? 'none' : 'block';
  btn.setAttribute('aria-expanded', !isOpen);
}

document.addEventListener('click', function(e){
  var wrap = document.querySelector('.filter-dropdown-wrap');
  if(wrap && !wrap.contains(e.target)){
    document.getElementById('filterDropdown').style.display = 'none';
    document.getElementById('filterToggleBtn').setAttribute('aria-expanded','false');
  }
});

// Check if a recipe's ingredients contain any excluded keyword
function recipeContainsExcluded(recipe, excludedWords){
  if(!recipe || !recipe.ingredients || excludedWords.length === 0) return false;
  var allIngredients = recipe.ingredients.join(' ').toLowerCase();
  // Also check steps for hidden ingredients
  var allSteps = (recipe.steps || []).join(' ').toLowerCase();
  var fullText = allIngredients + ' ' + allSteps;
  for(var i = 0; i < excludedWords.length; i++){
    if(fullText.indexOf(excludedWords[i]) !== -1) return true;
  }
  return false;
}

// Master filter: combines search + tag + checkbox exclusions + custom exclusions
function applyAllFilters(){
  // 1. Gather checkbox exclusions → expand to keyword lists
  var excludedWords = [];
  document.querySelectorAll('#filterCheckboxes input[type=checkbox]:checked').forEach(function(cb){
    var keywords = ingredientKeywords[cb.value] || [cb.value];
    keywords.forEach(function(kw){ if(excludedWords.indexOf(kw) === -1) excludedWords.push(kw); });
  });

  // 2. Add custom exclusions
  customExclusions.forEach(function(word){
    if(excludedWords.indexOf(word) === -1) excludedWords.push(word);
  });

  // 3. Get search term
  var searchInput = document.querySelector('.rs-input');
  var searchTerm = searchInput ? searchInput.value.toLowerCase().trim() : '';

  // 4. Get active tag filter
  var activeTag = 'all';
  var activeTagBtn = document.querySelector('.rf-tag.active');
  if(activeTagBtn) activeTag = activeTagBtn.textContent.toLowerCase().trim().replace(' ','-').replace('my-recipes','my-recipes');

  // 5. Update filter count badge
  var totalFilters = document.querySelectorAll('#filterCheckboxes input[type=checkbox]:checked').length + customExclusions.length;
  var countEl = document.getElementById('filterCount');
  if(totalFilters > 0){ countEl.textContent = totalFilters; countEl.style.display = 'inline'; }
  else { countEl.style.display = 'none'; }

  // 6. Apply to all cards
  document.querySelectorAll('.recipe-card').forEach(function(card){
    var id = card.dataset.recipeId;
    var recipe = RECIPES[id];
    if(!recipe){ card.style.display = 'none'; return; }

    var show = true;

    // Search filter
    if(searchTerm){
      var haystack = (recipe.name + ' ' + recipe.tag + ' ' + (recipe.ingredients||[]).join(' ')).toLowerCase();
      if(haystack.indexOf(searchTerm) === -1) show = false;
    }

    // Tag filter
    if(show && activeTag !== 'all'){
      if(activeTag === 'my-recipes'){ if(!recipe.custom) show = false; }
      else { if(!(recipe.tag||'').toLowerCase().replace('-',' ').includes(activeTag.replace('-',' '))) show = false; }
    }

    // Ingredient exclusion filter
    if(show && excludedWords.length > 0){
      if(recipeContainsExcluded(recipe, excludedWords)) show = false;
    }

    card.style.display = show ? '' : 'none';
  });
  // Keep fridge-mode sorting in sync with filter changes
  if (typeof applyFridgeSort === 'function') applyFridgeSort();
}

// Custom exclusion: add a tag
function addCustomExclusion(){
  var input = document.getElementById('customExcludeInput');
  var text = input.value.trim().toLowerCase();
  if(!text) return;
  // Support comma-separated
  text.split(',').forEach(function(word){
    word = word.trim();
    if(word && customExclusions.indexOf(word) === -1){
      customExclusions.push(word);
    }
  });
  input.value = '';
  renderCustomTags();
  applyAllFilters();
}

function removeCustomExclusion(word){
  customExclusions = customExclusions.filter(function(w){ return w !== word; });
  renderCustomTags();
  applyAllFilters();
}

function renderCustomTags(){
  var container = document.getElementById('customExcludeTags');
  container.innerHTML = customExclusions.map(function(word){
    return '<span style="display:inline-flex;align-items:center;gap:4px;padding:3px 8px 3px 10px;background:var(--paper);border:1px solid var(--border);border-radius:12px;font-family:\'JetBrains Mono\',monospace;font-size:10px;color:var(--ink-m)">'
      + word
      + '<span tabindex="0" role="button" onclick="removeCustomExclusion(\'' + word + '\')" style="cursor:pointer;color:var(--ink-f);font-size:13px;line-height:1;margin-left:2px" title="Remove">×</span>'
      + '</span>';
  }).join('');
}

function clearAllFilters(){
  document.querySelectorAll('#filterCheckboxes input[type=checkbox]').forEach(function(cb){ cb.checked = false; });
  customExclusions = [];
  renderCustomTags();
  var searchInput = document.querySelector('.rs-input');
  if(searchInput) searchInput.value = '';
  applyAllFilters();
}
</script>

<script>

/* ═════════════════════════════════════════════════════════════════
 * NOURISHWELL PATCH — Features & A11y (inline)
 * Safe to run: IIFE, no globals clobbered except intentional.
 * ═════════════════════════════════════════════════════════════════ */
(function () {
  'use strict';

  function escapeHtml(s) {
    if (s == null) return '';
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
  }
  window.escapeHtml = escapeHtml;

  // ── XSS FIX for comments ───────────────────────────────────────
  if (typeof window.renderComments === 'function') {
    window.renderComments = function (recipeId) {
      const comments = (window.recipeComments && window.recipeComments[recipeId]) || [];
      let html = '<div class="comment-section">' +
        '<div style="font-family:\'JetBrains Mono\',monospace;font-size:9px;color:var(--ink-f);letter-spacing:.08em;text-transform:uppercase;margin-bottom:8px">Comments (' + comments.length + ')</div>';
      comments.forEach(function (c) {
        html += '<div class="comment-item"><div class="comment-author">' + escapeHtml(c.author) + ' · ' + escapeHtml(c.time) + '</div><div class="comment-text">' + escapeHtml(c.text) + '</div></div>';
      });
      const safeId = escapeHtml(recipeId);
      html += '<div class="comment-input-wrap"><input type="text" id="comment-input-' + safeId + '" placeholder="Add a comment..." aria-label="Add comment" onkeydown="if(event.key===\'Enter\')addComment(\'' + safeId + '\')"><button onclick="addComment(\'' + safeId + '\')">Post</button></div></div>';
      return html;
    };
  }

  // ── INSIGHTS ───────────────────────────────────────────────────
  function computeTodayNutrition() {
    const kcalEl = document.querySelector('.dc-total-num');
    const values = { kcal: 1920, target: window._nwDailyTarget || 2400, carbs: 201, protein: 68, fat: 38, sugar: 84, carbsT: 300, proteinT: 120, fatT: 65, sugarT: 50 };
    if (kcalEl) {
      const m = kcalEl.textContent.replace(/,/g,'').match(/\d+/);
      if (m) values.kcal = parseInt(m[0], 10);
    }
    return values;
  }

  function generateInsights() {
    const n = computeTodayNutrition();
    const out = [];
    const proteinPct = (n.protein / n.proteinT) * 100;
    if (proteinPct < 60) {
      out.push({ type:'warn', icon:'💪', title:'Protein could be higher today', body:'You\'re at ' + n.protein + 'g of your ' + n.proteinT + 'g target. A 150g pot of Greek yoghurt (~17g) or 100g of chicken (~30g) would help close the gap.' });
    } else if (proteinPct >= 90) {
      out.push({ type:'good', icon:'✓', title:'Protein target smashed', body:'Great job hitting ' + n.protein + 'g protein — ideal for recovery and satiety.' });
    }
    if (n.sugar > n.sugarT * 1.3) {
      out.push({ type:'alert', icon:'🍬', title:'Sugar intake is above target', body:'At ' + n.sugar + 'g, you\'re over the recommended ' + n.sugarT + 'g/day. Try swapping one sugary drink for sparkling water with lemon tomorrow.' });
    } else if (n.sugar <= n.sugarT * 0.8) {
      out.push({ type:'good', icon:'✓', title:'Sugar well under target', body:'You\'re at ' + n.sugar + 'g — comfortably below the ' + n.sugarT + 'g daily max. Nice consistency.' });
    }
    const hr = new Date().getHours();
    const kcalPct = (n.kcal / n.target) * 100;
    if (hr >= 20 && kcalPct < 70) {
      out.push({ type:'warn', icon:'⏰', title:'You may be under-eating today', body:'At ' + n.kcal + ' kcal so far, you\'re well under target. A light evening snack with protein could help.' });
    } else if (hr <= 14 && kcalPct > 70) {
      out.push({ type:'warn', icon:'⏰', title:'Front-loaded intake', body:'You\'ve consumed ' + Math.round(kcalPct) + '% of today\'s target by lunch. Consider a lighter dinner.' });
    }
    try {
      const diary = JSON.parse(localStorage.getItem(_nwKey('diary-history')) || '{}');
      const days = Object.keys(diary).length;
      if (days >= 7 && days % 7 === 0) {
        out.push({ type:'good', icon:'🌟', title:days + '-day logging streak', body:'Consistency is the single best predictor of nutritional improvement. Keep going.' });
      }
    } catch (e) {}
    if (out.length === 0) {
      out.push({ type:'good', icon:'🌱', title:'Looking balanced today', body:'Your macros are in a healthy range. Small consistent choices add up.' });
    }
    return out.slice(0, 3);
  }

  function renderInsights() {
    const host = document.getElementById('insights-container');
    if (!host) return;
    const insights = generateInsights();
    host.innerHTML = insights.map(function (i) {
      return '<div class="insight-card ' + i.type + '" role="status"><div class="insight-title"><span class="insight-icon" aria-hidden="true">' + i.icon + '</span>' + escapeHtml(i.title) + '</div><div class="insight-body">' + escapeHtml(i.body) + '</div></div>';
    }).join('');
  }
  window.renderInsights = renderInsights;

  // ── FRIDGE MODE ────────────────────────────────────────────────
  const COMMON_INGREDIENTS = [
    { emoji:'🍅', name:'Tomato' }, { emoji:'🥚', name:'Eggs' }, { emoji:'🧄', name:'Garlic' }, { emoji:'🧅', name:'Onion' },
    { emoji:'🥑', name:'Avocado' }, { emoji:'🐟', name:'Salmon' }, { emoji:'🍗', name:'Chicken' }, { emoji:'🌾', name:'Quinoa' },
    { emoji:'🍚', name:'Rice' }, { emoji:'🍝', name:'Pasta' }, { emoji:'🥬', name:'Spinach' }, { emoji:'🧀', name:'Feta' }
  ];
  let fridgeSelected = new Set();
  try { const saved = localStorage.getItem('nw-fridge'); if (saved) JSON.parse(saved).forEach(function (x) { fridgeSelected.add(x); }); } catch (e) {}
  function saveFridge() { try { localStorage.setItem('nw-fridge', JSON.stringify([...fridgeSelected])); } catch (e) {} }

  function renderFridgePanel() {
    const host = document.getElementById('fridge-panel-host');
    if (!host) return;
    const chipsHtml = COMMON_INGREDIENTS.map(function (ing) {
      const isSel = fridgeSelected.has(ing.name.toLowerCase());
      return '<button type="button" class="fridge-chip ' + (isSel ? 'selected' : '') + '" data-ing="' + escapeHtml(ing.name.toLowerCase()) + '" aria-pressed="' + isSel + '"><span aria-hidden="true">' + ing.emoji + '</span> ' + escapeHtml(ing.name) + (isSel ? '<span class="chip-x" aria-hidden="true">×</span>' : '') + '</button>';
    }).join('');
    const customChips = [...fridgeSelected]
      .filter(function (x) { return !COMMON_INGREDIENTS.some(function (c) { return c.name.toLowerCase() === x; }); })
      .map(function (x) { return '<button type="button" class="fridge-chip selected" data-ing="' + escapeHtml(x) + '" aria-pressed="true">' + escapeHtml(x) + '<span class="chip-x" aria-hidden="true">×</span></button>'; }).join('');
    host.innerHTML =
      '<div class="fridge-panel">' +
        '<div class="fridge-title"><span aria-hidden="true">🧊</span> What\'s in your fridge?</div>' +
        '<div class="fridge-sub">Tap what you have — we\'ll rank recipes by how many you can make</div>' +
        '<div class="fridge-chips">' + chipsHtml + customChips + '</div>' +
        '<div class="fridge-input"><label for="fridge-custom-input" class="sr-only">Add a custom ingredient</label><input type="text" id="fridge-custom-input" placeholder="Add something else (e.g. mushrooms)"><button type="button" id="fridge-add-btn">Add</button></div>' +
      '</div>';

    host.querySelectorAll('.fridge-chip').forEach(function (chip) {
      chip.addEventListener('click', function () {
        const ing = chip.dataset.ing;
        if (fridgeSelected.has(ing)) fridgeSelected.delete(ing); else fridgeSelected.add(ing);
        saveFridge(); renderFridgePanel(); applyFridgeSort();
      });
    });
    const addBtn = document.getElementById('fridge-add-btn');
    const inputEl = document.getElementById('fridge-custom-input');
    function addCustom() {
      const val = (inputEl.value || '').trim().toLowerCase();
      if (!val) return;
      fridgeSelected.add(val); saveFridge(); inputEl.value = ''; renderFridgePanel(); applyFridgeSort();
    }
    addBtn.addEventListener('click', addCustom);
    inputEl.addEventListener('keydown', function (e) { if (e.key === 'Enter') { e.preventDefault(); addCustom(); } });
  }

  function applyFridgeSort() {
    if (!window.RECIPES) return;
    const grid = document.querySelector('.recipe-grid');
    if (!grid) return;
    const cards = Array.from(grid.querySelectorAll('.recipe-card'));
    const selected = [...fridgeSelected];
    const scored = cards.map(function (card) {
      const id = card.dataset.recipeId;
      const r = window.RECIPES[id];
      if (!r || !r.ingredients) return { card: card, score: 0, total: 0 };
      const ingText = r.ingredients.join(' ').toLowerCase();
      let matches = 0;
      selected.forEach(function (s) { if (ingText.includes(s)) matches++; });
      return { card: card, score: matches, total: selected.length };
    });
    cards.forEach(function (c) { const b = c.querySelector('.rc-match-badge'); if (b) b.remove(); });
    if (selected.length > 0) {
      scored.sort(function (a, b) { return b.score - a.score; });
      scored.forEach(function (s) {
        if (s.score > 0) {
          const badge = document.createElement('div');
          badge.className = 'rc-match-badge';
          badge.textContent = s.score + '/' + s.total + ' match';
          s.card.appendChild(badge);
        }
        grid.appendChild(s.card);
      });
    }
  }
  window.applyFridgeSort = applyFridgeSort;

  // ── COOKED TOGGLE ──────────────────────────────────────────────
  let cookedSet = new Set();
  try { const s = localStorage.getItem('nw-cooked'); if (s) JSON.parse(s).forEach(function (x) { cookedSet.add(x); }); } catch (e) {}
  function saveCooked() { try { localStorage.setItem('nw-cooked', JSON.stringify([...cookedSet])); } catch (e) {} }
  function augmentFavouriteCards() {
    document.querySelectorAll('.fav-card').forEach(function (card) {
      if (card.querySelector('.cooked-toggle')) return;
      const titleEl = card.querySelector('.fav-card-title');
      if (!titleEl) return;
      const id = (titleEl.textContent || '').toLowerCase().replace(/\s+/g, '-');
      const footer = card.querySelector('.fav-card-footer');
      if (!footer) return;
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'cooked-toggle' + (cookedSet.has(id) ? ' cooked' : '');
      btn.setAttribute('aria-pressed', cookedSet.has(id));
      btn.innerHTML = cookedSet.has(id) ? '<span aria-hidden="true">✓</span> Tried' : '<span aria-hidden="true">🍽️</span> Try soon';
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        if (cookedSet.has(id)) cookedSet.delete(id); else cookedSet.add(id);
        saveCooked(); btn.classList.toggle('cooked');
        const pressed = cookedSet.has(id);
        btn.setAttribute('aria-pressed', pressed);
        btn.innerHTML = pressed ? '<span aria-hidden="true">✓</span> Tried' : '<span aria-hidden="true">🍽️</span> Try soon';
      });
      const remove = footer.querySelector('.fav-remove');
      if (remove) footer.insertBefore(btn, remove); else footer.appendChild(btn);
    });
  }
  window.augmentFavouriteCards = augmentFavouriteCards;

  // ── COOKING MODE ───────────────────────────────────────────────
  function buildCookingModeScaffold() {
    if (document.getElementById('cookingMode')) return;
    const el = document.createElement('div');
    el.id = 'cookingMode';
    el.className = 'cooking-mode';
    el.setAttribute('role', 'dialog');
    el.setAttribute('aria-modal', 'true');
    el.setAttribute('aria-labelledby', 'cook-title');
    el.innerHTML =
      '<div class="cook-header"><div class="cook-title" id="cook-title"></div><button type="button" class="cook-close" aria-label="Exit cooking mode" id="cook-close">✕</button></div>' +
      '<div class="cook-body"><div class="cook-step"><div class="cook-step-counter" id="cook-counter"></div><div class="cook-step-text" id="cook-step-text"></div><div class="cook-ingredient-list" id="cook-ingredients" style="display:none"></div></div></div>' +
      '<div class="cook-footer"><button type="button" class="cook-nav-btn ghost" id="cook-prev">← Previous</button><div class="cook-progress"><div class="cook-progress-fill" id="cook-fill"></div></div><button type="button" class="cook-nav-btn" id="cook-next">Next →</button></div>';
    document.body.appendChild(el);
    document.getElementById('cook-close').addEventListener('click', closeCookingMode);
    document.getElementById('cook-prev').addEventListener('click', function () { cookNav(-1); });
    document.getElementById('cook-next').addEventListener('click', function () { cookNav(1); });
  }
  let cookState = { recipe: null, step: -1 };
  function openCookingMode(recipeId) {
    if (!window.RECIPES) return;
    const r = window.RECIPES[recipeId];
    if (!r) return;
    buildCookingModeScaffold();
    cookState.recipe = r; cookState.step = -1;
    renderCookStep();
    document.getElementById('cookingMode').classList.add('active');
    document.body.style.overflow = 'hidden';
    setTimeout(function () { document.getElementById('cook-close').focus(); }, 50);
  }
  window.openCookingMode = openCookingMode;
  function closeCookingMode() {
    const el = document.getElementById('cookingMode'); if (el) el.classList.remove('active');
    document.body.style.overflow = ''; cookState = { recipe: null, step: -1 };
  }
  window.closeCookingMode = closeCookingMode;
  function cookNav(dir) {
    if (!cookState.recipe) return;
    const steps = cookState.recipe.steps || [];
    cookState.step = Math.max(-1, Math.min(steps.length - 1, cookState.step + dir));
    renderCookStep();
  }
  function renderCookStep() {
    const r = cookState.recipe; if (!r) return;
    document.getElementById('cook-title').textContent = r.name;
    const steps = r.steps || [];
    const total = steps.length + 1;
    const idx = cookState.step + 1;
    const counter = document.getElementById('cook-counter');
    const text = document.getElementById('cook-step-text');
    const ing = document.getElementById('cook-ingredients');
    const fill = document.getElementById('cook-fill');
    const prevBtn = document.getElementById('cook-prev');
    const nextBtn = document.getElementById('cook-next');
    if (cookState.step === -1) {
      counter.textContent = 'Ingredients';
      text.textContent = 'Gather your ingredients';
      ing.style.display = 'block';
      ing.innerHTML = (r.ingredients || []).map(function (i) { return '<div>• ' + escapeHtml(i) + '</div>'; }).join('');
    } else {
      counter.textContent = 'Step ' + (cookState.step + 1) + ' of ' + steps.length;
      text.textContent = steps[cookState.step];
      ing.style.display = 'none';
    }
    fill.style.width = ((idx + 1) / total * 100) + '%';
    prevBtn.disabled = cookState.step === -1;
    nextBtn.disabled = cookState.step === steps.length - 1;
    nextBtn.textContent = cookState.step === steps.length - 1 ? '✓ Done' : 'Next →';
  }

  // ── KEYBOARD SHORTCUTS ─────────────────────────────────────────
  let gPressed = false;
  document.addEventListener('keydown', function (e) {
    const tag = (e.target.tagName || '').toLowerCase();
    const isTyping = tag === 'input' || tag === 'textarea' || e.target.isContentEditable;
    if (isTyping && e.key !== 'Escape') return;
    if (e.key === 'Escape') {
      if (document.getElementById('cookingMode') && document.getElementById('cookingMode').classList.contains('active')) closeCookingMode();
      const so = document.getElementById('shortcutsHelp'); if (so && so.classList.contains('open')) so.classList.remove('open');
      return;
    }
    const cm = document.getElementById('cookingMode');
    if (cm && cm.classList.contains('active')) {
      if (e.key === 'ArrowRight') { e.preventDefault(); cookNav(1); return; }
      if (e.key === 'ArrowLeft')  { e.preventDefault(); cookNav(-1); return; }
    }
    if (e.key === '?' && e.shiftKey) { e.preventDefault(); toggleShortcutHelp(true); return; }
    if (e.key === '/') {
      const search = document.querySelector('.rs-input') || document.querySelector('.qa-search-input');
      if (search) { e.preventDefault(); search.focus(); return; }
    }
    if (e.key === 'g' && !e.metaKey && !e.ctrlKey) { gPressed = true; setTimeout(function () { gPressed = false; }, 800); return; }
    if (gPressed) {
      gPressed = false;
      const mapping = { r:'record', f:'favourites', p:'planner', c:'plan', s:'recipe' };
      const target = mapping[e.key];
      if (target && typeof window.switchPage === 'function') {
        const navBtn = Array.from(document.querySelectorAll('.sn-item')).find(function (el) { return (el.getAttribute('onclick') || '').includes("'" + target + "'"); });
        if (navBtn) window.switchPage(target, navBtn);
      }
    }
  });

  function toggleShortcutHelp(show) {
    let el = document.getElementById('shortcutsHelp');
    if (!el) {
      el = document.createElement('div');
      el.id = 'shortcutsHelp';
      el.className = 'shortcuts-overlay';
      el.setAttribute('role', 'dialog');
      el.setAttribute('aria-modal', 'true');
      el.setAttribute('aria-labelledby', 'shortcuts-title');
      function row(label, keys) { return '<div class="shortcut-row"><span>' + label + '</span><span class="shortcut-keys">' + keys.map(function (k) { return '<span class="shortcut-key">' + escapeHtml(k) + '</span>'; }).join('') + '</span></div>'; }
      el.innerHTML = '<div class="shortcuts-modal"><div id="shortcuts-title" style="font-family:\'Instrument Serif\',serif;font-size:22px;font-style:italic;margin-bottom:16px;color:var(--ink)">Keyboard <em>Shortcuts</em></div>' +
        row('Focus search', ['/']) +
        row('Go to Record Today', ['g','r']) +
        row('Go to Recipes', ['g','s']) +
        row('Go to Favourites', ['g','f']) +
        row('Go to Compare', ['g','c']) +
        row('Go to Meal Planner', ['g','p']) +
        row('Next / previous step in cooking mode', ['←','→']) +
        row('Close / dismiss', ['Esc']) +
        row('Show this help', ['?']) +
      '</div>';
      el.addEventListener('click', function (e) { if (e.target === el) el.classList.remove('open'); });
      document.body.appendChild(el);
    }
    el.classList.toggle('open', show);
  }
  window.toggleShortcutHelp = toggleShortcutHelp;

  // ── EXPORT CSV ─────────────────────────────────────────────────
  function exportWeeklyReportCSV() {
    let history = {};
    try { history = JSON.parse(localStorage.getItem(_nwKey('diary-history')) || '{}'); } catch (e) {}
    const rows = [['Date','Calories','Protein (g)','Carbs (g)','Fat (g)','Sugar (g)']];
    for (let i = 6; i >= 0; i--) {
      const d = new Date(); d.setDate(d.getDate() - i);
      const key = d.toISOString().split('T')[0];
      const day = history[key] || {};
      rows.push([key, day.kcal || '', day.protein || '', day.carbs || '', day.fat || '', day.sugar || '']);
    }
    const csv = rows.map(function (r) {
      return r.map(function (cell) { const s = String(cell); return /[",\n]/.test(s) ? '"' + s.replace(/"/g, '""') + '"' : s; }).join(',');
    }).join('\n');
    const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = 'nourishwell-weekly-report-' + new Date().toISOString().split('T')[0] + '.csv';
    document.body.appendChild(link); link.click(); document.body.removeChild(link); URL.revokeObjectURL(url);
  }
  window.exportWeeklyReportCSV = exportWeeklyReportCSV;

  // ── UNIVERSAL KEYBOARD HANDLER for role="button" ───────────────
  document.addEventListener('keydown', function (e) {
    if (e.key !== 'Enter' && e.key !== ' ') return;
    const t = e.target; if (!t) return;
    const isRoleBtn = t.getAttribute && t.getAttribute('role') === 'button';
    const hasTabindex = t.hasAttribute && t.hasAttribute('tabindex');
    if (isRoleBtn && hasTabindex && t.tagName.toLowerCase() !== 'button') { e.preventDefault(); t.click(); }
  });

  // ── AUTO-MARK DECORATIVE EMOJIS aria-hidden ────────────────────
  const EMOJI_RE = /[\u{1F300}-\u{1FAFF}\u{2600}-\u{27BF}\u{1F000}-\u{1F02F}]/u;
  function markDecorativeEmojis(root) {
    root = root || document.body;
    const walker = document.createTreeWalker(root, NodeFilter.SHOW_ELEMENT, null);
    let node;
    while ((node = walker.nextNode())) {
      if (!node || !node.textContent) continue;
      if (node.hasAttribute && node.hasAttribute('aria-hidden')) continue;
      const raw = node.textContent.trim(); if (!raw) continue;
      const onlyEmoji = EMOJI_RE.test(raw) && raw.length <= 4 && !/[a-zA-Z0-9]/.test(raw);
      const tag = node.tagName.toLowerCase();
      if (onlyEmoji && (tag === 'span' || tag === 'div' || tag === 'i') && node.children.length === 0) {
        const parent = node.parentElement;
        if (parent) {
          const parentText = parent.textContent.trim();
          if (parentText.length > raw.length || parent.getAttribute('aria-label')) {
            node.setAttribute('aria-hidden', 'true');
          }
        }
      }
    }
  }
  window.markDecorativeEmojis = markDecorativeEmojis;

  // ── ARIA-LIVE ──────────────────────────────────────────────────
  function ensureLiveRegion() {
    if (document.getElementById('nw-live-region')) return;
    const live = document.createElement('div');
    live.id = 'nw-live-region'; live.className = 'sr-only';
    live.setAttribute('role', 'status'); live.setAttribute('aria-live', 'polite'); live.setAttribute('aria-atomic', 'true');
    document.body.appendChild(live);
  }
  function announce(text) {
    ensureLiveRegion();
    const live = document.getElementById('nw-live-region');
    live.textContent = ''; setTimeout(function () { live.textContent = text; }, 50);
  }
  window.announce = announce;

  if (typeof window.switchPage === 'function') {
    const origSwitchPage = window.switchPage;
    window.switchPage = function (p, el) {
      origSwitchPage(p, el);
      const titles = { record:'Record Today', recipe:'Discover Recipes', favourites:'My Favourites', plan:'Recipe Compare', planner:'Meal Planner' };
      announce('Navigated to ' + (titles[p] || p));
      if (p === 'favourites') augmentFavouriteCards();
      if (p === 'record') renderInsights();
      if (p === 'recipe') { renderFridgePanel(); applyFridgeSort(); }
    };
  }

  function init() {
    ensureLiveRegion();
    markDecorativeEmojis();
    renderInsights();
    renderFridgePanel();
    augmentFavouriteCards();
    const mo = new MutationObserver(function () { markDecorativeEmojis(); });
    mo.observe(document.body, { childList: true, subtree: true });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
})();

</script>
<script>
// ═══════════════════════════════════════════════════════════════
// MEAL PLANNER ENGINE v2 — empty start + favourites + smart fill
// ═══════════════════════════════════════════════════════════════
(function(){
  function getTargetKcal() { return window._nwDailyTarget || 2400; }
  var TARGET_KCAL = getTargetKcal();
  var mpFillMode = 'balanced'; // 'light' = ~50%, 'balanced' = ~75%, 'full' = 100%
  var mpPlan = { breakfast:[], lunch:[], dinner:[] };
  var mpLocked = new Set();
  var mpPickerMeal = '';

  // Load saved plan
  try {
    var saved = localStorage.getItem(_nwKey('meal-plan-v2'));
    if (saved) {
      var parsed = JSON.parse(saved);
      mpPlan = parsed.plan || mpPlan;
      mpLocked = new Set(parsed.locked || []);
    }
  } catch(e){}

  function mpSave(){
    try { localStorage.setItem(_nwKey('meal-plan-v2'), JSON.stringify({ plan:mpPlan, locked:[...mpLocked] })); } catch(e){}
  }

  function mpGetRecipes(){
    if (!window.RECIPES) return [];
    return Object.values(window.RECIPES);
  }

  function mpGetFavourites(){
    // Get favourite recipe IDs from the global favourites Set
    if (!window.favourites) return [];
    return [...window.favourites];
  }

  function mpGetAllUsedIds(){
    var ids = [];
    ['breakfast','lunch','dinner'].forEach(function(m){
      mpPlan[m].forEach(function(item){ ids.push(item.id); });
    });
    return ids;
  }

  function mpCalcTotals(){
    var t = { kcal:0, protein:0, carbs:0, fat:0, items:0 };
    var recipes = mpGetRecipes();
    ['breakfast','lunch','dinner'].forEach(function(m){
      mpPlan[m].forEach(function(item){
        var r = recipes.find(function(x){ return x.id === item.id; });
        if (r) { t.kcal += r.kcal||0; t.items++; }
      });
    });
    t.protein = Math.round(t.kcal * 0.047);
    t.carbs = Math.round(t.kcal * 0.066);
    t.fat = Math.round(t.kcal * 0.024);
    return t;
  }

  function mpCalcMealKcal(meal){
    var total = 0;
    var recipes = mpGetRecipes();
    mpPlan[meal].forEach(function(item){
      var r = recipes.find(function(x){ return x.id === item.id; });
      if (r) total += r.kcal||0;
    });
    return total;
  }

  // ── Smart Fill Algorithm ──
  // Greedy knapsack: fill meals until we reach the target percentage
  window.mpSetFillMode = function(btn, mode){
    document.getElementById('mp-fill-mode').querySelectorAll('.sp-cat').forEach(function(b){ b.classList.remove('active'); });
    btn.classList.add('active');
    mpFillMode = mode;
  };

  window.mpAutoFill = function(){
    var targetPct = mpFillMode === 'light' ? 0.5 : mpFillMode === 'balanced' ? 0.75 : 1.0;
    var targetKcal = Math.round(TARGET_KCAL * targetPct);
    var currentKcal = mpCalcTotals().kcal;
    var remaining = targetKcal - currentKcal;

    if (remaining <= 0) {
      if (typeof showToast === 'function') showToast('Already at or above ' + Math.round(targetPct*100) + '% target', '#b8621f');
      return;
    }

    var used = mpGetAllUsedIds();
    var pool = mpGetRecipes().filter(function(r){ return used.indexOf(r.id) === -1; });
    // Sort by kcal ascending for better packing
    pool.sort(function(a,b){ return (a.kcal||0) - (b.kcal||0); });

    var added = 0;
    var meals = ['breakfast','lunch','dinner'];
    var mealIdx = 0;

    // Distribute evenly across meals that have fewer items
    while (remaining > 0 && pool.length > 0) {
      // Find the meal with least items
      var targetMeal = meals[0];
      var minItems = mpPlan[meals[0]].length;
      meals.forEach(function(m){
        if (mpPlan[m].length < minItems) { minItems = mpPlan[m].length; targetMeal = m; }
      });

      // Find best fitting recipe (closest to remaining / meals-needing-fill)
      var perMealTarget = remaining / Math.max(1, meals.filter(function(m){ return mpPlan[m].length <= minItems; }).length);
      var bestIdx = -1;
      var bestDiff = Infinity;
      for (var i = 0; i < pool.length; i++) {
        var diff = Math.abs((pool[i].kcal||0) - perMealTarget);
        if ((pool[i].kcal||0) <= remaining && diff < bestDiff) {
          bestDiff = diff;
          bestIdx = i;
        }
      }
      if (bestIdx === -1) break; // No recipe fits

      mpPlan[targetMeal].push({ id: pool[bestIdx].id });
      remaining -= (pool[bestIdx].kcal||0);
      pool.splice(bestIdx, 1);
      added++;
    }

    mpSave();
    mpRenderAll();
    if (typeof showToast === 'function') showToast('Added ' + added + ' recipe' + (added!==1?'s':'') + ' to reach ~' + Math.round(targetPct*100) + '% target', '#1e6b5e');
  };

  window.mpClearAll = function(){
    mpPlan = { breakfast:[], lunch:[], dinner:[] };
    mpLocked = new Set();
    mpSave();
    mpRenderAll();
    if (typeof showToast === 'function') showToast('Plan cleared', '#b8621f');
  };

  // ── Render ──
  function mpRenderCard(item, meal){
    var recipes = mpGetRecipes();
    var r = recipes.find(function(x){ return x.id === item.id; });
    if (!r) return '';
    var locked = mpLocked.has(meal+':'+item.id);
    var cls = locked ? 'mp-card locked' : 'mp-card suggested';
    var bg = r.bg || 'var(--teal-lll)';
    var badge = locked
      ? '<div class="mp-badge" style="background:var(--teal)">🔒</div>'
      : '';
    var timeStr = (r.tag||'').split('\u00b7')[1] || (r.tag||'').split('·')[1] || '';
    return '<div class="'+cls+'">' +
      '<div class="mp-card-img" style="background:'+bg+'">'+r.emoji+badge+'</div>' +
      '<div class="mp-card-body">' +
        '<div class="mp-card-name">'+(typeof escapeHtml==='function'?escapeHtml(r.name):r.name)+'</div>' +
        '<div class="mp-card-meta">'+(r.kcal||0)+' kcal'+(timeStr?' · '+timeStr.trim():'')+'</div>' +
        '<div class="mp-card-actions">' +
          '<span style="color:var(--ink-f)" onclick="mpRemoveItem(\''+meal+'\',\''+item.id+'\')">✕ Remove</span>' +
          (locked
            ? '<span style="color:var(--amber)" onclick="mpUnlock(\''+meal+'\',\''+item.id+'\')">🔓 Unlock</span>'
            : '<span style="color:var(--teal)" onclick="mpLockItem(\''+meal+'\',\''+item.id+'\')">🔒 Lock</span>') +
          ' <span style="color:var(--amber)" onclick="mpSwapItem(\''+meal+'\',\''+item.id+'\')">🔄</span>' +
        '</div>' +
      '</div></div>';
  }

  function mpRenderMeal(meal, icon, label){
    var host = document.getElementById('mp-'+meal);
    if (!host) return;
    var mealKcal = mpCalcMealKcal(meal);
    var cards = mpPlan[meal].map(function(item){ return mpRenderCard(item, meal); }).join('');

    // Add button — always show
    cards += '<div class="mp-add-card" onclick="mpOpenPicker(\''+meal+'\')"><span style="font-size:24px;margin-bottom:6px">+</span><span style="font-size:10px;font-weight:600">Add from favourites</span></div>';

    // Empty state if no items
    var emptyHint = mpPlan[meal].length === 0
      ? '<div style="font-family:\'JetBrains Mono\',monospace;font-size:9px;color:var(--ink-f);font-style:italic;margin-top:8px">No items yet — add from your favourites or use Smart Fill</div>'
      : '';

    host.innerHTML =
      '<div class="mp-meal-header">' +
        '<div class="mp-meal-title"><span aria-hidden="true">'+icon+'</span><span class="mp-name">'+label+'</span><span class="mp-kcal">'+mealKcal+' kcal</span></div>' +
        (mpPlan[meal].length > 0 ? '<button class="mp-refresh" onclick="mpRefreshMeal(\''+meal+'\')">🔄 Refresh unlocked</button>' : '') +
      '</div>' +
      '<div class="mp-cards">'+cards+'</div>' +
      emptyHint;
  }

  function mpRenderAll(){
    TARGET_KCAL = getTargetKcal();
    mpRenderMeal('breakfast','🌅','Breakfast');
    mpRenderMeal('lunch','☀️','Lunch');
    mpRenderMeal('dinner','🌙','Dinner');
    mpRenderSummary();
    mpRenderBudget();
  }

  function mpRenderSummary(){
    var t = mpCalcTotals();
    var withinBudget = t.kcal <= TARGET_KCAL;
    var statusHtml = t.items === 0
      ? '<div style="font-family:\'JetBrains Mono\',monospace;font-size:8px;padding:5px 12px;border-radius:6px;background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.4)">No items yet</div>'
      : withinBudget
        ? '<div style="font-family:\'JetBrains Mono\',monospace;font-size:8px;padding:5px 12px;border-radius:6px;background:rgba(47,143,127,0.15);color:var(--teal-l)">✓ Within budget</div>'
        : '<div style="font-family:\'JetBrains Mono\',monospace;font-size:8px;padding:5px 12px;border-radius:6px;background:rgba(224,123,120,0.15);color:#b5413e">⚠ Over budget</div>';

    document.getElementById('mp-summary').innerHTML =
      '<div style="display:flex;align-items:center;gap:20px;flex-wrap:wrap">' +
        mpStat('Planned', t.kcal+' <span style=\"font-size:11px;color:rgba(255,255,255,0.3)\">kcal</span>', '#fff', true) +
        mpDiv() +
        mpStat('Protein', t.protein+'g', 'var(--teal-l)', false) +
        mpDiv() +
        mpStat('Carbs', t.carbs+'g', 'var(--amber-l)', false) +
        mpDiv() +
        mpStat('Fat', t.fat+'g', 'var(--blue)', false) +
        mpDiv() +
        mpStat('Items', t.items+' recipes', '#fff', false) +
      '</div>' +
      '<div style="display:flex;align-items:center;gap:10px">' +
        statusHtml +
        '<button onclick="mpConfirm()" '+(t.items===0?'disabled style="padding:10px 22px;background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.3);border:none;border-radius:8px;font-family:\'Bricolage Grotesque\',sans-serif;font-size:12px;font-weight:600;cursor:not-allowed"':'style="padding:10px 22px;background:var(--teal);color:#fff;border:none;border-radius:8px;font-family:\'Bricolage Grotesque\',sans-serif;font-size:12px;font-weight:600;cursor:pointer;transition:background .2s"')+'>Confirm plan →</button>' +
      '</div>';
  }

  function mpStat(label, value, color, big){
    return '<div><div style="font-family:\'JetBrains Mono\',monospace;font-size:8px;color:rgba(255,255,255,0.35);letter-spacing:.08em;text-transform:uppercase;margin-bottom:3px">'+label+'</div><div style="font-size:'+(big?'18':'14')+'px;font-weight:700;color:'+color+'">'+value+'</div></div>';
  }
  function mpDiv(){ return '<div style="width:1px;height:30px;background:rgba(255,255,255,0.08)"></div>'; }

  function mpRenderBudget(){
    var t = mpCalcTotals();
    var remaining = TARGET_KCAL - t.kcal;
    var pct = Math.min(100, Math.round((t.kcal / TARGET_KCAL) * 100));
    document.getElementById('mp-budget-text').innerHTML = t.kcal.toLocaleString()+' used · <span style="color:'+(remaining>=0?'var(--teal)':'#e07b78')+';font-weight:600">'+Math.abs(remaining)+' '+(remaining>=0?'remaining':'over')+'</span>';
    document.getElementById('mp-budget-bar').style.width = pct+'%';
    document.getElementById('mp-budget-bar').style.background = remaining >= 0 ? 'linear-gradient(90deg,var(--teal),var(--teal-l))' : 'linear-gradient(90deg,#e07b78,#c0392b)';
  }

  // ── Actions ──
  window.mpRemoveItem = function(meal, id){
    mpPlan[meal] = mpPlan[meal].filter(function(x){ return x.id !== id; });
    mpLocked.delete(meal+':'+id);
    mpSave(); mpRenderAll();
  };
  window.mpLockItem = function(meal, id){
    mpLocked.add(meal+':'+id);
    mpSave(); mpRenderAll();
    if(typeof showToast==='function') showToast('Locked — won\'t change on refresh','#1e6b5e');
  };
  window.mpUnlock = function(meal, id){
    mpLocked.delete(meal+':'+id);
    mpSave(); mpRenderAll();
  };
  window.mpSwapItem = function(meal, id){
    var used = mpGetAllUsedIds();
    var pool = mpGetRecipes().filter(function(r){ return used.indexOf(r.id) === -1; });
    if (pool.length === 0) { if(typeof showToast==='function') showToast('No more recipes to swap with','#b8621f'); return; }
    var pick = pool[Math.floor(Math.random() * pool.length)];
    var idx = mpPlan[meal].findIndex(function(x){ return x.id === id; });
    if (idx !== -1) {
      mpLocked.delete(meal+':'+id);
      mpPlan[meal][idx] = { id: pick.id };
    }
    mpSave(); mpRenderAll();
  };
  window.mpRefreshMeal = function(meal){
    var keep = [];
    var unlocked = [];
    mpPlan[meal].forEach(function(item){
      if (mpLocked.has(meal+':'+item.id)) keep.push(item);
      else unlocked.push(item);
    });
    var used = mpGetAllUsedIds().filter(function(id){
      return !unlocked.some(function(u){ return u.id === id; });
    });
    var pool = mpGetRecipes().filter(function(r){ return used.indexOf(r.id) === -1; });
    var picks = [];
    for (var i = 0; i < unlocked.length && pool.length > 0; i++){
      var idx = Math.floor(Math.random() * pool.length);
      picks.push({ id: pool[idx].id });
      pool.splice(idx, 1);
    }
    mpPlan[meal] = keep.concat(picks);
    mpSave(); mpRenderAll();
  };
  window.mpConfirm = function(){
    if (mpCalcTotals().items === 0) return;
    mpSave();
    if(typeof showToast==='function') showToast('Plan confirmed! ✓','#1e6b5e');
  };

  // ── Picker (shows favourites first, then all recipes) ──
  window.mpOpenPicker = function(meal){
    mpPickerMeal = meal;
    document.getElementById('mp-picker-meal').textContent = meal.charAt(0).toUpperCase()+meal.slice(1);
    document.getElementById('mp-picker-search').value = '';
    mpFilterPicker('');
    document.getElementById('mp-picker-overlay').style.display = 'flex';
  };
  window.mpClosePicker = function(){
    document.getElementById('mp-picker-overlay').style.display = 'none';
  };
  window.mpFilterPicker = function(q){
    var recipes = mpGetRecipes();
    var favIds = mpGetFavourites();
    var used = mpGetAllUsedIds();
    var term = q.toLowerCase().trim();

    // Split into favourites and others
    var favRecipes = [];
    var otherRecipes = [];
    recipes.forEach(function(r){
      if (used.indexOf(r.id) !== -1) return;
      if (term && (r.name||'').toLowerCase().indexOf(term) === -1) return;
      if (favIds.indexOf(r.id) !== -1) favRecipes.push(r);
      else otherRecipes.push(r);
    });

    var list = document.getElementById('mp-picker-list');
    var html = '';

    if (favRecipes.length > 0) {
      html += '<div style="font-family:\'JetBrains Mono\',monospace;font-size:9px;color:var(--teal);letter-spacing:.08em;text-transform:uppercase;padding:12px 0 6px;border-bottom:1px solid var(--fog)">❤️ Your favourites</div>';
      favRecipes.forEach(function(r){ html += mpPickerRow(r); });
    }

    if (otherRecipes.length > 0) {
      html += '<div style="font-family:\'JetBrains Mono\',monospace;font-size:9px;color:var(--ink-f);letter-spacing:.08em;text-transform:uppercase;padding:12px 0 6px;border-bottom:1px solid var(--fog);margin-top:8px">All recipes</div>';
      otherRecipes.forEach(function(r){ html += mpPickerRow(r); });
    }

    if (!html) html = '<div style="text-align:center;padding:40px 0;color:var(--ink-f);font-size:13px">No recipes available — all already added</div>';
    list.innerHTML = html;
  };

  function mpPickerRow(r){
    return '<div class="mp-picker-item" onclick="mpPickRecipe(\''+r.id+'\')">'+
      '<div style="width:44px;height:44px;border-radius:12px;background:'+(r.bg||'var(--teal-lll)')+';display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0">'+r.emoji+'</div>'+
      '<div style="flex:1"><div style="font-size:13px;font-weight:700;color:var(--ink)">'+(typeof escapeHtml==='function'?escapeHtml(r.name):r.name)+'</div><div style="font-family:\'JetBrains Mono\',monospace;font-size:10px;color:var(--ink-f);margin-top:2px">'+(r.kcal||0)+' kcal · '+(r.tag||'')+'</div></div>'+
    '</div>';
  }

  window.mpPickRecipe = function(id){
    mpPlan[mpPickerMeal].push({ id: id });
    mpSave(); mpRenderAll(); mpClosePicker();
    if(typeof showToast==='function') showToast('Added to '+mpPickerMeal,'#1e6b5e');
  };

  // ── Init: empty start ──
  function mpInit(){
    if (mpGetRecipes().length === 0) return;
    mpRenderAll();
  }

  var origSwitch = window.switchPage;
  if (origSwitch) {
    window.switchPage = function(p, el){
      origSwitch(p, el);
      if (p === 'planner') mpInit();
    };
  }
  setTimeout(mpInit, 200);
})();

</script>
<script>document.body.style.opacity='0';</script>
<script src="community-hub.js"></script>
<script src="api.js"></script>
<script src="patch_dashboard.js"></script>
<script src="welcome-modal.js"></script>
<script src="nw-tour.js"></script>

<script>
// ══════════════════════════════════════════════════════════════
// NourishWell — My Nutritionist Page
// Reads bound expert from localStorage (written by community-hub.js)
// and accepted status from nw-bind-requests
// ══════════════════════════════════════════════════════════════
(function() {

var EXPERTS_INFO = {
  "dr-rivera": { name:"Dr. Ana Rivera", title:"Registered Dietitian", specialty:"Weight Management & Sports Nutrition", avatar:"DR", color:"#2f8f7f", bio:"PhD in Clinical Nutrition · 12 years experience · University of Leeds" },
  "dr-chen":   { name:"Dr. James Chen", title:"Clinical Nutritionist", specialty:"Gut Health & Metabolic Disorders", avatar:"JC", color:"#7aaad4", bio:"MSc Nutritional Medicine · 8 years experience · NHS Registered" },
  "sarah-k":   { name:"Sarah Kowalski", title:"Nutrition Coach", specialty:"Plant-Based & Lifestyle Nutrition", avatar:"SK", color:"#d4956a", bio:"BSc Dietetics · 5 years experience · Certified Health Coach" },
  "dr-patel":  { name:"Dr. Priya Patel", title:"Endocrinology & Nutrition", specialty:"Diabetes & Hormonal Health", avatar:"PP", color:"#e07b78", bio:"MD Endocrinology · 15 years experience · NICE Advisor" },
  "marcus-j":  { name:"Marcus Johnson", title:"Performance Nutritionist", specialty:"Athletic Performance & Recovery", avatar:"MJ", color:"#7c3aed", bio:"MSc Sports Science · 7 years experience · Team GB Consultant" }
};

// Demo messages from pro (shown when bound + accepted)
var DEMO_MESSAGES = [
  { from:"pro", text:"Hi! I have reviewed your food diary from this week. Your protein intake is consistently below target — let us work on that together.", time:"Today, 09:14" },
  { from:"pro", text:"I have scheduled a check-in for next Monday at 10am. Does that work for you? I will send a confirmation shortly.", time:"Yesterday, 17:32" },
  { from:"user", text:"That works perfectly, thank you! Should I keep logging everything in the app beforehand?", time:"Yesterday, 18:05" },
  { from:"pro", text:"Yes please — the more detail the better. Focus especially on meal timing and portion sizes. See you Monday!", time:"Yesterday, 18:41" }
];

var DEMO_APPTS = [
  { date:"Mon 28 Apr", time:"10:00 AM", type:"Check-in Review", status:"confirmed" },
  { date:"Mon 12 May", time:"10:00 AM", type:"Monthly Assessment", status:"pending" }
];

// Real messages from API (replaces DEMO_MESSAGES when API is available)
var _myProMessages = DEMO_MESSAGES.slice(); // start with demo, replaced by API data
var _myProMsgsLoaded = false;
var _myProAppts = DEMO_APPTS.slice();
var _myProActiveTab = "messages";
var _myProPlansLoaded = false;
var _myProPlanMeals = ['','','','','','',''];
var _myProPlanTraining = ['','','','','','',''];
var _myProPlanTargetKcal = null;
var _myProPlanTargetProtein = null;
var _myProPlanNotes = null;

/** Switch tab in My Nutritionist page */
window._myProSwitchTab = function(tab) {
  _myProActiveTab = tab;
  renderMyPro();
};

/** Load fitness/meal plans from backend API */
async function _loadProPlans() {
  if (typeof NW === "undefined" || !NW.plans || !NW.auth || !NW.auth.userId) return;
  try {
    var plans = await NW.plans.get(NW.auth.userId);
    if (Array.isArray(plans)) {
      plans.forEach(function(p) {
        try {
          var days = JSON.parse(p.daysJson || "[]");
          if (p.planType === "meal") {
            _myProPlanMeals = days.length === 7 ? days : ['','','','','','',''];
            if (p.targetKcal) _myProPlanTargetKcal = p.targetKcal;
            if (p.targetProtein) _myProPlanTargetProtein = p.targetProtein;
            if (p.notes) _myProPlanNotes = p.notes;
          } else if (p.planType === "training") {
            _myProPlanTraining = days.length === 7 ? days : ['','','','','','',''];
          }
        } catch(e) {}
      });
      renderMyPro();
    }
  } catch(e) {
    console.warn("[NW] load plans failed:", e.message);
  }
}

/** Resolve the pro's backend userId from localStorage or the session cache. */
function _getProUserId(boundProId) {
  try {
    var reqs = JSON.parse(localStorage.getItem("nw-bind-requests") || "[]");
    var myReq = reqs.find(function(r){ return r.proId === boundProId; });
    if (myReq && myReq.proUserId) return myReq.proUserId;
  } catch(e){}
  // Fall back to the value confirmed by the last successful /api/auth/me call
  return _cachedBackendProId || null;
}

/** Load messages from API between current user and their pro */
async function _loadProMessages(boundProId) {
  if (typeof NW === "undefined" || !NW.messages) return;
  var proUserId = _getProUserId(boundProId);
  if (!proUserId) return;

  try {
    var msgs = await NW.messages.get(proUserId);
    if (Array.isArray(msgs) && msgs.length > 0) {
      var myId = NW.auth.userId ? String(NW.auth.userId) : "";
      _myProMessages = msgs.map(function(m) {
        return {
          from: String(m.senderId) === myId ? "user" : "pro",
          text: m.text,
          time: m.createdAt ? new Date(m.createdAt).toLocaleString([], {month:"short",day:"numeric",hour:"2-digit",minute:"2-digit"}) : ""
        };
      });
      renderMyPro();
    }
  } catch(e) {
    console.warn("[NW] load pro messages failed:", e.message);
    // Keep demo messages as fallback
  }

  // Also load appointments
  try {
    var appts = await NW.appointments.getAll();
    if (Array.isArray(appts) && appts.length > 0) {
      var myAppts = appts.filter(function(a) { return String(a.clientId) === String(NW.auth.userId) || String(a.proId) === proUserId; });
      if (myAppts.length > 0) {
        _myProAppts = myAppts.map(function(a) {
          var d = a.date ? new Date(a.date) : new Date();
          var dateStr = ["Sun","Mon","Tue","Wed","Thu","Fri","Sat"][d.getDay()] + " " + d.getDate() + " " + ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"][d.getMonth()];
          return { date: dateStr, time: a.time || "", type: a.type || "Check-in", status: a.status || "pending" };
        });
        renderMyPro();
      }
    }
  } catch(e) {}
}

function getUserId() {
  try { var s = sessionStorage.getItem("nw-session"); return s ? JSON.parse(s).userId : "guest"; } catch(e) { return "guest"; }
}

function getBoundExpert() {
  try {
    // Must match community-hub.js _key() logic exactly:
    // NW.auth.userId exists → "nw-{userId}-community-bound-expert"
    // NW.auth.userId missing → "nw-community-bound-expert"
    var u = (typeof NW !== "undefined" && NW.auth) ? NW.auth.userId : "";
    var key = u ? "nw-" + u + "-community-bound-expert" : "nw-community-bound-expert";
    return localStorage.getItem(key) || "";
  } catch(e) { return ""; }
}

var _backendCheckDone = false;
// Cache the backend proId so renderMyPro can use it without re-fetching
var _cachedBackendProId = null;

/**
 * Check backend bind status. ONLY handles the "pending → accepted" transition.
 * Removal detection is handled exclusively in the notification poll to avoid
 * false-positives from concurrent async calls.
 */
async function _checkBackendBindStatus(boundProId) {
  if (typeof NW === "undefined" || !NW.auth || !NW.auth.token) return;
  try {
    var me = await fetch('/api/auth/me', {
      headers: { Authorization: 'Bearer ' + NW.auth.token }
    }).then(function(r){ return r.ok ? r.json() : null; });
    if (!me) return;

    if (me.proId) {
      var wasCached = _cachedBackendProId;
      // Store the confirmed proId so renderMyPro and messaging can use it immediately
      _cachedBackendProId = me.proId;

      // Also ensure localStorage has the proUserId so _getProUserId always finds it
      var reqs = JSON.parse(localStorage.getItem("nw-bind-requests") || "[]");
      var updated = false;
      reqs = reqs.map(function(r) {
        if (r.proId === boundProId) {
          var changed = (r.status !== "accepted" || r.proUserId !== me.proId);
          r.status = "accepted";
          r.proUserId = me.proId;
          if (changed) updated = true;
        }
        return r;
      });
      if (updated) {
        localStorage.setItem("nw-bind-requests", JSON.stringify(reqs));
      }
      // Re-render if this is the first time we confirmed the proId (so msg/plan load retries work)
      if (updated || !wasCached) {
        _backendCheckDone = true;
        renderMyPro();
      }
    }
    // NOTE: We intentionally do NOT clear the binding here if me.proId is null.
    // That is handled solely by the notification poll (which double-verifies before acting).
  } catch(e) { console.warn("[NW] backend bind check failed:", e); }
}

function getBindStatus(proId) {
  try {
    // If the backend has confirmed proId this session, treat as accepted
    if (_cachedBackendProId) return "accepted";
    var all = JSON.parse(localStorage.getItem("nw-bind-requests") || "[]");
    var req = all.find(function(r){ return r.proId === proId; });
    return req ? req.status : "none";
  } catch(e) { return "none"; }
}

function renderMyPro() {
  var el = document.getElementById("mypro-content");
  var sub = document.getElementById("mypro-subtitle");
  if (!el) return;

  var boundId = getBoundExpert();

  // Kick off backend check (async; won't block the initial render)
  if (boundId && !_backendCheckDone) {
    _backendCheckDone = true;
    _checkBackendBindStatus(boundId);
  }

  // ── NOT BOUND ──
  if (!boundId) {
    if (sub) sub.textContent = "Connect with a professional to get personalised advice";
    el.innerHTML = `
      <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;padding:64px 24px;text-align:center">
        <div style="font-size:56px;margin-bottom:16px">🩺</div>
        <div style="font-family:'Instrument Serif',serif;font-size:24px;font-style:italic;color:var(--ink);margin-bottom:8px">No nutritionist yet</div>
        <div style="font-size:14px;color:var(--ink-f);max-width:360px;line-height:1.7;margin-bottom:28px">Connect with a qualified nutrition professional to get personalised advice, meal feedback, and ongoing support tailored to your goals.</div>
        <button onclick="switchPage('community', document.getElementById('sn-community')); setTimeout(function(){ if(window._chSwitchTab) window._chSwitchTab('findpro', document.querySelector('.ch-tab:nth-child(3)')); }, 300);"
          style="padding:13px 28px;background:var(--ink);color:#fff;border:none;border-radius:10px;font-family:'Bricolage Grotesque',sans-serif;font-size:14px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:8px">
          🔍 Find a Nutritionist
        </button>
      </div>`;
    return;
  }

  var status = getBindStatus(boundId);
  var exp = EXPERTS_INFO[boundId] || { name:"Your Nutritionist", title:"", specialty:"", avatar:"?", color:"#2f8f7f", bio:"" };

  // ── PENDING ──
  if (status === "pending" || status === "none") {
    if (sub) sub.textContent = "Request sent — waiting for your nutritionist to confirm";
    el.innerHTML = `
      <div style="background:var(--white);border:1px solid var(--border);border-radius:16px;padding:28px;margin-bottom:16px;box-shadow:0 4px 16px rgba(10,20,16,0.04)">
        <div style="display:flex;align-items:center;gap:16px;margin-bottom:20px">
          <div style="width:64px;height:64px;border-radius:50%;background:${exp.color};color:#fff;display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:700;flex-shrink:0">${exp.avatar}</div>
          <div>
            <div style="font-size:17px;font-weight:700;color:var(--ink)">${exp.name}</div>
            <div style="font-size:12px;color:var(--ink-f);margin-top:2px">${exp.title}</div>
            <div style="font-size:11px;color:var(--ink-f);margin-top:1px;font-family:'JetBrains Mono',monospace">${exp.bio}</div>
          </div>
        </div>
        <div style="background:#fffbeb;border:1px solid #fde68a;border-radius:10px;padding:14px 18px;display:flex;align-items:center;gap:12px">
          <span style="font-size:20px">⏳</span>
          <div>
            <div style="font-size:13px;font-weight:600;color:#92400e">Request pending</div>
            <div style="font-size:12px;color:#78350f;margin-top:2px">Your connection request has been sent. Once ${exp.name.split(' ')[0]} accepts, you will see their messages and appointments here.</div>
          </div>
        </div>
        <button onclick="window._nwUnbind && window._nwUnbind()" style="margin-top:16px;padding:8px 16px;background:transparent;color:var(--ink-f);border:1px solid var(--border);border-radius:8px;font-size:12px;cursor:pointer;font-family:'Bricolage Grotesque',sans-serif">Cancel request</button>
      </div>`;
    return;
  }

  // ── ACCEPTED — 3-tab interface ──
  if (sub) sub.textContent = "Your personalised nutrition support";

  // Load data from API — only mark as loaded once we have a proUserId to call with
  if (!_myProMsgsLoaded) {
    var _pid = _getProUserId(boundId);
    if (_pid) {
      _myProMsgsLoaded = true;
      _loadProMessages(boundId);
    }
    // else: proUserId not ready yet; leave _myProMsgsLoaded=false so next render retries
  }
  if (!_myProPlansLoaded && NW.auth.userId) {
    _myProPlansLoaded = true;
    _loadProPlans();
  }

  var currentTab = _myProActiveTab || "messages";

  // Build tab content based on active tab
  var tabContent = "";

  if (currentTab === "messages") {
    var msgsHtml = _myProMessages.map(function(m) {
      var isMe = m.from === "user";
      return `<div style="display:flex;justify-content:${isMe?"flex-end":"flex-start"};margin-bottom:10px">
        <div style="max-width:75%;background:${isMe?"var(--ink)":"var(--paper)"};color:${isMe?"#fff":"var(--ink)"};padding:10px 14px;border-radius:${isMe?"14px 14px 4px 14px":"14px 14px 14px 4px"};font-size:13px;line-height:1.55">
          ${escapeHtml(m.text)}
          <div style="font-family:'JetBrains Mono',monospace;font-size:9px;opacity:.5;margin-top:4px;text-align:right">${m.time}</div>
        </div>
      </div>`;
    }).join("");
    tabContent = `
      <div style="max-height:360px;overflow-y:auto;margin-bottom:12px;padding:4px">${msgsHtml || '<div style="text-align:center;padding:40px;color:var(--ink-f);font-size:13px">No messages yet. Start a conversation!</div>'}</div>
      <div style="display:flex;gap:8px;padding-top:10px;border-top:1px solid var(--fog)">
        <input id="mypro-msg-inp" type="text" placeholder="Send a message..." aria-label="Send message to nutritionist" onkeydown="if(event.key==='Enter')window._nwSendProMsg()" style="flex:1;padding:10px 14px;border:1px solid var(--border);border-radius:8px;font-family:'Bricolage Grotesque',sans-serif;font-size:13px;outline:none;background:var(--paper);color:var(--ink)">
        <button onclick="window._nwSendProMsg()" style="padding:10px 18px;background:var(--ink);color:#fff;border:none;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer">Send →</button>
      </div>`;
  } else if (currentTab === "plan") {
    var DAYS = ['MON','TUE','WED','THU','FRI','SAT','SUN'];
    var mealHtml = DAYS.map(function(d,i) {
      var val = (_myProPlanMeals[i] || '');
      var dot = val ? 'var(--teal)' : 'var(--fog)';
      return '<div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--fog)"><span style="font-family:JetBrains Mono,monospace;font-size:11px;font-weight:700;color:var(--ink);width:36px">'+d+'</span><span style="width:8px;height:8px;border-radius:50%;background:'+dot+';flex-shrink:0"></span><span style="font-size:13px;color:var(--ink)">'+escapeHtml(val || '—')+'</span></div>';
    }).join('');
    var trainHtml = DAYS.map(function(d,i) {
      var val = (_myProPlanTraining[i] || '');
      var dot = val ? 'var(--teal)' : 'var(--fog)';
      return '<div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--fog)"><span style="font-family:JetBrains Mono,monospace;font-size:11px;font-weight:700;color:var(--ink);width:36px">'+d+'</span><span style="width:8px;height:8px;border-radius:50%;background:'+dot+';flex-shrink:0"></span><span style="font-size:13px;color:var(--ink)">'+escapeHtml(val || '—')+'</span></div>';
    }).join('');

    var targetsHtml = '';
    if (_myProPlanTargetKcal || _myProPlanTargetProtein) {
      targetsHtml = '<div style="margin-top:16px;padding:14px;background:var(--paper);border-radius:10px"><div style="font-family:JetBrains Mono,monospace;font-size:10px;color:var(--ink-f);text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px">Daily Targets</div>';
      if (_myProPlanTargetKcal) targetsHtml += '<div style="font-size:13px;color:var(--ink)">🔥 '+_myProPlanTargetKcal+' kcal</div>';
      if (_myProPlanTargetProtein) targetsHtml += '<div style="font-size:13px;color:var(--ink);margin-top:4px">🥩 '+_myProPlanTargetProtein+'g protein</div>';
      targetsHtml += '</div>';
    }

    var notesHtml = _myProPlanNotes ? '<div style="margin-top:16px;padding:14px;background:#fffbeb;border:1px solid #fde68a;border-radius:10px"><div style="font-family:JetBrains Mono,monospace;font-size:10px;color:#92400e;text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px">📝 Pro Notes</div><div style="font-size:13px;color:#78350f;line-height:1.6">'+escapeHtml(_myProPlanNotes)+'</div></div>' : '';

    tabContent = '<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">'
      + '<div><div style="font-family:JetBrains Mono,monospace;font-size:10px;color:var(--ink-f);text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px">🍽️ Weekly Meal Plan</div>'+mealHtml+'</div>'
      + '<div><div style="font-family:JetBrains Mono,monospace;font-size:10px;color:var(--ink-f);text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px">🏋️ Training Schedule</div>'+trainHtml+'</div>'
      + '</div>'
      + targetsHtml + notesHtml;

    if (!_myProPlanMeals.some(function(v){return v;}) && !_myProPlanTraining.some(function(v){return v;})) {
      tabContent = '<div style="text-align:center;padding:40px;color:var(--ink-f);font-size:13px">Your nutritionist hasn\'t set a plan yet. Check back soon!</div>';
    }
  } else if (currentTab === "appointments") {
    var apptsHtml = _myProAppts.map(function(a) {
      var badge = a.status === "confirmed"
        ? '<span style="font-family:JetBrains Mono,monospace;font-size:9px;padding:3px 10px;border-radius:8px;background:var(--teal-lll);color:var(--teal)">✓ Confirmed</span>'
        : '<span style="font-family:JetBrains Mono,monospace;font-size:9px;padding:3px 10px;border-radius:8px;background:#fffbeb;color:#92400e">⏳ Pending</span>';
      return '<div style="display:flex;align-items:center;gap:14px;padding:14px 0;border-bottom:1px solid var(--fog)">'
        + '<div style="width:48px;height:48px;border-radius:10px;background:var(--teal-lll);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0">📅</div>'
        + '<div style="flex:1"><div style="font-size:14px;font-weight:600;color:var(--ink)">'+escapeHtml(a.type || 'Appointment')+'</div>'
        + '<div style="font-family:JetBrains Mono,monospace;font-size:11px;color:var(--ink-f);margin-top:3px">'+escapeHtml(a.date)+' · '+escapeHtml(a.time)+'</div></div>'
        + badge + '</div>';
    }).join("");
    tabContent = apptsHtml || '<div style="text-align:center;padding:40px;color:var(--ink-f);font-size:13px">No upcoming appointments. Your nutritionist will schedule sessions here.</div>';
    tabContent += '<div style="padding-top:14px;font-size:12px;color:var(--ink-f)">Appointments are managed by your nutritionist.</div>';
  }

  function tabCls(t) { return currentTab === t ? 'background:var(--ink);color:#fff' : 'background:var(--paper);color:var(--ink-f)'; }

  el.innerHTML = `
    <!-- Pro card -->
    <div style="background:var(--white);border:1px solid var(--border);border-radius:16px;padding:22px;margin-bottom:16px;box-shadow:0 4px 16px rgba(10,20,16,0.04)">
      <div style="display:flex;align-items:center;gap:16px">
        <div style="width:64px;height:64px;border-radius:50%;background:${exp.color};color:#fff;display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:700;flex-shrink:0">${exp.avatar}</div>
        <div style="flex:1">
          <div style="font-size:17px;font-weight:700;color:var(--ink)">${exp.name}</div>
          <div style="font-size:12px;color:var(--ink-f);margin-top:2px">${exp.title} · ${exp.specialty}</div>
        </div>
        <div style="display:flex;flex-direction:column;gap:6px;flex-shrink:0">
          <span style="font-family:'JetBrains Mono',monospace;font-size:9px;padding:3px 10px;border-radius:8px;background:var(--teal-lll);color:var(--teal)">✓ Connected</span>
          <button onclick="window._nwUnbind && window._nwUnbind()" style="padding:5px 10px;background:transparent;color:var(--ink-f);border:1px solid var(--border);border-radius:6px;font-size:10px;cursor:pointer;font-family:'Bricolage Grotesque',sans-serif">Disconnect</button>
        </div>
      </div>
    </div>

    <!-- Tabs -->
    <div style="display:flex;gap:6px;margin-bottom:16px">
      <button onclick="window._myProSwitchTab('messages')" style="padding:9px 18px;border:none;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;font-family:'Bricolage Grotesque',sans-serif;${tabCls('messages')}">💬 Messages</button>
      <button onclick="window._myProSwitchTab('plan')" style="padding:9px 18px;border:none;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;font-family:'Bricolage Grotesque',sans-serif;${tabCls('plan')}">📋 Fitness Plan</button>
      <button onclick="window._myProSwitchTab('appointments')" style="padding:9px 18px;border:none;border-radius:8px;font-size:12px;font-weight:600;cursor:pointer;font-family:'Bricolage Grotesque',sans-serif;${tabCls('appointments')}">📅 Appointments</button>
    </div>

    <!-- Tab content -->
    <div style="background:var(--white);border:1px solid var(--border);border-radius:16px;padding:22px;box-shadow:0 4px 16px rgba(10,20,16,0.04)">
      ${tabContent}
    </div>`;
}

// Unbind action — clears backend binding + localStorage
window._nwUnbind = async function() {
  try {
    // Call backend self-unbind (best effort; proceed even if it fails)
    if (typeof NW !== "undefined" && NW.auth && NW.auth.token) {
      try {
        await fetch('/api/clients/self-unbind', {
          method: 'DELETE',
          headers: { 'Authorization': 'Bearer ' + NW.auth.token }
        });
      } catch(e) { console.warn("[NW] self-unbind API call failed:", e); }
    }
  } catch(e) {}

  try {
    var u2 = (typeof NW !== "undefined" && NW.auth) ? NW.auth.userId : "";
    var unbindKey = u2 ? "nw-" + u2 + "-community-bound-expert" : "nw-community-bound-expert";
    localStorage.removeItem(unbindKey);
    // Mark bind requests as cancelled
    var all = JSON.parse(localStorage.getItem("nw-bind-requests") || "[]");
    var myId = u2 || "";
    all = all.filter(function(r) {
      return r.userId !== myId && r.userId !== ("u-" + myId);
    });
    localStorage.setItem("nw-bind-requests", JSON.stringify(all));
    if (window._chClearBound) window._chClearBound();
  } catch(e) {}

  // Reset plan data and cached backend state
  _myProMsgsLoaded = false;
  _myProPlansLoaded = false;
  _myProPlanMeals = ['','','','','','',''];
  _myProPlanTraining = ['','','','','','',''];
  _myProPlanTargetKcal = null;
  _myProPlanTargetProtein = null;
  _myProPlanNotes = null;
  _backendCheckDone = false;
  _cachedBackendProId = null;
  renderMyPro();
  if (typeof showToast === "function") showToast("Disconnected from nutritionist");
};

// Send message via API
window._nwSendProMsg = async function() {
  var inp = document.getElementById("mypro-msg-inp");
  var text = inp ? inp.value.trim() : "";
  if (!text) return;
  inp.value = "";

  // Find the pro's userId
  var boundId = getBoundExpert();
  var proUserId = _getProUserId(boundId);

  // Optimistic UI update
  _myProMessages.push({ from:"user", text:text, time:"Just now" });
  renderMyPro();

  // Send via API if possible
  if (typeof NW !== "undefined" && NW.messages && proUserId) {
    try {
      await NW.messages.send(proUserId, text);
    } catch(e) { console.warn("[NW] send to pro failed:", e.message); }
  }
};

// Re-render when page becomes active (so status updates are reflected)
var _origSwitchPagePro = window.switchPage;
window.switchPage = function(p, el) {
  if (_origSwitchPagePro) _origSwitchPagePro(p, el);
  if (p === "mypro") { _myProMsgsLoaded = false; _myProPlansLoaded = false; _backendCheckDone = false; /* keep _cachedBackendProId — avoids re-flash if still bound */ setTimeout(renderMyPro, 50); }
};

document.addEventListener("DOMContentLoaded", function() {
  // Listen for localStorage changes (e.g., pro accepts from another tab)
  window.addEventListener("storage", function(e) {
    if (e.key === "nw-bind-requests") {
      var active = document.getElementById("page-mypro");
      if (active && active.classList.contains("active")) renderMyPro();
    }
  });

  // ── Periodic bind-status check: poll backend every 15s while on mypro page ──
  setInterval(function() {
    var active = document.getElementById("page-mypro");
    if (!active || !active.classList.contains("active")) return;
    var boundId = getBoundExpert();
    if (!boundId) return;
    _backendCheckDone = false;
    _checkBackendBindStatus(boundId);
  }, 15000);

  // ── Notification check helper (reused by both immediate + interval) ──
  async function _checkUserNotifs() {
    if (typeof NW === "undefined" || !NW.auth || !NW.auth.token) return;
    try {
      var data = await NW.notifications.getUnreadCount();
      var count = (data && data.unreadCount) || 0;
      var mailDot = document.getElementById("userMailDot");
      if (mailDot) mailDot.style.display = count > 0 ? 'block' : 'none';
      var sn = document.getElementById("sn-mypro");
      if (sn) {
        var dot = sn.querySelector(".nw-notif-dot");
        if (count > 0) {
          if (!dot) { dot = document.createElement("span"); dot.className = "nw-notif-dot"; dot.style.cssText = "display:inline-block;width:7px;height:7px;border-radius:50%;background:#dc2626;margin-left:4px;vertical-align:middle"; sn.appendChild(dot); }
        } else { if (dot) dot.remove(); }
      }
    } catch(e) {}
  }

  // Run immediately at startup (so dots appear without waiting 20s)
  setTimeout(_checkUserNotifs, 1500);

  // ── Notification polling: check for plan updates & messages every 20s ──
  setInterval(async function() {
    if (typeof NW === "undefined" || !NW.auth || !NW.auth.token) return;
    // Update dots via shared helper
    await _checkUserNotifs();
    try {
      var data = await NW.notifications.getUnreadCount();
      var count = (data && data.unreadCount) || 0;
      if (count > 0) {
        var notifs = await NW.notifications.getAll(true);
        if (!Array.isArray(notifs)) return;
        for (var ni = 0; ni < notifs.length; ni++) {
          var n = notifs[ni];
          if (n.type === "plan_updated" || n.type === "plan_deleted") {
            _myProPlansLoaded = false;
            _myProPlanMeals = ['','','','','','',''];
            _myProPlanTraining = ['','','','','','',''];
            var planMsg = n.type === "plan_updated"
              ? "🔔 Your nutritionist updated your plan — check it out"
              : "🔔 Your nutritionist deleted a plan";
            if (typeof showToast === "function") showToast(planMsg);
            await NW.notifications.markRead(n.id);
          } else if (n.type === "message_received") {
            if (typeof showToast === "function") showToast("💬 New message from your nutritionist");
            await NW.notifications.markRead(n.id);
          } else if (n.type === "user_unbound") {
            // Verify we are ACTUALLY unbound before clearing local state.
            // A stale notification from a previous session could fire right after
            // a new pro has accepted us — always double-check the backend.
            try {
              var meCheck = await fetch('/api/auth/me', {
                headers: { 'Authorization': 'Bearer ' + NW.auth.token }
              }).then(function(r){ return r.ok ? r.json() : null; });
              if (meCheck && meCheck.proId) {
                // We are still bound — stale notification, just mark read
                await NW.notifications.markRead(n.id);
                continue;
              }
            } catch(e) { continue; }
            // Genuinely unbound — clear local binding
            if (typeof showToast === "function") showToast("⚠️ Your nutritionist has removed you from their client list");
            var u3 = NW.auth.userId || "";
            var uk = u3 ? "nw-" + u3 + "-community-bound-expert" : "nw-community-bound-expert";
            localStorage.removeItem(uk);
            var allR = JSON.parse(localStorage.getItem("nw-bind-requests") || "[]");
            allR = allR.filter(function(r){ return r.userId !== u3; });
            localStorage.setItem("nw-bind-requests", JSON.stringify(allR));
            if (window._chClearBound) window._chClearBound();
            _backendCheckDone = false;
            _cachedBackendProId = null;
            var myProPage = document.getElementById("page-mypro");
            if (myProPage && myProPage.classList.contains("active")) renderMyPro();
            await NW.notifications.markRead(n.id);
          }
        }
      }
    } catch(e) { /* ignore polling errors */ }
  }, 20000);
});

})();
</script>

<script>
// ── Populate Personal Details from auth session ──
document.addEventListener('DOMContentLoaded', function() {
  if (typeof NW === 'undefined' || !NW.auth || !NW.auth.name) return;
  var name = NW.auth.name || '';
  var parts = name.split(' ');
  var firstName = parts[0] || '';
  var lastName = parts.slice(1).join(' ') || '';
  var email = NW.auth.email || sessionStorage.getItem('nw-email') || '';
  var initials = parts.map(function(w){return (w[0]||'').toUpperCase();}).join('').substring(0,2);
  
  // Update avatar in top nav
  var avatarPic = document.querySelector('.tn-avatar-pic');
  if (avatarPic) avatarPic.textContent = initials;
  var avatarName = document.querySelector('.tn-avatar-name');
  if (avatarName) avatarName.textContent = name;
  
  // Update Personal Details overlay
  var overlay = document.getElementById('overlay-personal');
  if (!overlay) return;
  var inputs = overlay.querySelectorAll('input[type="text"], input[type="email"]');
  if (inputs[0]) inputs[0].value = firstName;
  if (inputs[1]) inputs[1].value = lastName;
  if (inputs[2]) inputs[2].value = email;
  
  // Update avatar in overlay
  var bigAvatar = overlay.querySelector('div[style*="width:64px"]');
  if (bigAvatar) bigAvatar.textContent = initials;
  var nameDiv = overlay.querySelector('div[style*="font-size:18px"]');
  if (nameDiv) nameDiv.textContent = name;
  
  // Load profile from backend
  if (NW.auth.token) {
    fetch('/api/auth/me', { headers: { Authorization: 'Bearer ' + NW.auth.token } })
      .then(function(r){ return r.ok ? r.json() : null; })
      .then(function(me) {
        if (!me) return;
        if (me.height)     { var el = document.getElementById('profileHeight');     if(el) el.value = me.height; }
        if (me.weight)     { var el = document.getElementById('profileWeight');     if(el) el.value = me.weight; }
        if (me.age)        { var el = document.getElementById('profileAge');        if(el) el.value = me.age; }
        if (me.targetKcal) { var el = document.getElementById('profileTargetKcal'); if(el) el.value = me.targetKcal; }
        if (me.goal)       { var el = document.getElementById('profileGoal');       if(el) el.value = me.goal; }
      }).catch(function(){});
  }
});

// ── Save Health Profile to backend ──
window.saveHealthProfile = async function() {
  if (typeof NW === 'undefined' || !NW.auth || !NW.auth.token) return;
  var height     = parseFloat(document.getElementById('profileHeight')?.value) || null;
  var weight     = parseFloat(document.getElementById('profileWeight')?.value) || null;
  var age        = parseInt(document.getElementById('profileAge')?.value)       || null;
  var targetKcal = parseInt(document.getElementById('profileTargetKcal')?.value) || null;
  var goal       = document.getElementById('profileGoal')?.value || null;
  try {
    await fetch('/api/auth/profile', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + NW.auth.token },
      body: JSON.stringify({ height, weight, age, targetKcal, goal })
    });
    var btn = document.getElementById('profileSaveBtn');
    if (btn) { var orig = btn.textContent; btn.textContent = '✓ Saved!'; btn.style.background = 'var(--teal)'; setTimeout(function(){ btn.textContent = orig; btn.style.background = ''; }, 2000); }
  } catch(e) { console.warn('[NW] profile save failed:', e); }
};
</script>
</body>
</html>
